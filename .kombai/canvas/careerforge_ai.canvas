      "html": "\n<div class=\"bg-[#09090B] text-white selection:bg-[#6366F1]/30 selection:text-[#6366F1] font-sans\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=DM+Sans:wght@400;500&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .font-sans { font-family: 'Inter', sans-serif; }\n        .font-body { font-family: 'DM Sans', sans-serif; }\n        \n        /* Custom scrollbar for better dark mode feel */\n        ::-webkit-scrollbar { width: 8px; }\n        ::-webkit-scrollbar-track { background: #09090B; }\n        ::-webkit-scrollbar-thumb { background: #18181B; border-radius: 10px; }\n        ::-webkit-scrollbar-thumb:hover { background: #6366F1; }\n\n        .glass {\n            background: rgba(255, 255, 255, 0.02);\n            backdrop-filter: blur(16px);\n            border: 1px solid rgba(255, 255, 255, 0.08);\n        }\n\n        .neon-glow {\n            box-shadow: 0 0 30px rgba(99, 102, 241, 0.25), 0 0 60px rgba(99, 102, 241, 0.1);\n        }\n    </style>\n\n    \n    <nav class=\"absolute top-0 left-0 z-50 w-full border-b border-white/5 bg-[#09090B]/80 backdrop-blur-md\" data-kid=\"2\">\n        <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\" data-kid=\"3\">\n            <div class=\"flex items-center gap-2\" data-kid=\"4\">\n                <div class=\"w-10 h-10 bg-[#6366F1] rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-[0_0_20px_rgba(99,102,241,0.4)]\" data-kid=\"5\">\n                    CF\n                </div>\n                <span class=\"text-xl font-bold tracking-tight\" data-kid=\"6\">CareerForge <span class=\"text-[#6366F1]\" data-kid=\"7\">AI</span></span>\n            </div>\n            <div class=\"hidden md:flex items-center gap-8\" data-kid=\"8\">\n                <a href=\"#\" class=\"text-sm font-medium text-gray-400 hover:text-white transition-colors\" data-kid=\"9\">Features</a>\n                <a href=\"#\" class=\"text-sm font-medium text-gray-400 hover:text-white transition-colors\" data-kid=\"10\">How It Works</a>\n                <a href=\"#\" class=\"text-sm font-medium text-gray-400 hover:text-white transition-colors\" data-kid=\"11\">Success Stories</a>\n                <a href=\"#\" class=\"text-sm font-medium text-gray-400 hover:text-white transition-colors\" data-kid=\"12\">Pricing</a>\n            </div>\n            <div class=\"flex items-center gap-4\" data-kid=\"13\">\n                <button class=\"text-sm font-medium text-gray-400 hover:text-white transition-colors\" data-kid=\"14\">Log In</button>\n                <button class=\"px-5 py-2.5 bg-[#6366F1] hover:bg-[#4f46e5] text-white rounded-lg text-sm font-semibold transition-all\" data-kid=\"15\">Get Started</button>\n            </div>\n        </div>\n    </nav>\n\n    \n    <section class=\"relative pt-24 pb-32 px-6 overflow-hidden min-h-[950px] flex flex-col items-center\" data-kid=\"16\">\n        \n        <div class=\"absolute -top-[20%] left-1/2 -translate-x-1/2 w-[1000px] h-[700px] bg-[#6366F1]/20 rounded-full blur-[180px] pointer-events-none\" data-kid=\"17\"></div>\n        \n        <div class=\"max-w-4xl mx-auto text-center relative z-10 mb-24\" data-kid=\"18\">\n            <div class=\"inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#6366F1]/10 border border-[#6366F1]/20 text-[#6366F1] text-xs font-semibold mb-8 uppercase tracking-wider\" data-kid=\"19\">\n                <i class=\"ti ti-sparkles\" data-kid=\"20\"></i>\n                <span data-kid=\"21\">Trusted by 50,000+ Job Seekers</span>\n            </div>\n            <h1 class=\"text-6xl md:text-8xl font-extrabold tracking-tighter mb-8 leading-[0.95] bg-clip-text text-transparent bg-gradient-to-b from-white to-white/60\" data-kid=\"22\">\n                Land More Interviews <br data-kid=\"23\"> <span class=\"text-[#6366F1]\" data-kid=\"24\">With AI.</span>\n            </h1>\n            <p class=\"text-xl text-gray-400 mb-12 max-w-2xl mx-auto font-body leading-relaxed\" data-kid=\"25\">\n                Optimize resumes, improve ATS scores, generate tailored applications, and track every opportunity from one unified dashboard.\n            </p>\n            <div class=\"flex flex-wrap items-center justify-center gap-5\" data-kid=\"26\">\n                <button class=\"px-8 py-4 bg-[#6366F1] hover:bg-[#4f46e5] text-white rounded-xl font-bold transition-all shadow-[0_0_25px_rgba(99,102,241,0.4)] text-lg\" data-kid=\"27\">\n                    Get Started Free\n                </button>\n                <button class=\"px-8 py-4 bg-white/5 hover:bg-white/10 border border-white/10 text-white rounded-xl font-bold transition-all backdrop-blur-sm flex items-center gap-2 text-lg\" data-kid=\"28\">\n                    <i class=\"ti ti-player-play-filled\" data-kid=\"29\"></i>\n                    Watch Demo\n                </button>\n            </div>\n        </div>\n\n        \n        <div class=\"max-w-6xl mx-auto w-full relative z-10 group\" data-kid=\"30\">\n            <div class=\"absolute -inset-1 bg-gradient-to-r from-[#6366F1]/20 to-violet-500/20 rounded-[2rem] blur-2xl group-hover:blur-3xl transition-all duration-500\" data-kid=\"31\"></div>\n            <div class=\"relative bg-[#18181B] rounded-2xl border border-white/10 shadow-2xl overflow-hidden\" data-kid=\"32\">\n                <div class=\"h-12 border-b border-white/5 bg-[#18181B] flex items-center px-4 gap-4\" data-kid=\"33\">\n                    <div class=\"flex gap-2\" data-kid=\"34\">\n                        <div class=\"w-3 h-3 rounded-full bg-red-500/30\" data-kid=\"35\"></div>\n                        <div class=\"w-3 h-3 rounded-full bg-amber-500/30\" data-kid=\"36\"></div>\n                        <div class=\"w-3 h-3 rounded-full bg-emerald-500/30\" data-kid=\"37\"></div>\n                    </div>\n                    <div class=\"flex-1 bg-black/40 rounded-lg h-7 border border-white/5 flex items-center px-4 text-xs text-gray-500 font-mono\" data-kid=\"38\">\n                        careerforge.ai/dashboard/resume-analyzer\n                    </div>\n                </div>\n                <div class=\"aspect-[16/9] w-full bg-[#09090B]\" data-kid=\"39\">\n                    <img src=\"https://images.pexels.com/photos/27141316/pexels-photo-27141316.jpeg?auto=compress&cs=tinysrgb&w=1600&q=80\" alt=\"Dashboard Visualization\" class=\"w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"40\">\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-20 border-y border-white/5 bg-black/20\" data-kid=\"41\">\n        <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"42\">\n            <p class=\"text-center text-gray-400 text-[10px] font-bold uppercase tracking-[0.4em] mb-14 opacity-60\" data-kid=\"43\">Pioneering the future of careers with users from</p>\n            <div class=\"flex flex-wrap items-center justify-center gap-10 md:gap-24 grayscale hover:grayscale-0 transition-all duration-700\" data-kid=\"44\">\n                <img src=\"https://upload.wikimedia.org/wikipedia/commons/2/2f/Google_2015_logo.svg\" alt=\"Google\" class=\"h-5 w-auto invert opacity-60 hover:opacity-100 transition-opacity\" decoding=\"async\" loading=\"lazy\" data-kid=\"45\">\n                <img src=\"https://upload.wikimedia.org/wikipedia/commons/9/96/Microsoft_logo_%282012%29.svg\" alt=\"Microsoft\" class=\"h-5 w-auto invert opacity-60 hover:opacity-100 transition-opacity\" decoding=\"async\" loading=\"lazy\" data-kid=\"46\">\n                <img src=\"https://upload.wikimedia.org/wikipedia/commons/a/a9/Amazon_logo.svg\" alt=\"Amazon\" class=\"h-5 w-auto invert opacity-60 hover:opacity-100 transition-opacity\" decoding=\"async\" loading=\"lazy\" data-kid=\"47\">\n                <img src=\"https://upload.wikimedia.org/wikipedia/commons/7/7b/Meta_Platforms_Inc._logo.svg\" alt=\"Meta\" class=\"h-5 w-auto invert opacity-60 hover:opacity-100 transition-opacity\" decoding=\"async\" loading=\"lazy\" data-kid=\"48\">\n                <img src=\"https://upload.wikimedia.org/wikipedia/commons/0/08/Netflix_2015_logo.svg\" alt=\"Netflix\" class=\"h-5 w-auto invert opacity-60 hover:opacity-100 transition-opacity\" decoding=\"async\" loading=\"lazy\" data-kid=\"49\">\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"features\" class=\"py-32 px-6\" data-kid=\"50\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"51\">\n            <div class=\"text-center mb-24\" data-kid=\"52\">\n                <h2 class=\"text-4xl md:text-5xl font-bold mb-6 tracking-tight\" data-kid=\"53\">Built For High-Performance Careers</h2>\n                <p class=\"text-gray-400 text-xl max-w-2xl mx-auto font-body\" data-kid=\"54\">Everything you need to automate the boring parts of job searching and focus on winning interviews.</p>\n            </div>\n            \n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\" data-kid=\"55\">\n                \n                <div class=\"md:col-span-2 bg-[#18181B] rounded-[2rem] p-10 border border-white/5 relative overflow-hidden group hover:border-[#6366F1]/40 transition-all\" data-kid=\"56\">\n                    <div class=\"relative z-10 flex flex-col justify-between h-full\" data-kid=\"57\">\n                        <div data-kid=\"58\">\n                            <div class=\"w-14 h-14 rounded-2xl bg-[#6366F1]/10 flex items-center justify-center text-[#6366F1] mb-8 border border-[#6366F1]/20\" data-kid=\"59\">\n                                <i class=\"ti ti-search text-3xl\" data-kid=\"60\"></i>\n                            </div>\n                            <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"61\">ATS Resume Scanner</h3>\n                            <p class=\"text-gray-400 text-lg max-w-md font-body\" data-kid=\"62\">Scan your resume against 100+ Applicant Tracking Systems to identify hidden blockers and missing keywords.</p>\n                        </div>\n                        <div class=\"mt-12 bg-black/40 rounded-2xl border border-white/5 p-6 flex flex-col gap-4\" data-kid=\"63\">\n                            <div class=\"flex items-center justify-between\" data-kid=\"64\">\n                                <span class=\"text-sm font-medium text-gray-400\" data-kid=\"65\">ATS Compatibility</span>\n                                <span class=\"text-sm font-bold text-emerald-400\" data-kid=\"66\">92% (High)</span>\n                            </div>\n                            <div class=\"w-full h-2 bg-white/5 rounded-full overflow-hidden\" data-kid=\"67\">\n                                <div class=\"w-[92%] h-full bg-emerald-500 rounded-full\" data-kid=\"68\"></div>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"absolute -right-16 -bottom-16 w-80 h-80 bg-[#6366F1]/5 rounded-full blur-[80px]\" data-kid=\"69\"></div>\n                </div>\n\n                \n                <div class=\"bg-[#18181B] rounded-[2rem] p-10 border border-white/5 flex flex-col group hover:border-[#6366F1]/40 transition-all\" data-kid=\"70\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-8 border border-emerald-500/20 group-hover:rotate-12 transition-transform\" data-kid=\"71\">\n                        <i class=\"ti ti-sparkles text-3xl\" data-kid=\"72\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"73\">Resume Optimizer</h3>\n                    <p class=\"text-gray-400 font-body\" data-kid=\"74\">AI-powered suggestions to transform passive bullet points into results-oriented impact statements.</p>\n                    <div class=\"mt-auto pt-10\" data-kid=\"75\">\n                        <div class=\"p-4 rounded-xl bg-black/40 border border-white/5 text-xs font-mono text-gray-500\" data-kid=\"76\">\n                             <div class=\"mb-2 line-through text-red-500/70\" data-kid=\"77\">\"Managed a team of five people.\"</div>\n                             <div class=\"text-emerald-400 font-bold\" data-kid=\"78\">\"Directed cross-functional team of 5, increasing output by 25%.\"</div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"bg-[#18181B] rounded-[2rem] p-10 border border-white/5 flex flex-col group hover:border-[#6366F1]/40 transition-all\" data-kid=\"79\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-amber-500/10 flex items-center justify-center text-amber-500 mb-8 border border-amber-500/20 group-hover:scale-110 transition-transform\" data-kid=\"80\">\n                        <i class=\"ti ti-target text-3xl\" data-kid=\"81\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"82\">Job Match Analyzer</h3>\n                    <p class=\"text-gray-400 font-body\" data-kid=\"83\">Input any job description and instantly see your fit score and specific skill gaps that need addressing.</p>\n                </div>\n\n                \n                <div class=\"md:col-span-2 bg-[#18181B] rounded-[2rem] p-10 border border-white/5 relative overflow-hidden group hover:border-[#6366F1]/40 transition-all\" data-kid=\"84\">\n                    <div class=\"relative z-10 flex flex-col md:flex-row gap-12 items-center h-full\" data-kid=\"85\">\n                        <div class=\"flex-1\" data-kid=\"86\">\n                            <div class=\"w-14 h-14 rounded-2xl bg-violet-500/10 flex items-center justify-center text-violet-500 mb-8 border border-violet-500/20\" data-kid=\"87\">\n                                <i class=\"ti ti-file-text text-3xl\" data-kid=\"88\"></i>\n                            </div>\n                            <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"89\">Cover Letter Generator</h3>\n                            <p class=\"text-gray-400 text-lg font-body\" data-kid=\"90\">Generate personalized, high-conversion cover letters tailored to each job posting in seconds.</p>\n                        </div>\n                        <div class=\"w-full md:w-64 aspect-[3/4] bg-black/40 rounded-2xl border border-white/5 p-6 flex flex-col gap-3 group-hover:-translate-y-2 transition-transform\" data-kid=\"91\">\n                            <div class=\"h-2 w-1/3 bg-[#6366F1]/40 rounded\" data-kid=\"92\"></div>\n                            <div class=\"mt-4 h-1.5 w-full bg-white/5 rounded\" data-kid=\"93\"></div>\n                            <div class=\"h-1.5 w-full bg-white/5 rounded\" data-kid=\"94\"></div>\n                            <div class=\"h-1.5 w-3/4 bg-white/5 rounded\" data-kid=\"95\"></div>\n                            <div class=\"mt-6 h-1.5 w-full bg-[#6366F1]/10 rounded\" data-kid=\"96\"></div>\n                            <div class=\"h-1.5 w-full bg-[#6366F1]/10 rounded\" data-kid=\"97\"></div>\n                            <div class=\"h-1.5 w-2/3 bg-[#6366F1]/10 rounded\" data-kid=\"98\"></div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"bg-[#18181B] rounded-[2rem] p-10 border border-white/5 flex flex-col group hover:border-[#6366F1]/40 transition-all overflow-hidden relative\" data-kid=\"99\">\n                    <div class=\"relative z-10\" data-kid=\"100\">\n                        <div class=\"w-14 h-14 rounded-2xl bg-[#6366F1]/10 flex items-center justify-center text-[#6366F1] mb-8 border border-[#6366F1]/20\" data-kid=\"101\">\n                            <i class=\"ti ti-layout-kanban text-3xl\" data-kid=\"102\"></i>\n                        </div>\n                        <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"103\">Application Tracker</h3>\n                        <p class=\"text-gray-400 font-body\" data-kid=\"104\">Kanban-style tracking for your entire job hunt pipeline, from initial saved jobs to final offers.</p>\n                    </div>\n                    <div class=\"absolute -right-4 -bottom-4 w-32 h-32 opacity-10 group-hover:opacity-20 transition-opacity\" data-kid=\"105\">\n                         <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/checkered-diamond.svg\" alt=\"Deco\" class=\"w-full h-full text-[#6366F1]\" style=\"filter: brightness(0) saturate(100%) invert(43%) sepia(80%) show(2541%) hue-rotate(222deg) brightness(98%) contrast(92%);\" data-kid=\"106\">\n                    </div>\n                </div>\n                \n                <div class=\"md:col-span-3 bg-gradient-to-r from-[#18181B] to-[#18181B] border border-white/5 rounded-[2rem] p-10 flex flex-col md:flex-row items-center gap-12 group hover:border-[#6366F1]/40 transition-all\" data-kid=\"107\">\n                    <div class=\"flex-1\" data-kid=\"108\">\n                        <div class=\"w-14 h-14 rounded-2xl bg-indigo-500/10 flex items-center justify-center text-indigo-400 mb-8 border border-indigo-500/20\" data-kid=\"109\">\n                            <i class=\"ti ti-user-robot text-3xl\" data-kid=\"110\"></i>\n                        </div>\n                        <h3 class=\"text-3xl font-bold mb-4\" data-kid=\"111\">AI Career Advisor</h3>\n                        <p class=\"text-gray-400 text-lg font-body\" data-kid=\"112\">Get 24/7 expert advice on interview prep, salary negotiation, and career strategy from our specialized AI agent.</p>\n                    </div>\n                    <div class=\"flex-1 w-full max-w-lg bg-black/40 rounded-2xl border border-white/5 p-6 font-body\" data-kid=\"113\">\n                        <div class=\"space-y-4\" data-kid=\"114\">\n                            <div class=\"flex justify-start\" data-kid=\"115\">\n                                <div class=\"bg-white/5 p-4 rounded-2xl rounded-bl-none text-sm text-gray-300 max-w-[85%]\" data-kid=\"116\">How should I answer \"What's your greatest weakness?\"</div>\n                            </div>\n                            <div class=\"flex justify-end\" data-kid=\"117\">\n                                <div class=\"bg-[#6366F1]/20 p-4 rounded-2xl rounded-br-none text-sm text-indigo-300 max-w-[85%] border border-[#6366F1]/30\" data-kid=\"118\">Choose a real skill you're improving and frame it as a learning journey. For example...</div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"how-it-works\" class=\"py-32 px-6 bg-black/20\" data-kid=\"119\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"120\">\n            <div class=\"text-center mb-24\" data-kid=\"121\">\n                <h2 class=\"text-4xl md:text-5xl font-bold mb-6 tracking-tight\" data-kid=\"122\">Your Path to the Offer Letter</h2>\n                <p class=\"text-gray-400 text-xl font-body\" data-kid=\"123\">A simple, four-step process to supercharge your career.</p>\n            </div>\n\n            <div class=\"relative max-w-5xl mx-auto py-10\" data-kid=\"124\">\n                \n                <div class=\"absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[2px] bg-gradient-to-b from-transparent via-[#6366F1]/30 to-transparent hidden md:block\" data-kid=\"125\"></div>\n\n                <div class=\"space-y-24\" data-kid=\"126\">\n                    \n                    <div class=\"relative flex flex-col md:flex-row items-center gap-12 group\" data-kid=\"127\">\n                        <div class=\"flex-1 text-center md:text-right group-hover:-translate-x-2 transition-transform duration-500\" data-kid=\"128\">\n                            <h3 class=\"text-2xl font-bold mb-4 text-white group-hover:text-[#6366F1] transition-colors\" data-kid=\"129\">1. Upload Resume</h3>\n                            <p class=\"text-gray-400 font-body leading-relaxed\" data-kid=\"130\">Drag and drop your current resume. Our AI instantly parses your experience and identifies your core skills.</p>\n                        </div>\n                        <div class=\"relative z-10 w-16 h-16 rounded-full bg-[#18181B] border-4 border-[#09090B] flex items-center justify-center shadow-[0_0_25px_rgba(99,102,241,0.4)] transition-all duration-500 group-hover:scale-110 group-hover:shadow-[0_0_40px_rgba(99,102,241,0.6)]\" data-kid=\"131\">\n                            <div class=\"w-10 h-10 rounded-full bg-[#6366F1] flex items-center justify-center text-white font-bold\" data-kid=\"132\">1</div>\n                        </div>\n                        <div class=\"flex-1 hidden md:block\" data-kid=\"133\"></div>\n                    </div>\n\n                    \n                    <div class=\"relative flex flex-col md:flex-row-reverse items-center gap-12\" data-kid=\"134\">\n                        <div class=\"flex-1 text-center md:text-left\" data-kid=\"135\">\n                            <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"136\">2. Analyze Job Description</h3>\n                            <p class=\"text-gray-400 font-body\" data-kid=\"137\">Paste the link or text of a job you're interested in. We'll map your skills against their specific requirements.</p>\n                        </div>\n                        <div class=\"relative z-10 w-16 h-16 rounded-full bg-[#18181B] border-4 border-[#09090B] flex items-center justify-center shadow-[0_0_20px_rgba(99,102,241,0.3)]\" data-kid=\"138\">\n                            <div class=\"w-10 h-10 rounded-full bg-[#6366F1] flex items-center justify-center text-white font-bold\" data-kid=\"139\">2</div>\n                        </div>\n                        <div class=\"flex-1 hidden md:block\" data-kid=\"140\"></div>\n                    </div>\n\n                    \n                    <div class=\"relative flex flex-col md:flex-row items-center gap-12\" data-kid=\"141\">\n                        <div class=\"flex-1 text-center md:text-right\" data-kid=\"142\">\n                            <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"143\">3. Receive AI Recommendations</h3>\n                            <p class=\"text-gray-400 font-body\" data-kid=\"144\">Get real-time feedback on how to tailor your resume and cover letter to rank higher in their ATS.</p>\n                        </div>\n                        <div class=\"relative z-10 w-16 h-16 rounded-full bg-[#18181B] border-4 border-[#09090B] flex items-center justify-center shadow-[0_0_20px_rgba(99,102,241,0.3)]\" data-kid=\"145\">\n                            <div class=\"w-10 h-10 rounded-full bg-[#6366F1] flex items-center justify-center text-white font-bold\" data-kid=\"146\">3</div>\n                        </div>\n                        <div class=\"flex-1 hidden md:block\" data-kid=\"147\"></div>\n                    </div>\n\n                    \n                    <div class=\"relative flex flex-col md:flex-row-reverse items-center gap-12\" data-kid=\"148\">\n                        <div class=\"flex-1 text-center md:text-left\" data-kid=\"149\">\n                            <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"150\">4. Track Applications</h3>\n                            <p class=\"text-gray-400 font-body\" data-kid=\"151\">Manage all your applications from a single dashboard and stay organized throughout the interview process.</p>\n                        </div>\n                        <div class=\"relative z-10 w-16 h-16 rounded-full bg-[#18181B] border-4 border-[#09090B] flex items-center justify-center shadow-[0_0_20px_rgba(99,102,241,0.3)]\" data-kid=\"152\">\n                            <div class=\"w-10 h-10 rounded-full bg-[#6366F1] flex items-center justify-center text-white font-bold\" data-kid=\"153\">4</div>\n                        </div>\n                        <div class=\"flex-1 hidden md:block\" data-kid=\"154\"></div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"testimonials\" class=\"py-32 px-6\" data-kid=\"155\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"156\">\n            <div class=\"text-center mb-24\" data-kid=\"157\">\n                <h2 class=\"text-4xl md:text-5xl font-bold mb-6 tracking-tight\" data-kid=\"158\">Success Stories</h2>\n                <p class=\"text-gray-400 text-xl font-body\" data-kid=\"159\">Join thousands who have accelerated their career with CareerForge.</p>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"160\">\n                \n                <div class=\"glass pt-16 pb-10 px-10 rounded-[2rem] border border-white/[0.08] relative group\" data-kid=\"161\">\n                    <div class=\"absolute -top-10 left-10\" data-kid=\"162\">\n                        <img src=\"https://i.pravatar.cc/150?u=sarah\" alt=\"User\" class=\"w-20 h-20 rounded-2xl border-2 border-[#6366F1] shadow-xl shadow-[#6366F1]/20 group-hover:scale-105 transition-transform\" decoding=\"async\" loading=\"lazy\" data-kid=\"163\">\n                    </div>\n                    <div class=\"mt-4 mb-6 text-[#6366F1]\" data-kid=\"164\">\n                        <i class=\"ti ti-star-filled\" data-kid=\"165\"></i><i class=\"ti ti-star-filled\" data-kid=\"166\"></i><i class=\"ti ti-star-filled\" data-kid=\"167\"></i><i class=\"ti ti-star-filled\" data-kid=\"168\"></i><i class=\"ti ti-star-filled\" data-kid=\"169\"></i>\n                    </div>\n                    <p class=\"text-lg text-gray-300 font-body italic mb-8\" data-kid=\"170\">\"CareerForge was the game-changer for me. I went from zero responses to three interviews at top-tier tech companies within two weeks. The ATS scanner is magic.\"</p>\n                    <div data-kid=\"171\">\n                        <h4 class=\"font-bold text-white\" data-kid=\"172\">Sarah Jenkins</h4>\n                        <p class=\"text-sm text-gray-500 font-medium uppercase tracking-wider\" data-kid=\"173\">Product Designer @ Meta</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"glass pt-16 pb-10 px-10 rounded-[2rem] border border-white/[0.08] relative group md:mt-12\" data-kid=\"174\">\n                    <div class=\"absolute -top-10 left-10\" data-kid=\"175\">\n                        <img src=\"https://i.pravatar.cc/150?u=michael\" alt=\"User\" class=\"w-20 h-20 rounded-2xl border-2 border-[#6366F1] shadow-xl shadow-[#6366F1]/20 group-hover:scale-105 transition-transform\" decoding=\"async\" loading=\"lazy\" data-kid=\"176\">\n                    </div>\n                    <div class=\"mt-4 mb-6 text-[#6366F1]\" data-kid=\"177\">\n                        <i class=\"ti ti-star-filled\" data-kid=\"178\"></i><i class=\"ti ti-star-filled\" data-kid=\"179\"></i><i class=\"ti ti-star-filled\" data-kid=\"180\"></i><i class=\"ti ti-star-filled\" data-kid=\"181\"></i><i class=\"ti ti-star-filled\" data-kid=\"182\"></i>\n                    </div>\n                    <p class=\"text-lg text-gray-300 font-body italic mb-8\" data-kid=\"183\">\"The AI Career Advisor gave me better salary negotiation tips than my paid coach. I ended up negotiating a 20% higher offer. Worth every penny of the Pro plan.\"</p>\n                    <div data-kid=\"184\">\n                        <h4 class=\"font-bold text-white\" data-kid=\"185\">Michael Chen</h4>\n                        <p class=\"text-sm text-gray-500 font-medium uppercase tracking-wider\" data-kid=\"186\">Sr. Software Engineer @ Google</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"glass pt-16 pb-10 px-10 rounded-[2rem] border border-white/[0.08] relative group md:mt-24\" data-kid=\"187\">\n                    <div class=\"absolute -top-10 left-10\" data-kid=\"188\">\n                        <img src=\"https://i.pravatar.cc/150?u=emily\" alt=\"User\" class=\"w-20 h-20 rounded-2xl border-2 border-[#6366F1] shadow-xl shadow-[#6366F1]/20 group-hover:scale-105 transition-transform\" decoding=\"async\" loading=\"lazy\" data-kid=\"189\">\n                    </div>\n                    <div class=\"mt-4 mb-6 text-[#6366F1]\" data-kid=\"190\">\n                        <i class=\"ti ti-star-filled\" data-kid=\"191\"></i><i class=\"ti ti-star-filled\" data-kid=\"192\"></i><i class=\"ti ti-star-filled\" data-kid=\"193\"></i><i class=\"ti ti-star-filled\" data-kid=\"194\"></i><i class=\"ti ti-star-filled\" data-kid=\"195\"></i>\n                    </div>\n                    <p class=\"text-lg text-gray-300 font-body italic mb-8\" data-kid=\"196\">\"Tailoring cover letters used to take me hours. Now it takes seconds, and they sound more professional than when I write them myself. It's like having a personal assistant.\"</p>\n                    <div data-kid=\"197\">\n                        <h4 class=\"font-bold text-white\" data-kid=\"198\">Emily Rodriguez</h4>\n                        <p class=\"text-sm text-gray-500 font-medium uppercase tracking-wider\" data-kid=\"199\">Marketing Manager @ Amazon</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"pricing\" class=\"py-32 px-6 bg-[#09090B] relative\" data-kid=\"200\">\n         <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[600px] bg-[#6366F1]/5 rounded-full blur-[200px] pointer-events-none\" data-kid=\"201\"></div>\n        <div class=\"max-w-7xl mx-auto relative z-10\" data-kid=\"202\">\n            <div class=\"text-center mb-24\" data-kid=\"203\">\n                <h2 class=\"text-4xl md:text-5xl font-bold mb-6 tracking-tight\" data-kid=\"204\">Simple Pricing, Exponential Returns</h2>\n                <p class=\"text-gray-400 text-xl font-body\" data-kid=\"205\">Invest in your career. Most users see ROI in their first interview.</p>\n            </div>\n\n            <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch\" data-kid=\"206\">\n                \n                <div class=\"bg-[#18181B] rounded-[2.5rem] p-10 border border-white/5 flex flex-col h-full hover:border-white/10 transition-all\" data-kid=\"207\">\n                    <div class=\"mb-10\" data-kid=\"208\">\n                        <h3 class=\"text-xl font-bold mb-4\" data-kid=\"209\">Starter</h3>\n                        <div class=\"flex items-baseline gap-1\" data-kid=\"210\">\n                            <span class=\"text-5xl font-extrabold\" data-kid=\"211\">$0</span>\n                            <span class=\"text-gray-500 font-medium\" data-kid=\"212\">/forever</span>\n                        </div>\n                        <p class=\"text-gray-400 mt-6 font-body\" data-kid=\"213\">Perfect for exploring our AI capabilities.</p>\n                    </div>\n                    <ul class=\"space-y-5 mb-12 flex-1\" data-kid=\"214\">\n                        <li class=\"flex items-center gap-3 text-sm text-gray-300 font-body\" data-kid=\"215\">\n                            <i class=\"ti ti-circle-check-filled text-[#6366F1]\" data-kid=\"216\"></i>\n                            3 AI Resume Scans / Mo\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm text-gray-300 font-body\" data-kid=\"217\">\n                            <i class=\"ti ti-circle-check-filled text-[#6366F1]\" data-kid=\"218\"></i>\n                            Basic Resume Optimizer\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm text-gray-300 font-body\" data-kid=\"219\">\n                            <i class=\"ti ti-circle-check-filled text-[#6366F1]\" data-kid=\"220\"></i>\n                            Job Match Score\n                        </li>\n                    </ul>\n                    <button class=\"w-full py-4 bg-white/5 hover:bg-white/10 border border-white/10 text-white rounded-xl font-bold transition-all\" data-kid=\"221\">Get Started</button>\n                </div>\n\n                \n                <div class=\"bg-[#18181B] rounded-[2.5rem] p-12 border-2 border-[#6366F1] neon-glow relative flex flex-col h-full lg:scale-110 z-20\" data-kid=\"222\">\n                    <div class=\"absolute -top-5 left-1/2 -translate-x-1/2 bg-[#6366F1] text-white text-[11px] font-black uppercase tracking-[0.2em] py-2 px-5 rounded-full\" data-kid=\"223\">Most Popular</div>\n                    <div class=\"mb-10\" data-kid=\"224\">\n                        <h3 class=\"text-xl font-bold mb-4\" data-kid=\"225\">Pro</h3>\n                        <div class=\"flex items-baseline gap-1\" data-kid=\"226\">\n                            <span class=\"text-5xl font-extrabold\" data-kid=\"227\">$19</span>\n                            <span class=\"text-gray-500 font-medium\" data-kid=\"228\">/month</span>\n                        </div>\n                        <p class=\"text-gray-400 mt-6 font-body\" data-kid=\"229\">For dedicated job seekers ready to win.</p>\n                    </div>\n                    <ul class=\"space-y-5 mb-12 flex-1\" data-kid=\"230\">\n                        <li class=\"flex items-center gap-3 text-sm text-gray-200 font-body\" data-kid=\"231\">\n                            <i class=\"ti ti-circle-check-filled text-[#6366F1]\" data-kid=\"232\"></i>\n                            Unlimited AI Resume Scans\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm text-gray-200 font-body\" data-kid=\"233\">\n                            <i class=\"ti ti-circle-check-filled text-[#6366F1]\" data-kid=\"234\"></i>\n                            Advanced Bullet Point Optimizer\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm text-gray-200 font-body\" data-kid=\"235\">\n                            <i class=\"ti ti-circle-check-filled text-[#6366F1]\" data-kid=\"236\"></i>\n                            Cover Letter Generator\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm text-gray-200 font-body\" data-kid=\"237\">\n                            <i class=\"ti ti-circle-check-filled text-[#6366F1]\" data-kid=\"238\"></i>\n                            Application Kanban Tracker\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm text-gray-200 font-body\" data-kid=\"239\">\n                            <i class=\"ti ti-circle-check-filled text-[#6366F1]\" data-kid=\"240\"></i>\n                            Priority AI Queue\n                        </li>\n                    </ul>\n                    <button class=\"w-full py-5 bg-[#6366F1] hover:bg-[#4f46e5] text-white rounded-xl font-bold transition-all shadow-[0_0_20px_rgba(99,102,241,0.4)] text-lg\" data-kid=\"241\">Subscribe Now</button>\n                </div>\n\n                \n                <div class=\"bg-[#18181B] rounded-[2.5rem] p-10 border border-white/5 flex flex-col h-full hover:border-white/10 transition-all\" data-kid=\"242\">\n                    <div class=\"mb-10\" data-kid=\"243\">\n                        <h3 class=\"text-xl font-bold mb-4\" data-kid=\"244\">Elite</h3>\n                        <div class=\"flex items-baseline gap-1\" data-kid=\"245\">\n                            <span class=\"text-5xl font-extrabold\" data-kid=\"246\">$49</span>\n                            <span class=\"text-gray-500 font-medium\" data-kid=\"247\">/month</span>\n                        </div>\n                        <p class=\"text-gray-400 mt-6 font-body\" data-kid=\"248\">Concierge career success for executives.</p>\n                    </div>\n                    <ul class=\"space-y-5 mb-12 flex-1\" data-kid=\"249\">\n                        <li class=\"flex items-center gap-3 text-sm text-gray-300 font-body\" data-kid=\"250\">\n                            <i class=\"ti ti-circle-check-filled text-[#6366F1]\" data-kid=\"251\"></i>\n                            All Pro Features\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm text-gray-300 font-body\" data-kid=\"252\">\n                            <i class=\"ti ti-circle-check-filled text-[#6366F1]\" data-kid=\"253\"></i>\n                            AI Interview Prep Simulation\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm text-gray-300 font-body\" data-kid=\"254\">\n                            <i class=\"ti ti-circle-check-filled text-[#6366F1]\" data-kid=\"255\"></i>\n                            Salary Negotiation Advisor\n                        </li>\n                        <li class=\"flex items-center gap-3 text-sm text-gray-300 font-body\" data-kid=\"256\">\n                            <i class=\"ti ti-circle-check-filled text-[#6366F1]\" data-kid=\"257\"></i>\n                            Direct DM to Career Coaches\n                        </li>\n                    </ul>\n                    <button class=\"w-full py-4 bg-white/5 hover:bg-white/10 border border-white/10 text-white rounded-xl font-bold transition-all\" data-kid=\"258\">Go Premium</button>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-40 px-6 relative\" data-kid=\"259\">\n        <div class=\"absolute right-0 top-1/2 -translate-y-1/2 w-96 h-96 bg-[#6366F1]/10 rounded-full blur-[120px] pointer-events-none\" data-kid=\"260\"></div>\n        <div class=\"max-w-3xl mx-auto relative z-10\" data-kid=\"261\">\n            <div class=\"text-center mb-20\" data-kid=\"262\">\n                <h2 class=\"text-4xl md:text-5xl font-bold mb-6 tracking-tight\" data-kid=\"263\">Expert Answers</h2>\n                <p class=\"text-gray-400 text-lg font-body\" data-kid=\"264\">Everything you need to know about CareerForge AI.</p>\n            </div>\n\n            <div class=\"space-y-4\" data-kid=\"265\">\n                <details class=\"group bg-[#18181B] rounded-2xl border border-white/5 overflow-hidden\" open data-kid=\"266\">\n                    <summary class=\"flex items-center justify-between p-6 cursor-pointer list-none\" data-kid=\"267\">\n                        <span class=\"text-lg font-semibold\" data-kid=\"268\">Is my resume data secure?</span>\n                        <div class=\"w-6 h-6 border border-white/10 rounded-full flex items-center justify-center group-open:rotate-180 transition-transform\" data-kid=\"269\">\n                            <i class=\"ti ti-chevron-down\" data-kid=\"270\"></i>\n                        </div>\n                    </summary>\n                    <div class=\"px-6 pb-6 text-gray-400 font-body leading-relaxed\" data-kid=\"271\">\n                        Yes, we use industry-standard encryption to protect your data. Your resume information is used only to provide analysis and optimizations, and we never share it with third parties without your explicit consent.\n                    </div>\n                </details>\n\n                <details class=\"group bg-[#18181B] rounded-2xl border border-white/5 overflow-hidden\" data-kid=\"272\">\n                    <summary class=\"flex items-center justify-between p-6 cursor-pointer list-none\" data-kid=\"273\">\n                        <span class=\"text-lg font-semibold\" data-kid=\"274\">How accurate is the ATS scanner?</span>\n                        <div class=\"w-6 h-6 border border-white/10 rounded-full flex items-center justify-center group-open:rotate-180 transition-transform\" data-kid=\"275\">\n                            <i class=\"ti ti-chevron-down\" data-kid=\"276\"></i>\n                        </div>\n                    </summary>\n                    <div class=\"px-6 pb-6 text-gray-400 font-body leading-relaxed\" data-kid=\"277\">\n                        Our scanner is tested against top ATS platforms like Workday, Greenhouse, and Lever. It achieves a 98% accuracy rate in predicting how these systems will parse your document.\n                    </div>\n                </details>\n\n                <details class=\"group bg-[#18181B] rounded-2xl border border-white/5 overflow-hidden\" data-kid=\"278\">\n                    <summary class=\"flex items-center justify-between p-6 cursor-pointer list-none\" data-kid=\"279\">\n                        <span class=\"text-lg font-semibold\" data-kid=\"280\">Can I cancel my subscription anytime?</span>\n                        <div class=\"w-6 h-6 border border-white/10 rounded-full flex items-center justify-center group-open:rotate-180 transition-transform\" data-kid=\"281\">\n                            <i class=\"ti ti-chevron-down\" data-kid=\"282\"></i>\n                        </div>\n                    </summary>\n                    <div class=\"px-6 pb-6 text-gray-400 font-body leading-relaxed\" data-kid=\"283\">\n                        Absolutely. You can cancel your Pro or Elite subscription at any time from your account settings. You will retain access to the premium features until the end of your current billing cycle.\n                    </div>\n                </details>\n\n                <details class=\"group bg-[#18181B] rounded-2xl border border-white/5 overflow-hidden\" data-kid=\"284\">\n                    <summary class=\"flex items-center justify-between p-6 cursor-pointer list-none\" data-kid=\"285\">\n                        <span class=\"text-lg font-semibold\" data-kid=\"286\">Does the AI write cover letters for me?</span>\n                        <div class=\"w-6 h-6 border border-white/10 rounded-full flex items-center justify-center group-open:rotate-180 transition-transform\" data-kid=\"287\">\n                            <i class=\"ti ti-chevron-down\" data-kid=\"288\"></i>\n                        </div>\n                    </summary>\n                    <div class=\"px-6 pb-6 text-gray-400 font-body leading-relaxed\" data-kid=\"289\">\n                        Yes! It uses your resume and the job description to generate a highly tailored first draft. You can then refine it or ask the AI to change the tone or focus of specific sections.\n                    </div>\n                </details>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-black/40 border-t border-white/5 pt-24 pb-12 px-6\" data-kid=\"290\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"291\">\n            <div class=\"grid grid-cols-2 md:grid-cols-5 gap-12 mb-20\" data-kid=\"292\">\n                <div class=\"col-span-2\" data-kid=\"293\">\n                    <div class=\"flex items-center gap-2 mb-6\" data-kid=\"294\">\n                        <div class=\"w-10 h-10 bg-[#6366F1] rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-[0_0_20px_rgba(99,102,241,0.4)]\" data-kid=\"295\">\n                            CF\n                        </div>\n                        <span class=\"text-xl font-bold tracking-tight\" data-kid=\"296\">CareerForge <span class=\"text-[#6366F1]\" data-kid=\"297\">AI</span></span>\n                    </div>\n                    <p class=\"text-gray-500 max-w-sm font-body mb-8\" data-kid=\"298\">Empowering the next generation of professionals with cutting-edge AI career tools. Land your dream job faster.</p>\n                    <div class=\"flex gap-4\" data-kid=\"299\">\n                        <a href=\"#\" class=\"w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-[#6366F1] hover:border-[#6366F1] transition-all\" data-kid=\"300\"><i class=\"ti ti-brand-x text-xl\" data-kid=\"301\"></i></a>\n                        <a href=\"#\" class=\"w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-[#6366F1] hover:border-[#6366F1] transition-all\" data-kid=\"302\"><i class=\"ti ti-brand-linkedin text-xl\" data-kid=\"303\"></i></a>\n                        <a href=\"#\" class=\"w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-[#6366F1] hover:border-[#6366F1] transition-all\" data-kid=\"304\"><i class=\"ti ti-brand-github text-xl\" data-kid=\"305\"></i></a>\n                    </div>\n                </div>\n                <div data-kid=\"306\">\n                    <h4 class=\"font-bold mb-6\" data-kid=\"307\">Product</h4>\n                    <ul class=\"space-y-4 text-sm font-body text-gray-500\" data-kid=\"308\">\n                        <li data-kid=\"309\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"310\">Features</a></li>\n                        <li data-kid=\"311\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"312\">ATS Scanner</a></li>\n                        <li data-kid=\"313\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"314\">Resume Optimizer</a></li>\n                        <li data-kid=\"315\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"316\">Job Tracker</a></li>\n                        <li data-kid=\"317\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"318\">Pricing</a></li>\n                    </ul>\n                </div>\n                <div data-kid=\"319\">\n                    <h4 class=\"font-bold mb-6\" data-kid=\"320\">Company</h4>\n                    <ul class=\"space-y-4 text-sm font-body text-gray-500\" data-kid=\"321\">\n                        <li data-kid=\"322\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"323\">About Us</a></li>\n                        <li data-kid=\"324\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"325\">Blog</a></li>\n                        <li data-kid=\"326\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"327\">Careers</a></li>\n                        <li data-kid=\"328\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"329\">Contact</a></li>\n                    </ul>\n                </div>\n                <div data-kid=\"330\">\n                    <h4 class=\"font-bold mb-6\" data-kid=\"331\">Legal</h4>\n                    <ul class=\"space-y-4 text-sm font-body text-gray-500\" data-kid=\"332\">\n                        <li data-kid=\"333\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"334\">Privacy Policy</a></li>\n                        <li data-kid=\"335\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"336\">Terms of Service</a></li>\n                        <li data-kid=\"337\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"338\">Cookie Policy</a></li>\n                    </ul>\n                </div>\n            </div>\n            \n            <div class=\"flex flex-col md:flex-row items-center justify-between pt-12 border-t border-white/5 gap-6\" data-kid=\"339\">\n                <p class=\"text-sm text-gray-600 font-body\" data-kid=\"340\">© 2024 CareerForge AI. All rights reserved.</p>\n                <div class=\"flex items-center gap-2 text-sm text-gray-600 font-body\" data-kid=\"341\">\n                    Built with <i class=\"ti ti-heart-filled text-red-500\" data-kid=\"342\"></i> for the future of work.\n                </div>\n            </div>\n        </div>\n    </footer>\n</div>\n",
