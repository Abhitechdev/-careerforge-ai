      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=DM+Sans:wght@400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: #09090B;\n    color: #FFFFFF;\n    font-family: 'DM Sans', sans-serif;\n  }\n\n  .font-inter { font-family: 'Inter', sans-serif; }\n  .font-dm-sans { font-family: 'DM Sans', sans-serif; }\n\n  .bg-ink-black { background-color: #09090B; }\n  .bg-carbon-black { background-color: #18181B; }\n  .text-digital-blue { color: #6366F1; }\n  .bg-digital-blue { background-color: #6366F1; }\n\n  /* Glassmorphism utility */\n  .glass-panel {\n    background: rgba(24, 24, 27, 0.6);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.05);\n    border-radius: 16px;\n  }\n\n  /* Neon Glow for the Match Score */\n  .neon-glow-indigo {\n    border: 1.5px solid #6366F1;\n    box-shadow: 0 0 15px rgba(99, 102, 241, 0.2), 0 0 40px rgba(99, 102, 241, 0.1);\n  }\n\n  /* Shimmer Sweep Animation */\n  .shimmer-sweep {\n    position: relative;\n    overflow: hidden;\n  }\n  .shimmer-sweep::after {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: -100%;\n    width: 50%;\n    height: 100%;\n    background: linear-gradient(\n      90deg,\n      transparent,\n      rgba(255, 255, 255, 0.05),\n      transparent\n    );\n    animation: shimmer 4s infinite linear;\n  }\n  @keyframes shimmer {\n    0% { left: -150%; }\n    100% { left: 250%; }\n  }\n\n  .scan-line {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 2px;\n    background: linear-gradient(90deg, transparent, #6366F1, transparent);\n    animation: scan 3s infinite linear;\n    z-index: 5;\n    opacity: 0.3;\n  }\n\n  @keyframes scan {\n    0% { top: 0%; opacity: 0; }\n    50% { opacity: 0.5; }\n    100% { top: 100%; opacity: 0; }\n  }\n\n  .pulse-glow {\n    animation: pulse-glow 2s infinite ease-in-out;\n  }\n  @keyframes pulse-glow {\n    0%, 100% { filter: drop-shadow(0 0 5px rgba(99, 102, 241, 0.3)); }\n    50% { filter: drop-shadow(0 0 15px rgba(99, 102, 241, 0.6)); }\n  }\n\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 6px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: #27272a;\n    border-radius: 10px;\n  }\n</style>\n\n<div class=\"flex h-[1000px] bg-ink-black font-dm-sans overflow-hidden\" data-kid=\"1\">\n  \n  <aside class=\"w-16 border-r border-white/5 flex flex-col items-center py-8 gap-8 shrink-0 h-full\" data-kid=\"2\">\n    <div class=\"w-10 h-10 bg-digital-blue rounded-xl flex items-center justify-center shadow-[0_0_15px_rgba(99,102,241,0.5)]\" data-kid=\"3\">\n      <i class=\"ti ti-sparkles text-white text-xl\" data-kid=\"4\"></i>\n    </div>\n    <nav class=\"flex flex-col gap-6 text-zinc-500\" data-kid=\"5\">\n      <a href=\"#\" class=\"p-2 hover:text-white transition-colors\" data-kid=\"6\"><i class=\"ti ti-layout-sidebar text-2xl\" data-kid=\"7\"></i></a>\n      <a href=\"#\" class=\"p-2 text-white bg-white/5 rounded-lg\" data-kid=\"8\"><i class=\"ti ti-file-text-ai text-2xl\" data-kid=\"9\"></i></a>\n      <a href=\"#\" class=\"p-2 hover:text-white transition-colors\" data-kid=\"10\"><i class=\"ti ti-user-search text-2xl\" data-kid=\"11\"></i></a>\n      <a href=\"#\" class=\"p-2 hover:text-white transition-colors\" data-kid=\"12\"><i class=\"ti ti-report-search text-2xl\" data-kid=\"13\"></i></a>\n      <a href=\"#\" class=\"p-2 hover:text-white transition-colors\" data-kid=\"14\"><i class=\"ti ti-bell text-2xl\" data-kid=\"15\"></i></a>\n    </nav>\n    <div class=\"mt-auto\" data-kid=\"16\">\n      <img src=\"https://i.pravatar.cc/100?u=careerforge\" alt=\"User\" class=\"w-8 h-8 rounded-full border border-white/10\" decoding=\"async\" loading=\"lazy\" data-kid=\"17\">\n    </div>\n  </aside>\n\n  \n  <aside class=\"w-64 border-r border-white/5 bg-ink-black flex flex-col py-8 px-6 shrink-0 h-full\" data-kid=\"18\">\n    <h3 class=\"text-xs font-bold text-zinc-500 uppercase tracking-widest mb-6\" data-kid=\"19\">Career Tools</h3>\n    <div class=\"space-y-1\" data-kid=\"20\">\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 rounded-xl text-zinc-400 hover:bg-white/5 hover:text-white transition-all group\" data-kid=\"21\">\n        <i class=\"ti ti-dashboard text-lg\" data-kid=\"22\"></i>\n        <span class=\"font-medium\" data-kid=\"23\">Overview</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 rounded-xl bg-digital-blue/10 text-digital-blue border border-digital-blue/20 transition-all relative overflow-hidden group\" data-kid=\"24\">\n        <div class=\"absolute inset-y-0 left-0 w-1 bg-digital-blue\" data-kid=\"25\"></div>\n        <i class=\"ti ti-target text-lg\" data-kid=\"26\"></i>\n        <span class=\"font-medium\" data-kid=\"27\">Job Match Analyzer</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 rounded-xl text-zinc-400 hover:bg-white/5 hover:text-white transition-all\" data-kid=\"28\">\n        <i class=\"ti ti-file-type-txt text-lg\" data-kid=\"29\"></i>\n        <span class=\"font-medium\" data-kid=\"30\">Resume Optimizer</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 rounded-xl text-zinc-400 hover:bg-white/5 hover:text-white transition-all\" data-kid=\"31\">\n        <i class=\"ti ti-mail-spark text-lg\" data-kid=\"32\"></i>\n        <span class=\"font-medium\" data-kid=\"33\">Cover Letter Gen</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 rounded-xl text-zinc-400 hover:bg-white/5 hover:text-white transition-all\" data-kid=\"34\">\n        <i class=\"ti ti-device-laptop text-lg\" data-kid=\"35\"></i>\n        <span class=\"font-medium\" data-kid=\"36\">Interview Prep</span>\n      </a>\n    </div>\n\n    <div class=\"mt-12 space-y-6\" data-kid=\"37\">\n      <h3 class=\"text-xs font-bold text-zinc-500 uppercase tracking-widest\" data-kid=\"38\">Active Searches</h3>\n      <div class=\"space-y-4\" data-kid=\"39\">\n        <div class=\"flex flex-col gap-1\" data-kid=\"40\">\n          <div class=\"flex justify-between items-center text-sm\" data-kid=\"41\">\n            <span class=\"text-white font-medium\" data-kid=\"42\">Senior Product Designer</span>\n            <span class=\"text-xs text-digital-blue font-bold\" data-kid=\"43\">92%</span>\n          </div>\n          <div class=\"w-full bg-zinc-800 h-1 rounded-full overflow-hidden\" data-kid=\"44\">\n            <div class=\"bg-digital-blue h-full w-[92%]\" data-kid=\"45\"></div>\n          </div>\n        </div>\n        <div class=\"flex flex-col gap-1\" data-kid=\"46\">\n          <div class=\"flex justify-between items-center text-sm\" data-kid=\"47\">\n            <span class=\"text-white font-medium\" data-kid=\"48\">Frontend Architect</span>\n            <span class=\"text-xs text-zinc-500 font-bold\" data-kid=\"49\">64%</span>\n          </div>\n          <div class=\"w-full bg-zinc-800 h-1 rounded-full overflow-hidden\" data-kid=\"50\">\n            <div class=\"bg-zinc-600 h-full w-[64%]\" data-kid=\"51\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 overflow-y-auto custom-scrollbar h-full\" data-kid=\"52\">\n    \n    <header class=\"h-20 border-b border-white/5 flex items-center justify-between px-10 bg-ink-black/80 backdrop-blur-md z-20 relative shrink-0\" data-kid=\"53\">\n      <div class=\"flex items-center gap-4\" data-kid=\"54\">\n        <div class=\"flex flex-col\" data-kid=\"55\">\n          <h1 class=\"text-xl font-bold text-white font-inter tracking-tight\" data-kid=\"56\">Job Match Analyzer</h1>\n          <div class=\"flex items-center gap-2\" data-kid=\"57\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"58\"></span>\n            <span class=\"text-[10px] text-zinc-500 font-bold uppercase tracking-widest\" data-kid=\"59\">System Active: V4.2</span>\n          </div>\n        </div>\n        <span class=\"px-2 py-0.5 bg-digital-blue/20 text-digital-blue text-[10px] font-bold uppercase tracking-wider rounded border border-digital-blue/30\" data-kid=\"60\">AI Powered</span>\n      </div>\n      <div class=\"flex items-center gap-6\" data-kid=\"61\">\n        <div class=\"relative group\" data-kid=\"62\">\n          <i class=\"ti ti-search text-zinc-500 absolute left-3 top-1/2 -translate-y-1/2 group-focus-within:text-digital-blue transition-colors\" data-kid=\"63\"></i>\n          <input type=\"text\" placeholder=\"Search saved jobs...\" class=\"bg-carbon-black border border-white/5 rounded-lg py-2 pl-10 pr-4 text-sm text-zinc-300 focus:outline-hidden focus:ring-1 focus:ring-digital-blue/50 w-64\" data-kid=\"64\">\n        </div>\n        <button class=\"w-10 h-10 border border-white/10 rounded-lg flex items-center justify-center text-zinc-400 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"65\">\n          <i class=\"ti ti-settings\" data-kid=\"66\"></i>\n        </button>\n      </div>\n    </header>\n\n    \n    <div class=\"p-10 max-w-7xl mx-auto space-y-10\" data-kid=\"67\">\n      \n      \n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch\" data-kid=\"68\">\n        \n        \n        <div class=\"lg:col-span-7 flex flex-col space-y-6\" data-kid=\"69\">\n          <div class=\"space-y-1\" data-kid=\"70\">\n            <h2 class=\"text-2xl font-bold text-white font-inter flex items-center gap-3\" data-kid=\"71\">\n              <span class=\"w-8 h-8 rounded-full bg-digital-blue/10 flex items-center justify-center text-sm border border-digital-blue/20\" data-kid=\"72\">01</span>\n              Source Analysis\n            </h2>\n            <p class=\"text-zinc-500\" data-kid=\"73\">Target role description for cross-reference.</p>\n          </div>\n          \n          <div class=\"relative glass-panel p-1 group flex-1\" data-kid=\"74\">\n            <div class=\"absolute -inset-1 bg-gradient-to-br from-digital-blue/20 to-purple-500/20 rounded-2xl blur-xl opacity-0 group-focus-within:opacity-100 transition duration-1000\" data-kid=\"75\"></div>\n            <textarea class=\"w-full h-full min-h-[400px] bg-zinc-900/50 rounded-xl p-6 text-zinc-300 font-dm-sans focus:outline-hidden resize-none border-none relative z-10\" placeholder=\"Paste job posting content here... CareerForge AI will extract requirements and match them against your active profile.\" data-kid=\"76\"></textarea>\n            \n            <div class=\"absolute bottom-4 right-4 flex items-center gap-3 z-10\" data-kid=\"77\">\n              <button class=\"flex items-center gap-2 px-3 py-1.5 bg-zinc-800 hover:bg-zinc-700 rounded-lg text-xs text-zinc-400 transition-all\" data-kid=\"78\">\n                <i class=\"ti ti-clipboard\" data-kid=\"79\"></i>\n                Paste from clipboard\n              </button>\n            </div>\n          </div>\n\n          <div class=\"flex items-center justify-between pt-2\" data-kid=\"80\">\n            <div class=\"flex items-center gap-6\" data-kid=\"81\">\n              <label class=\"flex items-center gap-2 text-sm text-zinc-400 cursor-pointer hover:text-white transition-colors\" data-kid=\"82\">\n                <input type=\"checkbox\" checked class=\"w-4 h-4 rounded-sm bg-zinc-800 border-zinc-700 text-digital-blue focus:ring-digital-blue/50\" data-kid=\"83\">\n                Sync with active resume\n              </label>\n            </div>\n            <button class=\"px-10 py-4 bg-digital-blue hover:bg-digital-blue/90 text-white font-bold rounded-xl shadow-[0_8px_30px_rgba(99,102,241,0.4)] hover:shadow-[0_8px_40px_rgba(99,102,241,0.6)] transition-all flex items-center gap-3 group overflow-hidden relative\" data-kid=\"84\">\n              <span class=\"relative z-10 flex items-center gap-2\" data-kid=\"85\">\n                <i class=\"ti ti-sparkles group-hover:rotate-12 transition-transform\" data-kid=\"86\"></i>\n                Run Match Intelligence\n              </span>\n              <div class=\"absolute inset-0 bg-linear-to-r from-transparent via-white/25 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700\" data-kid=\"87\"></div>\n            </button>\n          </div>\n        </div>\n\n        \n        <div class=\"lg:col-span-5 flex flex-col space-y-6\" data-kid=\"88\">\n          <div class=\"space-y-1\" data-kid=\"89\">\n            <h2 class=\"text-2xl font-bold text-white font-inter flex items-center gap-3\" data-kid=\"90\">\n              <span class=\"w-8 h-8 rounded-full bg-digital-blue/10 flex items-center justify-center text-sm border border-digital-blue/20\" data-kid=\"91\">02</span>\n              Compatibility Score\n            </h2>\n            <p class=\"text-zinc-500\" data-kid=\"92\">AI-driven multi-factor fit assessment.</p>\n          </div>\n\n          <div class=\"glass-panel flex-1 flex flex-col items-center justify-center relative overflow-hidden neon-glow-indigo p-10 min-h-[500px]\" data-kid=\"93\">\n            \n            <div class=\"scan-line\" data-kid=\"94\"></div>\n            \n            \n            <img src=\"https://images.pexels.com/photos/27141307/pexels-photo-27141307.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"tech-bg\" class=\"absolute inset-0 w-full h-full object-cover opacity-10 pointer-events-none\" decoding=\"async\" loading=\"lazy\" data-kid=\"95\">\n            \n            <div class=\"relative w-72 h-72 flex items-center justify-center z-10\" data-kid=\"96\">\n              \n              <div class=\"absolute inset-0 rounded-full border border-digital-blue/20 scale-110 pulse-glow\" data-kid=\"97\"></div>\n              <div class=\"absolute inset-0 rounded-full border border-white/5 scale-125 border-dashed rotate-anim\" data-kid=\"98\"></div>\n              \n              \n              <svg class=\"w-full h-full transform -rotate-90 filter drop-shadow-[0_0_15px_rgba(99,102,241,0.4)]\" data-kid=\"99\">\n                <circle cx=\"144\" cy=\"144\" r=\"125\" fill=\"transparent\" stroke=\"#18181B\" stroke-width=\"12\" data-kid=\"100\"></circle>\n                <circle cx=\"144\" cy=\"144\" r=\"125\" fill=\"transparent\" stroke=\"url(#match_grad_v2)\" stroke-width=\"12\" stroke-dasharray=\"785\" stroke-dashoffset=\"117\" stroke-linecap=\"round\" class=\"transition-all duration-2000 ease-out\" data-kid=\"101\"></circle>\n                <defs data-kid=\"102\">\n                  <linearGradient id=\"match_grad_v2\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\" data-kid=\"103\">\n                    <stop offset=\"0%\" stop-color=\"#6366F1\" data-kid=\"104\"></stop>\n                    <stop offset=\"50%\" stop-color=\"#a855f7\" data-kid=\"105\"></stop>\n                    <stop offset=\"100%\" stop-color=\"#6366F1\" data-kid=\"106\"></stop>\n                  </linearGradient>\n                </defs>\n              </svg>\n              \n              \n              <div class=\"absolute flex flex-col items-center\" data-kid=\"107\">\n                <span class=\"text-7xl font-black text-white font-inter tracking-tighter\" data-kid=\"108\">85<span class=\"text-3xl text-digital-blue\" data-kid=\"109\">%</span></span>\n                <span class=\"text-xs text-zinc-500 uppercase tracking-[0.2em] font-bold mt-2\" data-kid=\"110\">Optimal Fit</span>\n              </div>\n            </div>\n\n            \n            <div class=\"grid grid-cols-3 w-full mt-12 gap-3 z-10\" data-kid=\"111\">\n              <div class=\"bg-white/5 rounded-xl p-4 border border-white/5 flex flex-col items-center\" data-kid=\"112\">\n                <div class=\"text-[9px] text-zinc-500 uppercase font-black tracking-widest mb-1\" data-kid=\"113\">ATS Rank</div>\n                <div class=\"text-xl font-bold text-emerald-400\" data-kid=\"114\">92</div>\n              </div>\n              <div class=\"bg-white/5 rounded-xl p-4 border border-white/5 flex flex-col items-center\" data-kid=\"115\">\n                <div class=\"text-[9px] text-zinc-500 uppercase font-black tracking-widest mb-1\" data-kid=\"116\">Keywords</div>\n                <div class=\"text-xl font-bold text-amber-400\" data-kid=\"117\">74%</div>\n              </div>\n              <div class=\"bg-white/5 rounded-xl p-4 border border-white/5 flex flex-col items-center\" data-kid=\"118\">\n                <div class=\"text-[9px] text-zinc-500 uppercase font-black tracking-widest mb-1\" data-kid=\"119\">Experience</div>\n                <div class=\"text-xl font-bold text-digital-blue\" data-kid=\"120\">8/10</div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n      </div>\n\n      \n      <div class=\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6\" data-kid=\"121\">\n        \n        \n        <div class=\"md:col-span-2 glass-panel p-8 shimmer-sweep border-rose-500/10 hover:border-rose-500/30 transition-colors\" data-kid=\"122\">\n          <div class=\"flex items-center justify-between mb-8\" data-kid=\"123\">\n            <div class=\"flex items-center gap-3\" data-kid=\"124\">\n              <div class=\"w-10 h-10 rounded-xl bg-rose-500/10 flex items-center justify-center border border-rose-500/20\" data-kid=\"125\">\n                <i class=\"ti ti-cross text-rose-500 text-xl\" data-kid=\"126\"></i>\n              </div>\n              <div data-kid=\"127\">\n                <h3 class=\"text-lg font-bold text-white\" data-kid=\"128\">Critical Skill Gaps</h3>\n                <p class=\"text-xs text-zinc-500\" data-kid=\"129\">Core requirements missing from profile.</p>\n              </div>\n            </div>\n            <span class=\"text-[10px] text-rose-400 font-black uppercase bg-rose-400/10 px-3 py-1 rounded-full border border-rose-400/20 tracking-wider\" data-kid=\"130\">Requires Action</span>\n          </div>\n          \n          <div class=\"space-y-6\" data-kid=\"131\">\n            <div class=\"flex flex-wrap gap-3\" data-kid=\"132\">\n              <span class=\"px-3 py-2 bg-zinc-900 border border-zinc-800 text-zinc-300 text-xs rounded-lg flex items-center gap-2 group hover:border-rose-500/50 transition-all cursor-pointer\" data-kid=\"133\">\n                <span class=\"w-2 h-2 rounded-full bg-rose-500\" data-kid=\"134\"></span>\n                Kubernetes\n              </span>\n              <span class=\"px-3 py-2 bg-zinc-900 border border-zinc-800 text-zinc-300 text-xs rounded-lg flex items-center gap-2 group hover:border-rose-500/50 transition-all cursor-pointer\" data-kid=\"135\">\n                <span class=\"w-2 h-2 rounded-full bg-rose-500\" data-kid=\"136\"></span>\n                GraphQL\n              </span>\n              <span class=\"px-3 py-2 bg-zinc-900 border border-zinc-800 text-zinc-300 text-xs rounded-lg flex items-center gap-2 group hover:border-rose-500/50 transition-all cursor-pointer\" data-kid=\"137\">\n                <span class=\"w-2 h-2 rounded-full bg-rose-500\" data-kid=\"138\"></span>\n                Next.js 14\n              </span>\n            </div>\n            <div class=\"bg-rose-500/5 rounded-xl p-5 border border-rose-500/10 flex items-center gap-4\" data-kid=\"139\">\n              <div class=\"shrink-0 w-10 h-10 bg-rose-500/10 rounded-full flex items-center justify-center border border-rose-500/20\" data-kid=\"140\">\n                <i class=\"ti ti-bulb text-rose-500\" data-kid=\"141\"></i>\n              </div>\n              <p class=\"text-sm text-rose-300 leading-relaxed font-medium\" data-kid=\"142\">\n                <span class=\"font-bold block text-xs uppercase tracking-wider mb-1\" data-kid=\"143\">Strategic Action:</span>\n                Complete the \"Kubernetes for Developers\" certification to increase your ATS match score by approximately 12.5%.\n              </p>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"glass-panel p-8 shimmer-sweep border-amber-500/10 hover:border-amber-500/30 transition-colors\" data-kid=\"144\">\n          <div class=\"flex items-center gap-3 mb-6\" data-kid=\"145\">\n            <div class=\"w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center border border-amber-500/20\" data-kid=\"146\">\n              <i class=\"ti ti-search text-amber-500 text-xl\" data-kid=\"147\"></i>\n            </div>\n            <h3 class=\"text-lg font-bold text-white\" data-kid=\"148\">ATS Keywords</h3>\n          </div>\n          <div class=\"flex flex-wrap gap-2 mb-4\" data-kid=\"149\">\n            <span class=\"px-2 py-1 bg-amber-500/10 border border-amber-500/20 text-amber-400 text-[10px] font-bold rounded uppercase\" data-kid=\"150\">Scalability</span>\n            <span class=\"px-2 py-1 bg-amber-500/10 border border-amber-500/20 text-amber-400 text-[10px] font-bold rounded uppercase\" data-kid=\"151\">Microservices</span>\n            <span class=\"px-2 py-1 bg-amber-500/10 border border-amber-500/20 text-amber-400 text-[10px] font-bold rounded uppercase\" data-kid=\"152\">CI/CD</span>\n            <span class=\"px-2 py-1 bg-amber-500/10 border border-amber-500/20 text-amber-400 text-[10px] font-bold rounded uppercase\" data-kid=\"153\">Distributed Systems</span>\n          </div>\n          <p class=\"text-xs text-zinc-500 leading-relaxed\" data-kid=\"154\">Essential terminology used by company recruiters to filter candidates.</p>\n        </div>\n\n        \n        <div class=\"glass-panel p-8 bg-linear-to-br from-digital-blue/10 to-transparent border-digital-blue/20\" data-kid=\"155\">\n          <div class=\"flex items-center gap-3 mb-6\" data-kid=\"156\">\n            <div class=\"w-10 h-10 rounded-xl bg-digital-blue/20 flex items-center justify-center border border-digital-blue/30 shadow-[0_0_15px_rgba(99,102,241,0.2)]\" data-kid=\"157\">\n              <i class=\"ti ti-bulb text-digital-blue text-xl\" data-kid=\"158\"></i>\n            </div>\n            <h3 class=\"text-lg font-bold text-white\" data-kid=\"159\">AI Instant Tip</h3>\n          </div>\n          <p class=\"text-sm text-zinc-300 mb-6 italic\" data-kid=\"160\">\"Reframe your last project title to include 'Distributed Architecture' to bypass the first ATS layer.\"</p>\n          <button class=\"w-full py-2 bg-digital-blue/10 hover:bg-digital-blue/20 text-digital-blue text-xs font-bold rounded-lg border border-digital-blue/20 transition-all\" data-kid=\"161\">Apply Recommendation</button>\n        </div>\n\n      </div>\n\n      \n      <div class=\"glass-panel p-10 relative overflow-hidden group border-white/10\" data-kid=\"162\">\n        \n        <div class=\"absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-digital-blue/30 rounded-tl-xl opacity-40\" data-kid=\"163\"></div>\n        <div class=\"absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-digital-blue/30 rounded-br-xl opacity-40\" data-kid=\"164\"></div>\n        \n        \n        <div class=\"absolute top-0 right-0 p-8 opacity-5 -rotate-12 group-hover:rotate-0 transition-transform duration-1000\" data-kid=\"165\">\n          <i class=\"ti ti-sparkles text-[200px] text-digital-blue\" data-kid=\"166\"></i>\n        </div>\n\n        <div class=\"relative z-10 max-w-4xl\" data-kid=\"167\">\n          <div class=\"flex items-center gap-3 mb-8\" data-kid=\"168\">\n            <div class=\"w-12 h-12 bg-digital-blue/10 rounded-2xl flex items-center justify-center\" data-kid=\"169\">\n              <i class=\"ti ti-stars-filled text-digital-blue text-2xl\" data-kid=\"170\"></i>\n            </div>\n            <div data-kid=\"171\">\n              <h3 class=\"text-2xl font-bold text-white font-inter\" data-kid=\"172\">AI Strategic Insights</h3>\n              <p class=\"text-zinc-500\" data-kid=\"173\">Detailed roadmap to secure an interview for this specific role.</p>\n            </div>\n          </div>\n\n          <div class=\"space-y-8\" data-kid=\"174\">\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-10\" data-kid=\"175\">\n              <div class=\"space-y-4\" data-kid=\"176\">\n                <h4 class=\"text-sm font-bold text-zinc-400 uppercase tracking-widest flex items-center gap-2\" data-kid=\"177\">\n                  <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" data-kid=\"178\"></span>\n                  Positioning Strategy\n                </h4>\n                <p class=\"text-zinc-400 leading-relaxed italic border-l-2 border-digital-blue/30 pl-4\" data-kid=\"179\">\n                  \"The job description heavily emphasizes <span class=\"text-white font-medium\" data-kid=\"180\">architectural leadership</span> rather than just coding. Shift your narrative from a 'task-doer' to a 'decision-maker' who understands the ROI of technical choices.\"\n                </p>\n              </div>\n              <div class=\"space-y-4\" data-kid=\"181\">\n                <h4 class=\"text-sm font-bold text-zinc-400 uppercase tracking-widest flex items-center gap-2\" data-kid=\"182\">\n                  <span class=\"w-1.5 h-1.5 rounded-full bg-amber-500\" data-kid=\"183\"></span>\n                  Interview Highlight\n                </h4>\n                <p class=\"text-zinc-400 leading-relaxed italic border-l-2 border-digital-blue/30 pl-4\" data-kid=\"184\">\n                  \"Expect questions about <span class=\"text-white font-medium\" data-kid=\"185\">scaling legacy monoliths</span>. Prepare a story about a time you transitioned a feature from a monolith to a microservice, as they mentioned a 'monolith-to-modern' journey in their tech blog.\"\n                </p>\n              </div>\n            </div>\n\n            <div class=\"pt-6 border-t border-white/5\" data-kid=\"186\">\n              <button class=\"flex items-center gap-2 text-digital-blue hover:text-white transition-colors font-bold group\" data-kid=\"187\">\n                Generate Optimized Cover Letter Based on this Match\n                <i class=\"ti ti-arrow-right group-hover:translate-x-1 transition-transform\" data-kid=\"188\"></i>\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </main>\n</div>\n",
