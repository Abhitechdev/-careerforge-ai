      "html": "\n<div class=\"flex h-[850px] w-full bg-[#09090B] text-zinc-100 font-sans selection:bg-[#6366F1]/30\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Sans:wght@400;500;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .font-sans { font-family: 'DM Sans', sans-serif; }\n        .font-heading { font-family: 'Inter', sans-serif; }\n\n        .custom-scrollbar::-webkit-scrollbar { width: 5px; }\n        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }\n        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.05); border-radius: 10px; }\n        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.1); }\n\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n        .chip-hover:hover { transform: translateY(-2px); }\n\n        .aurora-glow {\n            background: \n                radial-gradient(circle at 50% -20%, rgba(99, 102, 241, 0.12), transparent 60%),\n                radial-gradient(circle at 0% 100%, rgba(99, 102, 241, 0.05), transparent 50%),\n                radial-gradient(circle at 100% 100%, rgba(129, 140, 248, 0.05), transparent 50%);\n        }\n\n        @keyframes subtle-float {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-3px); }\n        }\n        .animate-float { animation: subtle-float 3s ease-in-out infinite; }\n\n        @keyframes message-in {\n            from { opacity: 0; transform: translateY(10px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        .animate-message { animation: message-in 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }\n\n        @keyframes shimmer {\n            0% { background-position: -200% 0; }\n            100% { background-position: 200% 0; }\n        }\n        .shimmer-bg {\n            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);\n            background-size: 200% 100%;\n            animation: shimmer 3s infinite;\n        }\n    </style>\n\n    \n    <aside class=\"w-72 flex flex-col bg-[#09090B] border-r border-white/5 shrink-0\" data-kid=\"2\">\n        \n        <div class=\"p-6\" data-kid=\"3\">\n            <div class=\"flex items-center gap-3 mb-8\" data-kid=\"4\">\n                <div class=\"w-9 h-9 rounded-xl bg-gradient-to-br from-[#6366F1] to-[#818CF8] flex items-center justify-center shadow-[0_0_20px_rgba(99,102,241,0.4)] ring-1 ring-white/20\" data-kid=\"5\">\n                    <i class=\"ti ti-sparkles text-white text-xl\" data-kid=\"6\"></i>\n                </div>\n                <div data-kid=\"7\">\n                    <h1 class=\"font-heading font-bold text-lg leading-tight tracking-tight\" data-kid=\"8\">CareerForge</h1>\n                    <span class=\"text-[10px] text-zinc-500 uppercase tracking-widest font-bold\" data-kid=\"9\">AI Co-pilot</span>\n                </div>\n            </div>\n\n            \n            <button class=\"w-full flex items-center justify-between gap-2 bg-white/5 hover:bg-white/10 border border-white/5 text-white px-4 py-3 rounded-xl transition-all mb-8 group ring-1 ring-white/5 relative overflow-hidden\" data-kid=\"10\">\n                <div class=\"absolute inset-0 shimmer-bg pointer-events-none opacity-40\" data-kid=\"11\"></div>\n                <div class=\"flex items-center gap-3 relative z-10\" data-kid=\"12\">\n                    <i class=\"ti ti-plus text-sm group-hover:rotate-90 transition-transform text-[#6366F1]\" data-kid=\"13\"></i>\n                    <span class=\"text-sm font-semibold\" data-kid=\"14\">New Session</span>\n                </div>\n                <kbd class=\"hidden md:inline-flex items-center gap-1 px-1.5 py-0.5 rounded border border-white/10 bg-white/5 text-[10px] text-zinc-500 font-mono relative z-10\" data-kid=\"15\">\n                    <i class=\"ti ti-command text-[8px]\" data-kid=\"16\"></i> K\n                </kbd>\n            </button>\n\n            \n            <nav class=\"space-y-6\" data-kid=\"17\">\n                <div data-kid=\"18\">\n                    <h3 class=\"text-zinc-500 text-[10px] uppercase tracking-widest font-bold px-2 mb-3\" data-kid=\"19\">Recent Discussions</h3>\n                    <div class=\"space-y-1\" data-kid=\"20\">\n                        <div class=\"group flex items-center gap-3 p-3 rounded-xl bg-[#6366F1]/15 border border-[#6366F1]/30 cursor-pointer shadow-[0_0_15px_rgba(99,102,241,0.1)]\" data-kid=\"21\">\n                            <i class=\"ti ti-message text-[#6366F1] animate-pulse\" data-kid=\"22\"></i>\n                            <span class=\"text-white text-sm font-semibold truncate\" data-kid=\"23\">Resume Optimization</span>\n                            <i class=\"ti ti-dots-vertical text-zinc-500 opacity-0 group-hover:opacity-100 transition-opacity ml-auto\" data-kid=\"24\"></i>\n                        </div>\n\n                        <div class=\"group flex items-center gap-3 p-3 rounded-xl hover:bg-white/5 border border-transparent cursor-pointer transition-colors\" data-kid=\"25\">\n                            <i class=\"ti ti-briefcase text-zinc-500 group-hover:text-zinc-300\" data-kid=\"26\"></i>\n                            <span class=\"text-zinc-400 text-sm font-medium truncate\" data-kid=\"27\">Interview Prep: Google</span>\n                        </div>\n\n                        <div class=\"group flex items-center gap-3 p-3 rounded-xl hover:bg-white/5 border border-transparent cursor-pointer transition-colors\" data-kid=\"28\">\n                            <i class=\"ti ti-coin text-zinc-500 group-hover:text-zinc-300\" data-kid=\"29\"></i>\n                            <span class=\"text-zinc-400 text-sm font-medium truncate\" data-kid=\"30\">Salary Negotiation</span>\n                        </div>\n                        \n                        <div class=\"group flex items-center gap-3 p-3 rounded-xl hover:bg-white/5 border border-transparent cursor-pointer transition-colors\" data-kid=\"31\">\n                            <i class=\"ti ti-target-arrow text-zinc-500 group-hover:text-zinc-300\" data-kid=\"32\"></i>\n                            <span class=\"text-zinc-400 text-sm font-medium truncate\" data-kid=\"33\">Career Pivot Strategy</span>\n                        </div>\n                    </div>\n                </div>\n\n                <div data-kid=\"34\">\n                    <h3 class=\"text-zinc-500 text-[10px] uppercase tracking-widest font-bold px-2 mb-3\" data-kid=\"35\">Folders</h3>\n                    <div class=\"space-y-1 px-2\" data-kid=\"36\">\n                        <div class=\"flex items-center gap-3 py-1.5 text-zinc-400 hover:text-white transition-colors cursor-pointer text-sm\" data-kid=\"37\">\n                            <i class=\"ti ti-folder text-zinc-600\" data-kid=\"38\"></i>\n                            <span data-kid=\"39\">Application Tracking</span>\n                        </div>\n                        <div class=\"flex items-center gap-3 py-1.5 text-zinc-400 hover:text-white transition-colors cursor-pointer text-sm\" data-kid=\"40\">\n                            <i class=\"ti ti-folder text-zinc-600\" data-kid=\"41\"></i>\n                            <span data-kid=\"42\">Personal Projects</span>\n                        </div>\n                    </div>\n                </div>\n            </nav>\n        </div>\n\n        \n        <div class=\"mt-auto p-4 border-t border-white/5 bg-[#18181B]/40 backdrop-blur-md\" data-kid=\"43\">\n            <div class=\"flex items-center gap-3 p-2 rounded-xl hover:bg-white/5 transition-colors cursor-pointer group\" data-kid=\"44\">\n                <div class=\"relative\" data-kid=\"45\">\n                    <img src=\"https://i.pravatar.cc/150?u=alex\" class=\"w-9 h-9 rounded-lg border border-white/10\" alt=\"Avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"46\">\n                    <div class=\"absolute -bottom-1 -right-1 w-3 h-3 bg-green-500 border-2 border-[#09090B] rounded-full\" data-kid=\"47\"></div>\n                </div>\n                <div class=\"flex flex-col\" data-kid=\"48\">\n                    <span class=\"text-white text-xs font-semibold group-hover:text-[#6366F1] transition-colors\" data-kid=\"49\">Alex Rivera</span>\n                    <span class=\"text-zinc-500 text-[10px] font-medium\" data-kid=\"50\">Pro Plan • Active</span>\n                </div>\n                <i class=\"ti ti-chevron-up text-zinc-500 ml-auto text-sm\" data-kid=\"51\"></i>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 flex flex-col bg-[#09090B] aurora-glow relative overflow-hidden\" data-kid=\"52\">\n        \n        \n        <header class=\"h-16 flex items-center justify-between px-8 border-b border-white/5 backdrop-blur-md bg-[#09090B]/50 z-10 shrink-0\" data-kid=\"53\">\n            <div class=\"flex items-center gap-4\" data-kid=\"54\">\n                <div class=\"flex -space-x-2\" data-kid=\"55\">\n                    <div class=\"w-8 h-8 rounded-lg bg-gradient-to-br from-[#6366F1] to-[#4F46E5] flex items-center justify-center border-2 border-white/10 shadow-lg shadow-[#6366F1]/20\" data-kid=\"56\">\n                        <i class=\"ti ti-robot text-white text-xs\" data-kid=\"57\"></i>\n                    </div>\n                </div>\n                <div data-kid=\"58\">\n                    <h2 class=\"text-sm font-semibold text-white\" data-kid=\"59\">Forge Advisor</h2>\n                    <div class=\"flex items-center gap-1.5\" data-kid=\"60\">\n                        <span class=\"w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse\" data-kid=\"61\"></span>\n                        <span class=\"text-[10px] text-zinc-500 font-medium\" data-kid=\"62\">AI Agent Online</span>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"flex items-center gap-3\" data-kid=\"63\">\n                <button class=\"p-2 text-zinc-400 hover:text-white transition-colors\" data-kid=\"64\">\n                    <i class=\"ti ti-search text-lg\" data-kid=\"65\"></i>\n                </button>\n                <button class=\"p-2 text-zinc-400 hover:text-white transition-colors\" data-kid=\"66\">\n                    <i class=\"ti ti-star text-lg\" data-kid=\"67\"></i>\n                </button>\n                <div class=\"w-px h-4 bg-white/10 mx-1\" data-kid=\"68\"></div>\n                <button class=\"flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white/5 hover:bg-white/10 text-xs font-medium text-zinc-300 transition-all\" data-kid=\"69\">\n                    <i class=\"ti ti-share-2 text-sm\" data-kid=\"70\"></i>\n                    Share\n                </button>\n            </div>\n        </header>\n\n        \n        <section class=\"flex-1 overflow-y-auto p-8 space-y-8 custom-scrollbar scroll-smooth\" data-kid=\"71\">\n            \n            <div class=\"flex items-center justify-center gap-4\" data-kid=\"72\">\n                <div class=\"h-px flex-1 bg-white/5\" data-kid=\"73\"></div>\n                <span class=\"text-[10px] text-zinc-600 font-bold uppercase tracking-widest\" data-kid=\"74\">Today</span>\n                <div class=\"h-px flex-1 bg-white/5\" data-kid=\"75\"></div>\n            </div>\n\n            \n            <div class=\"flex items-start gap-4 max-w-[75%] lg:max-w-2xl animate-message\" data-kid=\"76\">\n                <div class=\"w-9 h-9 rounded-xl bg-[#18181B] border border-white/10 flex items-center justify-center shrink-0 shadow-xl\" data-kid=\"77\">\n                    <i class=\"ti ti-sparkles text-[#6366F1] text-lg\" data-kid=\"78\"></i>\n                </div>\n                <div class=\"flex flex-col gap-2\" data-kid=\"79\">\n                    <div class=\"flex items-center gap-2\" data-kid=\"80\">\n                        <span class=\"text-xs font-bold text-zinc-200\" data-kid=\"81\">Forge AI</span>\n                        <span class=\"text-[10px] text-zinc-600\" data-kid=\"82\">10:24 AM</span>\n                    </div>\n                    <div class=\"bg-[#18181B] border border-white/5 text-zinc-300 p-5 rounded-2xl rounded-tl-none shadow-sm text-[14px] leading-relaxed relative group\" data-kid=\"83\">\n                        Hi Alex! I've spent some time analyzing your background and compared it to current senior market trends. \n                        <br data-kid=\"84\"><br data-kid=\"85\">\n                        Your expertise in <span class=\"text-[#6366F1] font-medium\" data-kid=\"86\">Next.js</span> and <span class=\"text-[#6366F1] font-medium\" data-kid=\"87\">Distributed Systems</span> is a huge asset. However, your current resume's \"Outcome Score\" is <span class=\"text-yellow-500 font-bold\" data-kid=\"88\">64/100</span>.\n                        <br data-kid=\"89\"><br data-kid=\"90\">\n                        Should we start by rewriting your project descriptions to focus more on quantifiable results? I've prepared a few examples based on your latest projects.\n                        \n                        <div class=\"absolute -right-3 bottom-0 translate-x-full flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-all duration-300 bg-[#18181B]/80 backdrop-blur-sm p-1 rounded-lg border border-white/10\" data-kid=\"91\">\n                            <button class=\"p-1.5 rounded-md hover:bg-white/5 text-zinc-500 hover:text-white transition-all\" title=\"Copy\" data-kid=\"92\">\n                                <i class=\"ti ti-copy text-xs\" data-kid=\"93\"></i>\n                            </button>\n                            <button class=\"p-1.5 rounded-md hover:bg-white/5 text-zinc-500 hover:text-white transition-all\" title=\"Good response\" data-kid=\"94\">\n                                <i class=\"ti ti-thumb-up text-xs\" data-kid=\"95\"></i>\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"flex items-start gap-4 flex-row-reverse max-w-[75%] lg:max-w-2xl ml-auto animate-message\" style=\"animation-delay: 0.1s;\" data-kid=\"96\">\n                <div class=\"w-9 h-9 rounded-xl bg-[#6366F1] flex items-center justify-center shrink-0 shadow-[0_4px_15px_rgba(99,102,241,0.3)]\" data-kid=\"97\">\n                    <i class=\"ti ti-user text-white text-lg\" data-kid=\"98\"></i>\n                </div>\n                <div class=\"flex flex-col gap-2 items-end\" data-kid=\"99\">\n                    <div class=\"flex items-center gap-2\" data-kid=\"100\">\n                        <span class=\"text-[10px] text-zinc-600\" data-kid=\"101\">10:26 AM</span>\n                        <span class=\"text-xs font-bold text-zinc-200\" data-kid=\"102\">Alex Rivera</span>\n                    </div>\n                    <div class=\"bg-gradient-to-br from-[#6366F1] to-[#4F46E5] text-white p-5 rounded-2xl rounded-tr-none shadow-[0_10px_25px_rgba(79,70,229,0.3)] border border-white/10 text-[14px] leading-relaxed relative overflow-hidden group\" data-kid=\"103\">\n                        <div class=\"absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none\" data-kid=\"104\"></div>\n                        Yes, definitely. I feel like my \"E-commerce migration\" project description is too technical and doesn't show the business value enough. How can I frame it better for a hiring manager?\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"flex items-start gap-4 max-w-[75%] lg:max-w-2xl animate-message\" style=\"animation-delay: 0.2s;\" data-kid=\"105\">\n                <div class=\"w-9 h-9 rounded-xl bg-[#18181B] border border-white/10 flex items-center justify-center shrink-0 shadow-xl\" data-kid=\"106\">\n                    <i class=\"ti ti-sparkles text-[#6366F1] text-lg\" data-kid=\"107\"></i>\n                </div>\n                <div class=\"flex flex-col gap-2\" data-kid=\"108\">\n                    <div class=\"flex items-center gap-2\" data-kid=\"109\">\n                        <span class=\"text-xs font-bold text-zinc-200\" data-kid=\"110\">Forge AI</span>\n                    </div>\n                    <div class=\"bg-[#18181B] border border-white/5 text-zinc-200 p-4 rounded-2xl rounded-tl-none flex items-center gap-4\" data-kid=\"111\">\n                        <div class=\"flex gap-1.5\" data-kid=\"112\">\n                            <div class=\"w-2 h-2 bg-[#6366F1] rounded-full animate-bounce [animation-duration:1s]\" data-kid=\"113\"></div>\n                            <div class=\"w-2 h-2 bg-[#6366F1] rounded-full animate-bounce [animation-duration:1s] [animation-delay:0.2s]\" data-kid=\"114\"></div>\n                            <div class=\"w-2 h-2 bg-[#6366F1] rounded-full animate-bounce [animation-duration:1s] [animation-delay:0.4s]\" data-kid=\"115\"></div>\n                        </div>\n                        <span class=\"text-zinc-400 text-xs font-medium tracking-wide\" data-kid=\"116\">Advisor is thinking...</span>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <footer class=\"p-8 pt-0 z-10\" data-kid=\"117\">\n            <div class=\"max-w-4xl mx-auto space-y-6\" data-kid=\"118\">\n                \n                <div class=\"flex gap-2.5 overflow-x-auto no-scrollbar py-2\" data-kid=\"119\">\n                    <button class=\"flex items-center gap-2 shrink-0 px-4 py-2 rounded-full bg-[#18181B] border border-white/10 text-zinc-300 text-xs font-medium hover:border-[#6366F1]/50 hover:bg-[#6366F1]/5 hover:text-white transition-all cursor-pointer group chip-hover\" data-kid=\"120\">\n                        <i class=\"ti ti-wand text-[#6366F1]\" data-kid=\"121\"></i>\n                        <span data-kid=\"122\">Improve my resume impact</span>\n                    </button>\n                    <button class=\"flex items-center gap-2 shrink-0 px-4 py-2 rounded-full bg-[#18181B] border border-white/10 text-zinc-300 text-xs font-medium hover:border-[#6366F1]/50 hover:bg-[#6366F1]/5 hover:text-white transition-all cursor-pointer group chip-hover\" data-kid=\"123\">\n                        <i class=\"ti ti-microphone text-[#6366F1]\" data-kid=\"124\"></i>\n                        <span data-kid=\"125\">Start mock interview prep</span>\n                    </button>\n                    <button class=\"flex items-center gap-2 shrink-0 px-4 py-2 rounded-full bg-[#18181B] border border-white/10 text-zinc-300 text-xs font-medium hover:border-[#6366F1]/50 hover:bg-[#6366F1]/5 hover:text-white transition-all cursor-pointer group chip-hover\" data-kid=\"126\">\n                        <i class=\"ti ti-book text-[#6366F1]\" data-kid=\"127\"></i>\n                        <span data-kid=\"128\">Suggested skills to learn</span>\n                    </button>\n                    <button class=\"flex items-center gap-2 shrink-0 px-4 py-2 rounded-full bg-[#18181B] border border-white/10 text-zinc-300 text-xs font-medium hover:border-[#6366F1]/50 hover:bg-[#6366F1]/5 hover:text-white transition-all cursor-pointer group chip-hover\" data-kid=\"129\">\n                        <i class=\"ti ti-cash text-[#6366F1]\" data-kid=\"130\"></i>\n                        <span data-kid=\"131\">Negotiation strategy</span>\n                    </button>\n                </div>\n\n                \n                <div class=\"relative group\" data-kid=\"132\">\n                    \n                    <div class=\"absolute -inset-1 bg-gradient-to-r from-[#6366F1]/20 to-[#818CF8]/20 rounded-[24px] blur-xl opacity-0 group-focus-within:opacity-100 transition duration-1000\" data-kid=\"133\"></div>\n                    \n                    <div class=\"relative bg-[#18181B] border border-white/10 rounded-[22px] shadow-2xl overflow-hidden focus-within:border-[#6366F1]/40 transition-all duration-300\" data-kid=\"134\">\n                        <div class=\"flex items-center p-2 min-h-[64px]\" data-kid=\"135\">\n                            \n                            <div class=\"flex items-center gap-1 pl-2\" data-kid=\"136\">\n                                <button class=\"p-2.5 text-zinc-500 hover:text-[#6366F1] transition-colors rounded-xl hover:bg-white/5\" data-kid=\"137\">\n                                    <i class=\"ti ti-paperclip text-xl\" data-kid=\"138\"></i>\n                                </button>\n                                <button class=\"p-2.5 text-zinc-500 hover:text-[#6366F1] transition-colors rounded-xl hover:bg-white/5\" data-kid=\"139\">\n                                    <i class=\"ti ti-photo text-xl\" data-kid=\"140\"></i>\n                                </button>\n                            </div>\n\n                            \n                            <div class=\"flex-1 px-4\" data-kid=\"141\">\n                                <textarea rows=\"1\" placeholder=\"Type your career goal or ask for feedback...\" class=\"w-full bg-transparent border-none outline-none text-zinc-200 py-3 text-[14px] leading-relaxed resize-none placeholder:text-zinc-600 max-h-32 custom-scrollbar\" data-kid=\"142\"></textarea>\n                            </div>\n\n                            \n                            <div class=\"flex items-center gap-3 pr-2\" data-kid=\"143\">\n                                <div class=\"flex items-center gap-2 px-3 py-1.5 rounded-lg bg-zinc-800/50 text-zinc-500 text-[10px] font-mono border border-white/5\" data-kid=\"144\">\n                                    <i class=\"ti ti-command text-[8px]\" data-kid=\"145\"></i> Enter\n                                </div>\n                                <button class=\"bg-[#6366F1] hover:bg-[#4F46E5] text-white p-3 rounded-2xl transition-all shadow-[0_8px_20px_rgba(99,102,241,0.4)] hover:shadow-[0_8px_25px_rgba(99,102,241,0.6)] group/btn\" data-kid=\"146\">\n                                    <i class=\"ti ti-send-2 text-xl group-hover/btn:translate-x-0.5 group-hover/btn:-translate-y-0.5 transition-transform\" data-kid=\"147\"></i>\n                                </button>\n                            </div>\n                        </div>\n\n                        \n                        <div class=\"bg-white/[0.02] border-t border-white/5 px-6 py-2 flex items-center justify-between\" data-kid=\"148\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"149\">\n                                <span class=\"text-[10px] text-zinc-500 flex items-center gap-1.5\" data-kid=\"150\">\n                                    <i class=\"ti ti-bolt text-[#6366F1]\" data-kid=\"151\"></i>\n                                    Powered by Forge-V4 Turbo\n                                </span>\n                                <span class=\"text-[10px] text-zinc-500 flex items-center gap-1.5\" data-kid=\"152\">\n                                    <i class=\"ti ti-shield-check text-green-500/70\" data-kid=\"153\"></i>\n                                    Data encrypted\n                                </span>\n                            </div>\n                            <div class=\"flex items-center gap-2\" data-kid=\"154\">\n                                <span class=\"text-[10px] text-zinc-600 font-medium\" data-kid=\"155\">0 / 2000</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                \n                <p class=\"text-[10px] text-zinc-500 text-center px-8\" data-kid=\"156\">\n                    Forge AI can make mistakes. Consider checking important information. \n                    <a href=\"#\" class=\"text-[#6366F1] hover:underline font-medium\" data-kid=\"157\">Terms of Service</a> & <a href=\"#\" class=\"text-[#6366F1] hover:underline font-medium\" data-kid=\"158\">Privacy Policy</a>.\n                </p>\n            </div>\n        </footer>\n\n        \n        <div class=\"absolute top-0 right-0 p-12 opacity-[0.03] pointer-events-none select-none\" data-kid=\"159\">\n            <i class=\"ti ti-brand-abstract text-[400px] text-[#6366F1] blur-xs\" data-kid=\"160\"></i>\n        </div>\n    </main>\n</div>\n",
