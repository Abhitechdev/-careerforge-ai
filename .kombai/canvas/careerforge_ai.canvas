      "html": "\n<div class=\"flex h-[900px] w-[1280px] bg-[#09090B] text-slate-200 font-['DM_Sans'] overflow-hidden selection:bg-[#6366F1]/30 selection:text-white\" data-kid=\"0\">\n  \n  \n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .scrollbar-hide::-webkit-scrollbar {\n      display: none;\n    }\n    .scrollbar-hide {\n      -ms-overflow-style: none;\n      scrollbar-width: none;\n    }\n    \n    .kanban-board-container::-webkit-scrollbar {\n      height: 6px;\n    }\n    .kanban-board-container::-webkit-scrollbar-track {\n      background: rgba(255, 255, 255, 0.02);\n      border-radius: 10px;\n    }\n    .kanban-board-container::-webkit-scrollbar-thumb {\n      background: rgba(99, 102, 241, 0.1);\n      border-radius: 10px;\n    }\n    .kanban-board-container::-webkit-scrollbar-thumb:hover {\n      background: rgba(99, 102, 241, 0.3);\n    }\n    \n    .kanban-column {\n      width: 340px; \n      flex-shrink: 0;\n    }\n\n    .shimmer {\n      background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.05) 50%, rgba(255,255,255,0) 100%);\n      background-size: 200% 100%;\n      animation: shimmer-sweep 3s infinite linear;\n    }\n\n    @keyframes shimmer-sweep {\n      0% { background-position: 100% 0; }\n      100% { background-position: -100% 0; }\n    }\n  </style>\n\n  \n  \n  \n  <aside class=\"w-18 bg-[#050507] border-r border-white/5 flex flex-col items-center py-8 shrink-0 z-50\" data-kid=\"2\">\n    <div class=\"w-10 h-10 bg-[#6366F1] rounded-xl flex items-center justify-center mb-10 shadow-[0_0_20px_rgba(99,102,241,0.3)]\" data-kid=\"3\">\n      <i class=\"ti ti-flame text-white text-2xl\" data-kid=\"4\"></i>\n    </div>\n    \n    <div class=\"flex flex-col gap-8\" data-kid=\"5\">\n      <div class=\"group relative\" data-kid=\"6\">\n        <i class=\"ti ti-smart-home text-2xl text-slate-500 hover:text-white cursor-pointer transition-colors\" data-kid=\"7\"></i>\n        <div class=\"absolute left-12 top-1/2 -translate-y-1/2 bg-[#18181B] text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-white/10 z-50\" data-kid=\"8\">Home</div>\n      </div>\n      \n      <div class=\"group relative\" data-kid=\"9\">\n        <i class=\"ti ti-layout-kanban text-2xl text-[#6366F1] cursor-pointer\" data-kid=\"10\"></i>\n        <div class=\"absolute -right-[23px] top-1/2 -translate-y-1/2 w-1 h-6 bg-[#6366F1] rounded-full\" data-kid=\"11\"></div>\n        <div class=\"absolute left-12 top-1/2 -translate-y-1/2 bg-[#18181B] text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-white/10 z-50\" data-kid=\"12\">Tracker</div>\n      </div>\n      \n      <div class=\"group relative\" data-kid=\"13\">\n        <i class=\"ti ti-file-text text-2xl text-slate-500 hover:text-white cursor-pointer transition-colors\" data-kid=\"14\"></i>\n        <div class=\"absolute left-12 top-1/2 -translate-y-1/2 bg-[#18181B] text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-white/10 z-50\" data-kid=\"15\">Resumes</div>\n      </div>\n      \n      <div class=\"group relative\" data-kid=\"16\">\n        <i class=\"ti ti-message-dots text-2xl text-slate-500 hover:text-white cursor-pointer transition-colors\" data-kid=\"17\"></i>\n        <div class=\"absolute left-12 top-1/2 -translate-y-1/2 bg-[#18181B] text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-white/10 z-50\" data-kid=\"18\">AI Advisor</div>\n      </div>\n    </div>\n    \n    <div class=\"mt-auto flex flex-col gap-8\" data-kid=\"19\">\n       <i class=\"ti ti-settings text-2xl text-slate-500 hover:text-white cursor-pointer\" data-kid=\"20\"></i>\n       <div class=\"relative group\" data-kid=\"21\">\n          <img src=\"https://i.pravatar.cc/100?u=alex_forge\" class=\"w-10 h-10 rounded-full border border-white/10 p-0.5 cursor-pointer hover:border-[#6366F1]/50 transition-colors\" decoding=\"async\" loading=\"lazy\" data-kid=\"22\">\n          <div class=\"absolute bottom-0 right-0 w-3 h-3 bg-emerald-500 rounded-full border-2 border-[#050507]\" data-kid=\"23\"></div>\n       </div>\n    </div>\n  </aside>\n\n  \n  <aside class=\"w-64 bg-[#09090B] border-r border-white/5 flex flex-col shrink-0\" data-kid=\"24\">\n    <div class=\"p-6 pb-2\" data-kid=\"25\">\n      <h2 class=\"text-[10px] font-extrabold text-slate-500 uppercase tracking-[0.2em] mb-8\" data-kid=\"26\">Career Engine</h2>\n      \n      <nav class=\"flex flex-col gap-1.5\" data-kid=\"27\">\n        <a href=\"#\" class=\"flex items-center justify-between px-3 py-2.5 bg-white/5 text-white rounded-xl border border-white/10 shadow-sm group\" data-kid=\"28\">\n          <div class=\"flex items-center gap-3\" data-kid=\"29\">\n            <i class=\"ti ti-layout-board-split text-lg text-[#6366F1]\" data-kid=\"30\"></i>\n            <span class=\"font-semibold text-sm\" data-kid=\"31\">Active Tracker</span>\n          </div>\n          <span class=\"text-[10px] bg-[#6366F1]/20 text-[#6366F1] px-1.5 py-0.5 rounded font-bold\" data-kid=\"32\">PRO</span>\n        </a>\n        \n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2.5 text-slate-400 hover:bg-white/5 hover:text-white rounded-xl transition-all group\" data-kid=\"33\">\n          <i class=\"ti ti-archive text-lg group-hover:text-slate-200\" data-kid=\"34\"></i>\n          <span class=\"text-sm font-medium\" data-kid=\"35\">Job History</span>\n        </a>\n        \n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2.5 text-slate-400 hover:bg-white/5 hover:text-white rounded-xl transition-all group\" data-kid=\"36\">\n          <i class=\"ti ti-chart-dots text-lg group-hover:text-slate-200\" data-kid=\"37\"></i>\n          <span class=\"text-sm font-medium\" data-kid=\"38\">Match Analytics</span>\n        </a>\n        \n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2.5 text-slate-400 hover:bg-white/5 hover:text-white rounded-xl transition-all group\" data-kid=\"39\">\n          <i class=\"ti ti-folder-bolt text-lg group-hover:text-slate-200\" data-kid=\"40\"></i>\n          <span class=\"text-sm font-medium\" data-kid=\"41\">Resume Vault</span>\n        </a>\n      </nav>\n    </div>\n\n    <div class=\"p-6 mt-6\" data-kid=\"42\">\n      <h3 class=\"text-[10px] font-extrabold text-slate-500 uppercase tracking-[0.2em] mb-4\" data-kid=\"43\">Daily Insights</h3>\n      <div class=\"space-y-6\" data-kid=\"44\">\n        <div data-kid=\"45\">\n          <div class=\"flex justify-between text-[11px] mb-2 font-medium\" data-kid=\"46\">\n            <span class=\"text-slate-400 italic\" data-kid=\"47\">Interview Readiness</span>\n            <span class=\"text-indigo-400\" data-kid=\"48\">82%</span>\n          </div>\n          <div class=\"h-1.5 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"49\">\n            <div class=\"h-full bg-gradient-to-r from-indigo-500 to-[#6366F1] rounded-full w-[82%] relative\" data-kid=\"50\">\n               <div class=\"absolute inset-0 shimmer\" data-kid=\"51\"></div>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"bg-[#18181B] p-4 rounded-2xl border border-white/5 relative group cursor-pointer overflow-hidden shadow-xl hover:border-[#6366F1]/30 transition-all\" data-kid=\"52\">\n           <div class=\"absolute -right-4 -top-4 w-16 h-16 bg-[#6366F1]/10 rounded-full blur-2xl group-hover:bg-[#6366F1]/20 transition-all\" data-kid=\"53\"></div>\n           <div class=\"flex items-center gap-2 mb-2\" data-kid=\"54\">\n             <i class=\"ti ti-sparkles text-indigo-400 text-sm animate-pulse\" data-kid=\"55\"></i>\n             <span class=\"text-[10px] font-bold text-indigo-400 uppercase tracking-wider\" data-kid=\"56\">AI Suggestion</span>\n           </div>\n           <p class=\"text-[11px] leading-relaxed text-slate-300\" data-kid=\"57\">Your profile matches <span class=\"text-white font-bold\" data-kid=\"58\">4 new</span> Senior Designer roles at <span class=\"text-white font-bold\" data-kid=\"59\">Figma</span> and <span class=\"text-white font-bold\" data-kid=\"60\">Linear</span>.</p>\n           <div class=\"mt-3 flex justify-end\" data-kid=\"61\">\n              <i class=\"ti ti-arrow-right text-slate-500 text-sm group-hover:translate-x-1 transition-transform\" data-kid=\"62\"></i>\n           </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"mt-auto p-6 border-t border-white/5\" data-kid=\"63\">\n       <div class=\"flex items-center gap-3\" data-kid=\"64\">\n          <div class=\"w-2 h-2 bg-indigo-500 rounded-full animate-pulse shadow-[0_0_8px_#6366F1]\" data-kid=\"65\"></div>\n          <span class=\"text-[11px] font-medium text-slate-400\" data-kid=\"66\">AI Core Online</span>\n       </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col bg-[#09090B] relative\" data-kid=\"67\">\n    \n    \n    <header class=\"h-18 border-b border-white/5 px-8 flex items-center justify-between shrink-0\" data-kid=\"68\">\n      <div class=\"flex items-center gap-4\" data-kid=\"69\">\n        <div class=\"flex items-center gap-2\" data-kid=\"70\">\n          <span class=\"text-slate-500 text-xs font-medium\" data-kid=\"71\">Dashboard</span>\n          <i class=\"ti ti-chevron-right text-[10px] text-slate-600\" data-kid=\"72\"></i>\n          <span class=\"text-slate-100 text-sm font-semibold tracking-tight\" data-kid=\"73\">Application Tracker</span>\n        </div>\n      </div>\n      \n      <div class=\"flex items-center gap-6\" data-kid=\"74\">\n        <div class=\"relative group\" data-kid=\"75\">\n          <i class=\"ti ti-search absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-500 text-sm transition-colors group-focus-within:text-[#6366F1]\" data-kid=\"76\"></i>\n          <input type=\"text\" placeholder=\"Quick search...\" class=\"bg-white/5 border border-white/5 rounded-xl pl-10 pr-4 py-2 text-xs w-64 focus:outline-none focus:border-[#6366F1]/40 focus:bg-white/[0.07] transition-all\" data-kid=\"77\">\n          <div class=\"absolute right-3 top-1/2 -translate-y-1/2 px-1.5 py-0.5 bg-white/5 border border-white/10 rounded text-[9px] text-slate-500 font-bold\" data-kid=\"78\">⌘K</div>\n        </div>\n        \n        <div class=\"flex items-center gap-3\" data-kid=\"79\">\n          <button class=\"w-9 h-9 flex items-center justify-center rounded-xl bg-white/5 border border-white/5 text-slate-400 hover:text-white hover:bg-white/10 transition-all relative\" data-kid=\"80\">\n            <i class=\"ti ti-bell text-lg\" data-kid=\"81\"></i>\n            <span class=\"absolute top-2 right-2.5 w-2 h-2 bg-indigo-500 rounded-full border-2 border-[#09090B]\" data-kid=\"82\"></span>\n          </button>\n          <button class=\"h-9 px-4 flex items-center gap-2 rounded-xl bg-[#6366F1] text-white text-xs font-bold shadow-[0_0_15px_rgba(99,102,241,0.25)] hover:shadow-[0_0_25px_rgba(99,102,241,0.4)] transition-all transform active:scale-95\" data-kid=\"83\">\n             <i class=\"ti ti-plus text-sm\" data-kid=\"84\"></i>\n             Add Application\n          </button>\n        </div>\n      </div>\n    </header>\n\n    \n    <div class=\"px-8 pt-8 pb-6 flex items-end justify-between shrink-0\" data-kid=\"85\">\n      <div data-kid=\"86\">\n        <h1 class=\"text-3xl font-['Inter'] font-extrabold text-white tracking-tight mb-2\" data-kid=\"87\">My Applications</h1>\n        <p class=\"text-slate-400 text-sm max-w-lg\" data-kid=\"88\">Track your progress ac