      "html": "\n<div class=\"flex h-[900px] w-full bg-[#09090B] text-zinc-100 font-['DM_Sans'] overflow-hidden relative\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Sans:wght@400;500;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n    \n    .font-inter { font-family: 'Inter', sans-serif; }\n    \n    ::-webkit-scrollbar {\n      width: 6px;\n    }\n    ::-webkit-scrollbar-track {\n      background: rgba(255, 255, 255, 0.02);\n    }\n    ::-webkit-scrollbar-thumb {\n      background: rgba(255, 255, 255, 0.1);\n      border-radius: 10px;\n    }\n    ::-webkit-scrollbar-thumb:hover {\n      background: rgba(99, 102, 241, 0.3);\n    }\n    \n    .glass-panel {\n      background: rgba(24, 24, 27, 0.6);\n      backdrop-filter: blur(12px);\n      border: 1px solid rgba(255, 255, 255, 0.05);\n    }\n    \n    .neon-border {\n      border: 1.5px solid #6366F1;\n      box-shadow: 0 0 12px rgba(99, 102, 241, 0.2), 0 0 36px rgba(99, 102, 241, 0.06);\n    }\n\n    .shimmer {\n      position: relative;\n      overflow: hidden;\n    }\n    .shimmer::after {\n      content: '';\n      position: absolute;\n      top: 0;\n      right: 0;\n      bottom: 0;\n      left: 0;\n      transform: translateX(-100%);\n      background-image: linear-gradient(\n        90deg,\n        rgba(255, 255, 255, 0) 0,\n        rgba(255, 255, 255, 0.03) 20%,\n        rgba(255, 255, 255, 0.06) 60%,\n        rgba(255, 255, 255, 0)\n      );\n      animation: shimmer 3s infinite;\n    }\n    @keyframes shimmer {\n      100% {\n        transform: translateX(100%);\n      }\n    }\n  </style>\n\n  \n  <aside class=\"w-16 border-r border-white/5 flex flex-col items-center py-6 gap-8 shrink-0 bg-[#09090B] z-20\" data-kid=\"2\">\n    <div class=\"w-10 h-10 bg-[#6366F1] rounded-xl flex items-center justify-center shadow-[0_0_20px_rgba(99,102,241,0.4)]\" data-kid=\"3\">\n      <i class=\"ti ti-flame text-white text-2xl\" data-kid=\"4\"></i>\n    </div>\n    \n    <nav class=\"flex flex-col gap-6\" data-kid=\"5\">\n      <a href=\"#\" class=\"w-10 h-10 flex items-center justify-center rounded-lg text-white/40 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"6\">\n        <i class=\"ti ti-layout-dashboard text-xl\" data-kid=\"7\"></i>\n      </a>\n      <a href=\"#\" class=\"w-10 h-10 flex items-center justify-center rounded-lg bg-[#6366F1]/15 text-[#6366F1] shadow-[0_0_15px_rgba(99,102,241,0.1)] transition-all relative group\" data-kid=\"8\">\n        <div class=\"absolute left-0 w-1 h-4 bg-[#6366F1] rounded-r-full -ml-3\" data-kid=\"9\"></div>\n        <i class=\"ti ti-file-analytics text-xl\" data-kid=\"10\"></i>\n      </a>\n      <a href=\"#\" class=\"w-10 h-10 flex items-center justify-center rounded-lg text-white/40 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"11\">\n        <i class=\"ti ti-users text-xl\" data-kid=\"12\"></i>\n      </a>\n      <a href=\"#\" class=\"w-10 h-10 flex items-center justify-center rounded-lg text-white/40 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"13\">\n        <i class=\"ti ti-message-chatbot text-xl\" data-kid=\"14\"></i>\n      </a>\n    </nav>\n    \n    <div class=\"mt-auto flex flex-col gap-6\" data-kid=\"15\">\n      <a href=\"#\" class=\"w-10 h-10 flex items-center justify-center rounded-lg text-white/40 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"16\">\n        <i class=\"ti ti-settings text-xl\" data-kid=\"17\"></i>\n      </a>\n      <div class=\"w-8 h-8 rounded-full bg-zinc-800 border border-white/10 overflow-hidden\" data-kid=\"18\">\n        <img src=\"https://i.pravatar.cc/100?u=alex\" alt=\"Profile\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"19\">\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col overflow-hidden bg-[#09090B]\" data-kid=\"20\">\n    \n    <header class=\"h-16 border-b border-white/5 flex items-center justify-between px-8 shrink-0 bg-[#09090B] z-10\" data-kid=\"21\">\n      <div class=\"flex items-center gap-4\" data-kid=\"22\">\n        <span class=\"text-zinc-500 text-sm\" data-kid=\"23\">Resumes</span>\n        <i class=\"ti ti-chevron-right text-zinc-600 text-[10px]\" data-kid=\"24\"></i>\n        <span class=\"text-zinc-100 font-medium font-inter\" data-kid=\"25\">Sr_Product_Designer_v2.pdf</span>\n        <div class=\"ml-4 px-2.5 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] font-bold uppercase tracking-wider\" data-kid=\"26\">Analyzed</div>\n      </div>\n      \n      <div class=\"flex items-center gap-4\" data-kid=\"27\">\n        <button class=\"flex items-center gap-2 px-4 py-1.5 rounded-lg border border-white/10 text-zinc-400 text-sm font-medium hover:border-white/20 hover:text-zinc-100 transition-all cursor-pointer\" data-kid=\"28\">\n          <i class=\"ti ti-download\" data-kid=\"29\"></i>\n          Export\n        </button>\n        <button class=\"flex items-center gap-2 px-5 py-2 rounded-lg bg-[#6366F1] text-white text-sm font-bold hover:bg-[#5356E2] transition-all shadow-[0_4px_12px_rgba(99,102,241,0.3)] hover:-translate-y-0.5 active:translate-y-0 cursor-pointer\" data-kid=\"30\">\n          <i class=\"ti ti-sparkles\" data-kid=\"31\"></i>\n          Re-Analyze\n        </button>\n      </div>\n    </header>\n\n    \n    <div class=\"flex-1 flex overflow-hidden\" data-kid=\"32\">\n      \n      <div class=\"w-[45%] bg-[#0D0D0F] border-r border-white/5 overflow-y-auto p-12 flex justify-center custom-scroll\" data-kid=\"33\">\n        <div class=\"w-full max-w-2xl bg-white text-zinc-800 rounded shadow-[0_20px_60px_rgba(0,0,0,0.6)] overflow-hidden aspect-[1/1.414] p-12 relative flex-col flex select-none\" data-kid=\"34\">\n          <header class=\"border-b border-zinc-100 pb-6 mb-8\" data-kid=\"35\">\n            <h1 class=\"text-3xl font-bold tracking-tight text-zinc-900 font-inter\" data-kid=\"36\">Alex Rivers</h1>\n            <p class=\"text-zinc-500 font-medium text-sm mt-1\" data-kid=\"37\">Senior Product Designer & Frontend Enthusiast</p>\n            <div class=\"mt-4 flex flex-wrap gap-x-4 gap-y-2 text-[11px] text-zinc-400 font-medium\" data-kid=\"38\">\n              <span class=\"flex items-center gap-1\" data-kid=\"39\"><i class=\"ti ti-mail\" data-kid=\"40\"></i> alex.rivers@email.com</span>\n              <span class=\"flex items-center gap-1\" data-kid=\"41\"><i class=\"ti ti-map-pin\" data-kid=\"42\"></i> San Francisco, CA</span>\n              <span class=\"flex items-center gap-1\" data-kid=\"43\"><i class=\"ti ti-brand-linkedin\" data-kid=\"44\"></i> linkedin.com/in/alexrivers</span>\n            </div>\n          </header>\n\n          <div class=\"space-y-8 flex-1\" data-kid=\"45\">\n            <section data-kid=\"46\">\n              <h2 class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-[#6366F1] mb-3\" data-kid=\"47\">Professional Summary</h2>\n              <p class=\"text-xs leading-relaxed text-zinc-600\" data-kid=\"48\">Highly motivated Product Designer with 8+ years of experience in creating user-centric digital experiences. Proven track record of leading design teams at high-growth SaaS startups. Expertise in UI/UX, Design Systems, and React development.</p>\n            </section>\n\n            <section data-kid=\"49\">\n              <h2 class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-[#6366F1] mb-4\" data-kid=\"50\">Experience</h2>\n              <div class=\"space-y-6\" data-kid=\"51\">\n                <div data-kid=\"52\">\n                  <div class=\"flex justify-between items-baseline mb-1\" data-kid=\"53\">\n                    <h3 class=\"font-bold text-zinc-900 text-sm\" data-kid=\"54\">Lead Product Designer • TechFlow Inc.</h3>\n                    <span class=\"text-[10px] text-zinc-400 italic font-medium\" data-kid=\"55\">2020 – Present</span>\n                  </div>\n                  <ul class=\"text-[11px] text-zinc-600 list-disc ml-4 space-y-1.5\" data-kid=\"56\">\n                    <li data-kid=\"57\">Spearheaded the redesign of the core analytics dashboard, resulting in a 25% increase in weekly active users.</li>\n                    <li class=\"bg-emerald-500/[0.08] border-l-2 border-emerald-500/60 px-2 py-0.5 -ml-2 rounded-r\" data-kid=\"58\">Established and maintained the company's first comprehensive Design System, reducing design-to-dev handoff time by 40%.</li>\n                    <li data-kid=\"59\">Mentored a team of 4 junior designers and collaborated directly with the CTO on product roadmap.</li>\n                  </ul>\n                </div>\n                <div data-kid=\"60\">\n                  <div class=\"flex justify-between items-baseline mb-1\" data-kid=\"61\">\n                    <h3 class=\"font-bold text-zinc-900 text-sm\" data-kid=\"62\">Senior UI/UX Designer • CloudScale</h3>\n                    <span class=\"text-[10px] text-zinc-400 italic font-medium\" data-kid=\"63\">2017 – 2020</span>\n                  </div>\n                  <ul class=\"text-[11px] text-zinc-600 list-disc ml-4 space-y-1.5\" data-kid=\"64\">\n                    <li class=\"bg-rose-500/[0.08] border-l-2 border-rose-500/60 px-2 py-0.5 -ml-2 rounded-r\" data-kid=\"65\">Designed end-to-end user journeys for the enterprise cloud management platform.</li>\n                    <li data-kid=\"66\">Conducted over 50+ user interviews to drive evidence-based design decisions.</li>\n                  </ul>\n                </div>\n              </div>\n            </section>\n          </div>\n\n          <footer class=\"mt-8 pt-6 border-t border-zinc-100 flex justify-between items-center\" data-kid=\"67\">\n            <div class=\"text-[10px] text-zinc-400\" data-kid=\"68\">Page 1 of 2</div>\n            <div class=\"flex gap-2\" data-kid=\"69\">\n              <span class=\"w-1.5 h-1.5 rounded-full bg-zinc-200\" data-kid=\"70\"></span>\n              <span class=\"w-1.5 h-1.5 rounded-full bg-zinc-200\" data-kid=\"71\"></span>\n            </div>\n          </footer>\n        </div>\n      </div>\n\n      \n      <div class=\"flex-1 overflow-y-auto bg-[#09090B] p-10 space-y-10 custom-scroll\" data-kid=\"72\">\n        \n        \n        <section data-kid=\"73\">\n          <div class=\"flex items-center justify-between mb-8\" data-kid=\"74\">\n            <h2 class=\"text-xl font-bold font-inter flex items-center gap-2\" data-kid=\"75\">\n              <i class=\"ti ti-chart-bar text-[#6366F1]\" data-kid=\"76\"></i>\n              Score Analysis\n            </h2>\n            <div class=\"flex items-center gap-2 text-xs font-medium text-zinc-500\" data-kid=\"77\">\n              <span data-kid=\"78\">Analysis updated 2 mins ago</span>\n              <i class=\"ti ti-refresh text-[#6366F1] cursor-pointer hover:rotate-180 transition-transform duration-500\" data-kid=\"79\"></i>\n            </div>\n          </div>\n          \n          <div class=\"grid grid-cols-2 lg:grid-cols-4 gap-6\" data-kid=\"80\">\n            \n            <div class=\"bg-[#18181B] border border-white/5 rounded-2xl p-6 flex flex-col items-center justify-center shimmer\" data-kid=\"81\">\n              <div class=\"relative w-28 h-28 mb-4\" data-kid=\"82\">\n                <svg width=\"112\" height=\"112\" viewBox=\"0 0 112 112\" class=\"transform -rotate-90\" data-kid=\"83\">\n                  <circle cx=\"56\" cy=\"56\" r=\"50\" stroke=\"currentColor\" stroke-width=\"8\" fill=\"transparent\" class=\"text-white/5\" data-kid=\"84\"></circle>\n                  <circle cx=\"56\" cy=\"56\" r=\"50\" stroke=\"currentColor\" stroke-width=\"8\" fill=\"transparent\" stroke-dasharray=\"314\" stroke-dashoffset=\"56.5\" stroke-linecap=\"round\" class=\"text-[#6366F1] drop-shadow-[0_0_12px_rgba(99,102,241,0.6)]\" data-kid=\"85\"></circle>\n                </svg>\n                <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"86\">\n                  <span class=\"text-3xl font-bold font-inter leading-none text-zinc-100\" data-kid=\"87\">82</span>\n                  <span class=\"text-[8px] text-zinc-500 uppercase font-bold tracking-widest mt-1\" data-kid=\"88\">Score</span>\n                </div>\n              </div>\n              <div class=\"flex items-center gap-1.5 text-emerald-400 text-xs font-bold\" data-kid=\"89\">\n                <i class=\"ti ti-trending-up\" data-kid=\"90\"></i>\n                <span data-kid=\"91\">+14 pts</span>\n              </div>\n            </div>\n\n            \n            <div class=\"bg-[#18181B] border border-white/5 rounded-2xl p-6 flex flex-col items-center justify-center\" data-kid=\"92\">\n              <div class=\"relative w-20 h-20 mb-4\" data-kid=\"93\">\n                <svg width=\"80\" height=\"80\" viewBox=\"0 0 80 80\" class=\"transform -rotate-90\" data-kid=\"94\">\n                  <circle cx=\"40\" cy=\"40\" r=\"34\" stroke=\"currentColor\" stroke-width=\"6\" fill=\"transparent\" class=\"text-white/5\" data-kid=\"95\"></circle>\n                  <circle cx=\"40\" cy=\"40\" r=\"34\" stroke=\"currentColor\" stroke-width=\"6\" fill=\"transparent\" stroke-dasharray=\"213.6\" stroke-dashoffset=\"53.4\" class=\"text-emerald-400 drop-shadow-[0_0_8px_rgba(52,211,153,0.3)]\" data-kid=\"96\"></circle>\n                </svg>\n                <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"97\">\n                  <span class=\"text-lg font-bold font-inter\" data-kid=\"98\">75%</span>\n                </div>\n              </div>\n              <span class=\"text-zinc-500 text-[10px] uppercase font-bold tracking-wider\" data-kid=\"99\">Keywords</span>\n            </div>\n\n            \n            <div class=\"bg-[#18181B] border border-white/5 rounded-2xl p-6 flex flex-col items-center justify-center\" data-kid=\"100\">\n              <div class=\"relative w-20 h-20 mb-4\" data-kid=\"101\">\n                <svg width=\"80\" height=\"80\" viewBox=\"0 0 80 80\" class=\"transform -rotate-90\" data-kid=\"102\">\n                  <circle cx=\"40\" cy=\"40\" r=\"34\" stroke=\"currentColor\" stroke-width=\"6\" fill=\"transparent\" class=\"text-white/5\" data-kid=\"103\"></circle>\n                  <circle cx=\"40\" cy=\"40\" r=\"34\" stroke=\"currentColor\" stroke-width=\"6\" fill=\"transparent\" stroke-dasharray=\"213.6\" stroke-dashoffset=\"21.3\" class=\"text-amber-400 drop-shadow-[0_0_8px_rgba(251,191,36,0.3)]\" data-kid=\"104\"></circle>\n                </svg>\n                <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"105\">\n                  <span class=\"text-lg font-bold font-inter\" data-kid=\"106\">90%</span>\n                </div>\n              </div>\n              <span class=\"text-zinc-500 text-[10px] uppercase font-bold tracking-wider\" data-kid=\"107\">Skills Gap</span>\n            </div>\n\n            \n            <div class=\"bg-[#18181B] border border-white/5 rounded-2xl p-6 flex flex-col items-center justify-center\" data-kid=\"108\">\n              <div class=\"relative w-20 h-20 mb-4\" data-kid=\"109\">\n                <svg width=\"80\" height=\"80\" viewBox=\"0 0 80 80\" class=\"transform -rotate-90\" data-kid=\"110\">\n                  <circle cx=\"40\" cy=\"40\" r=\"34\" stroke=\"currentColor\" stroke-width=\"6\" fill=\"transparent\" class=\"text-white/5\" data-kid=\"111\"></circle>\n                  <circle cx=\"40\" cy=\"40\" r=\"34\" stroke=\"currentColor\" stroke-width=\"6\" fill=\"transparent\" stroke-dasharray=\"213.6\" stroke-dashoffset=\"85.4\" class=\"text-rose-400 drop-shadow-[0_0_8px_rgba(244,63,94,0.3)]\" data-kid=\"112\"></circle>\n                </svg>\n                <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"113\">\n                  <span class=\"text-lg font-bold font-inter\" data-kid=\"114\">60%</span>\n                </div>\n              </div>\n              <span class=\"text-zinc-500 text-[10px] uppercase font-bold tracking-wider\" data-kid=\"115\">Formatting</span>\n            </div>\n          </div>\n        </section>\n\n        \n        <section data-kid=\"116\">\n          <div class=\"flex items-center gap-3 mb-6\" data-kid=\"117\">\n            <div class=\"w-8 h-8 rounded-lg bg-[#6366F1]/10 flex items-center justify-center\" data-kid=\"118\">\n              <i class=\"ti ti-sparkles text-[#6366F1] text-lg\" data-kid=\"119\"></i>\n            </div>\n            <h3 class=\"text-lg font-bold font-inter\" data-kid=\"120\">AI Insights & Improvements</h3>\n          </div>\n          \n          <div class=\"grid grid-cols-1 gap-4\" data-kid=\"121\">\n            \n            <div class=\"bg-[#18181B] border-l-4 border-rose-500 rounded-xl p-5 hover:bg-[#1C1C20] transition-colors group cursor-pointer\" data-kid=\"122\">\n              <div class=\"flex items-start gap-4\" data-kid=\"123\">\n                <div class=\"w-10 h-10 rounded-full bg-rose-500/10 flex items-center justify-center shrink-0\" data-kid=\"124\">\n                  <i class=\"ti ti-alert-triangle text-rose-500 text-xl\" data-kid=\"125\"></i>\n                </div>\n                <div class=\"flex-1\" data-kid=\"126\">\n                  <div class=\"flex justify-between items-start mb-2\" data-kid=\"127\">\n                    <h4 class=\"font-bold font-inter text-zinc-100 group-hover:text-rose-400 transition-colors\" data-kid=\"128\">Improve Phrasing Density</h4>\n                    <span class=\"px-2 py-0.5 rounded bg-rose-500/10 text-rose-500 text-[9px] font-bold uppercase\" data-kid=\"129\">Critical Fix</span>\n                  </div>\n                  <p class=\"text-sm text-zinc-400 leading-relaxed\" data-kid=\"130\">Your experience section at CloudScale uses vague verbs like \"Designed\" and \"Conducted\". AI recommends using: <span class=\"text-zinc-200\" data-kid=\"131\">\"Orchestrated\"</span>, <span class=\"text-zinc-200\" data-kid=\"132\">\"Spearheaded\"</span>, or <span class=\"text-zinc-200\" data-kid=\"133\">\"Engineered\"</span>.</p>\n                  <div class=\"mt-4 flex items-center gap-3\" data-kid=\"134\">\n                    <button class=\"px-3 py-1.5 rounded-full bg-[#6366F1] text-white text-[10px] font-bold hover:bg-[#5356E2] transition-all cursor-pointer shadow-lg shadow-[#6366F1]/20\" data-kid=\"135\">Apply AI Revision</button>\n                    <button class=\"px-3 py-1.5 rounded-full bg-white/5 text-zinc-400 text-[10px] font-bold hover:bg-white/10 hover:text-zinc-200 transition-all cursor-pointer\" data-kid=\"136\">Dismiss</button>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"bg-[#18181B] border-l-4 border-[#6366F1] rounded-xl p-5 hover:bg-[#1C1C20] transition-colors group cursor-pointer\" data-kid=\"137\">\n              <div class=\"flex items-start gap-4\" data-kid=\"138\">\n                <div class=\"w-10 h-10 rounded-full bg-[#6366F1]/10 flex items-center justify-center shrink-0\" data-kid=\"139\">\n                  <i class=\"ti ti-target-arrow text-[#6366F1] text-xl\" data-kid=\"140\"></i>\n                </div>\n                <div class=\"flex-1\" data-kid=\"141\">\n                  <div class=\"flex justify-between items-start mb-2\" data-kid=\"142\">\n                    <h4 class=\"font-bold font-inter text-zinc-100 group-hover:text-[#6366F1] transition-colors\" data-kid=\"143\">Keyword Optimization</h4>\n                    <span class=\"px-2 py-0.5 rounded bg-[#6366F1]/10 text-[#6366F1] text-[9px] font-bold uppercase\" data-kid=\"144\">High Impact</span>\n                  </div>\n                  <p class=\"text-sm text-zinc-400 leading-relaxed\" data-kid=\"145\">Missing core industry keywords for Senior roles: <span class=\"text-emerald-400 font-medium italic\" data-kid=\"146\">\"Agile Methodology\"</span>, <span class=\"text-emerald-400 font-medium italic\" data-kid=\"147\">\"Data-Driven Design\"</span>, <span class=\"text-emerald-400 font-medium italic\" data-kid=\"148\">\"Stakeholder Management\"</span>.</p>\n                  <div class=\"mt-4 bg-black/20 rounded-lg p-3 border border-white/5\" data-kid=\"149\">\n                    <div class=\"flex items-center gap-2 mb-2\" data-kid=\"150\">\n                      <div class=\"w-1.5 h-1.5 rounded-full bg-[#6366F1]\" data-kid=\"151\"></div>\n                      <span class=\"text-[10px] font-bold text-zinc-500 uppercase\" data-kid=\"152\">Suggested Insertion:</span>\n                    </div>\n                    <p class=\"text-xs text-zinc-500 italic\" data-kid=\"153\">\"...leading data-driven design initiatives within agile methodology frameworks...\"</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"bg-[#18181B] border-l-4 border-emerald-500 rounded-xl p-5 hover:bg-[#1C1C20] transition-colors group\" data-kid=\"154\">\n              <div class=\"flex items-start gap-4\" data-kid=\"155\">\n                <div class=\"w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center shrink-0\" data-kid=\"156\">\n                  <i class=\"ti ti-circle-check text-emerald-500 text-xl\" data-kid=\"157\"></i>\n                </div>\n                <div class=\"flex-1\" data-kid=\"158\">\n                  <div class=\"flex justify-between items-start mb-2\" data-kid=\"159\">\n                    <h4 class=\"font-bold font-inter text-zinc-100 group-hover:text-emerald-400 transition-colors\" data-kid=\"160\">Strong Quantitative Data</h4>\n                    <span class=\"px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-400 text-[9px] font-bold uppercase\" data-kid=\"161\">Well Done</span>\n                  </div>\n                  <p class=\"text-sm text-zinc-400 leading-relaxed\" data-kid=\"162\">Excellent use of metrics in your first experience block. Quantifying results (25% increase, 40% reduction) significantly boosts recruiter trust.</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        \n        <section class=\"bg-[#18181B] rounded-2xl border border-white/5 p-8 relative overflow-hidden\" data-kid=\"163\">\n          <div class=\"absolute -top-12 -right-12 w-48 h-48 bg-[#6366F1]/10 blur-3xl rounded-full\" data-kid=\"164\"></div>\n          \n          <h3 class=\"text-lg font-bold font-inter mb-6\" data-kid=\"165\">Job Title: Senior Product Designer</h3>\n          \n          <div class=\"space-y-6 relative z-10\" data-kid=\"166\">\n            <div data-kid=\"167\">\n              <div class=\"flex justify-between text-xs font-bold uppercase tracking-wider text-zinc-500 mb-2\" data-kid=\"168\">\n                <span data-kid=\"169\">Matching Skills</span>\n                <span class=\"text-emerald-400\" data-kid=\"170\">12 / 15</span>\n              </div>\n              <div class=\"flex flex-wrap gap-2\" data-kid=\"171\">\n                <span class=\"px-3 py-1 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[11px] font-bold flex items-center gap-1.5\" data-kid=\"172\"><i class=\"ti ti-check text-[10px]\" data-kid=\"173\"></i> Figma</span>\n                <span class=\"px-3 py-1 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[11px] font-bold flex items-center gap-1.5\" data-kid=\"174\"><i class=\"ti ti-check text-[10px]\" data-kid=\"175\"></i> Design Systems</span>\n                <span class=\"px-3 py-1 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[11px] font-bold flex items-center gap-1.5\" data-kid=\"176\"><i class=\"ti ti-check text-[10px]\" data-kid=\"177\"></i> React</span>\n                <span class=\"px-3 py-1 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[11px] font-bold flex items-center gap-1.5\" data-kid=\"178\"><i class=\"ti ti-check text-[10px]\" data-kid=\"179\"></i> User Research</span>\n                <span class=\"px-3 py-1 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[11px] font-bold flex items-center gap-1.5\" data-kid=\"180\"><i class=\"ti ti-check text-[10px]\" data-kid=\"181\"></i> Storyboarding</span>\n                <span class=\"px-3 py-1 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[11px] font-bold flex items-center gap-1.5\" data-kid=\"182\"><i class=\"ti ti-check text-[10px]\" data-kid=\"183\"></i> Prototyping</span>\n              </div>\n            </div>\n\n            <div class=\"pt-4 border-t border-white/5\" data-kid=\"184\">\n              <div class=\"flex justify-between text-xs font-bold uppercase tracking-wider text-zinc-500 mb-2\" data-kid=\"185\">\n                <span data-kid=\"186\">Missing Skills</span>\n                <span class=\"text-rose-400\" data-kid=\"187\">3 Gap Areas</span>\n              </div>\n              <div class=\"flex flex-wrap gap-2\" data-kid=\"188\">\n                <span class=\"px-3 py-1 rounded-lg bg-rose-500/10 border border-rose-500/20 text-rose-400 text-[11px] font-bold flex items-center gap-1.5\" data-kid=\"189\"><i class=\"ti ti-x text-[10px]\" data-kid=\"190\"></i> A/B Testing</span>\n                <span class=\"px-3 py-1 rounded-lg bg-rose-500/10 border border-rose-500/20 text-rose-400 text-[11px] font-bold flex items-center gap-1.5\" data-kid=\"191\"><i class=\"ti ti-x text-[10px]\" data-kid=\"192\"></i> SQL</span>\n                <span class=\"px-3 py-1 rounded-lg bg-rose-500/10 border border-rose-500/20 text-rose-400 text-[11px] font-bold flex items-center gap-1.5\" data-kid=\"193\"><i class=\"ti ti-x text-[10px]\" data-kid=\"194\"></i> Product Strategy</span>\n              </div>\n            </div>\n          </div>\n\n          <button class=\"w-full mt-8 py-3 rounded-xl bg-white/5 border border-white/10 text-zinc-300 text-sm font-bold hover:bg-white/10 transition-all flex items-center justify-center gap-2 cursor-pointer relative z-10\" data-kid=\"195\">\n            <i class=\"ti ti-link\" data-kid=\"196\"></i>\n            View Matching Jobs\n          </button>\n        </section>\n\n      </div>\n    </div>\n  </main>\n</div>\n",
