      "html": "\n<div class=\"flex bg-[#09090B] text-slate-200 font-['DM_Sans'] min-h-[900px] w-full selection:bg-[#6366F1]/30\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Sans:wght@400;500;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .font-inter { font-family: 'Inter', sans-serif; }\n        .font-dmsans { font-family: 'DM Sans', sans-serif; }\n\n        .aurora-glow {\n            background: \n                radial-gradient(circle at 20% -10%, rgba(99, 102, 241, 0.1), transparent 50%),\n                radial-gradient(circle at 80% 20%, rgba(16, 185, 129, 0.05), transparent 50%);\n        }\n\n        .glass-card {\n            background: rgba(24, 24, 27, 0.6);\n            backdrop-filter: blur(12px);\n            border: 1px solid rgba(255, 255, 255, 0.05);\n        }\n\n        .shimmer {\n            position: relative;\n            overflow: hidden;\n        }\n\n        .shimmer::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: -100%;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.03), transparent);\n            animation: shimmer-sweep 3s infinite;\n        }\n\n        @keyframes shimmer-sweep {\n            100% { left: 100%; }\n        }\n    </style>\n\n    \n    \n    <aside class=\"w-16 border-r border-white/5 flex flex-col items-center py-6 gap-8 bg-[#09090B] shrink-0\" data-kid=\"2\">\n        <div class=\"w-10 h-10 bg-[#6366F1] rounded-xl flex items-center justify-center shadow-[0_0_20px_rgba(99,102,241,0.3)] hover:scale-105 transition-transform cursor-pointer\" data-kid=\"3\">\n            <i class=\"ti ti-flame text-white text-2xl\" data-kid=\"4\"></i>\n        </div>\n        <nav class=\"flex flex-col gap-6\" data-kid=\"5\">\n            <a href=\"#\" class=\"p-2.5 rounded-xl hover:bg-white/5 transition-all text-white/40 hover:text-white group relative\" data-kid=\"6\">\n                <i class=\"ti ti-layout-dashboard text-xl group-hover:scale-110 transition-transform\" data-kid=\"7\"></i>\n                <span class=\"absolute left-full ml-4 px-2 py-1 bg-white text-black text-[10px] font-bold rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-50\" data-kid=\"8\">Dashboard</span>\n            </a>\n            <a href=\"#\" class=\"p-2.5 rounded-xl bg-[#6366F1]/10 text-[#6366F1] shadow-[inset_0_0_0_1px_rgba(99,102,241,0.2)] group relative\" data-kid=\"9\">\n                <i class=\"ti ti-file-text text-xl\" data-kid=\"10\"></i>\n                <span class=\"absolute left-full ml-4 px-2 py-1 bg-white text-black text-[10px] font-bold rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-50\" data-kid=\"11\">Resumes</span>\n            </a>\n            <a href=\"#\" class=\"p-2.5 rounded-xl hover:bg-white/5 transition-all text-white/40 hover:text-white group relative\" data-kid=\"12\">\n                <i class=\"ti ti-columns text-xl group-hover:scale-110 transition-transform\" data-kid=\"13\"></i>\n                <span class=\"absolute left-full ml-4 px-2 py-1 bg-white text-black text-[10px] font-bold rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-50\" data-kid=\"14\">Tracker</span>\n            </a>\n            <a href=\"#\" class=\"p-2.5 rounded-xl hover:bg-white/5 transition-all text-white/40 hover:text-white group relative\" data-kid=\"15\">\n                <i class=\"ti ti-user-search text-xl group-hover:scale-110 transition-transform\" data-kid=\"16\"></i>\n                <span class=\"absolute left-full ml-4 px-2 py-1 bg-white text-black text-[10px] font-bold rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-50\" data-kid=\"17\">Career Advisor</span>\n            </a>\n        </nav>\n        <div class=\"mt-auto flex flex-col gap-6\" data-kid=\"18\">\n            <a href=\"#\" class=\"p-2.5 rounded-xl hover:bg-white/5 transition-all text-white/40 hover:text-white group relative\" data-kid=\"19\">\n                <i class=\"ti ti-settings text-xl\" data-kid=\"20\"></i>\n            </a>\n            <div class=\"w-10 h-10 rounded-full border-2 border-white/10 overflow-hidden cursor-pointer hover:border-[#6366F1]/50 transition-colors\" data-kid=\"21\">\n                <img src=\"https://i.pravatar.cc/100?u=careerforge\" alt=\"User\" decoding=\"async\" loading=\"lazy\" data-kid=\"22\">\n            </div>\n        </div>\n    </aside>\n\n    \n    <aside class=\"w-64 border-r border-white/5 bg-[#09090B] flex flex-col shrink-0\" data-kid=\"23\">\n        <div class=\"h-16 flex items-center px-6 border-b border-white/5\" data-kid=\"24\">\n            <span class=\"font-inter font-bold text-sm tracking-widest text-white/60 uppercase\" data-kid=\"25\">Management</span>\n        </div>\n        <div class=\"p-4 flex flex-col gap-1\" data-kid=\"26\">\n            <button class=\"flex items-center justify-between w-full px-4 py-2.5 bg-[#6366F1]/10 rounded-xl text-sm text-white font-medium group transition-all border border-[#6366F1]/20 shadow-[0_0_15px_rgba(99,102,241,0.1)]\" data-kid=\"27\">\n                <span class=\"flex items-center gap-3\" data-kid=\"28\">\n                    <i class=\"ti ti-folder-open text-[#6366F1]\" data-kid=\"29\"></i>\n                    All Resumes\n                </span>\n                <span class=\"text-[10px] bg-[#6366F1]/20 px-1.5 py-0.5 rounded text-[#6366F1]\" data-kid=\"30\">12</span>\n            </button>\n            <button class=\"flex items-center justify-between w-full px-4 py-2.5 hover:bg-white/5 rounded-lg text-sm text-white/60 font-medium group transition-all\" data-kid=\"31\">\n                <span class=\"flex items-center gap-3\" data-kid=\"32\">\n                    <i class=\"ti ti-sparkles text-white/20 group-hover:text-[#6366F1] transition-colors\" data-kid=\"33\"></i>\n                    AI Optimized\n                </span>\n                <span class=\"text-[10px] bg-white/5 px-1.5 py-0.5 rounded text-white/40\" data-kid=\"34\">5</span>\n            </button>\n            <button class=\"flex items-center justify-between w-full px-4 py-2.5 hover:bg-white/5 rounded-lg text-sm text-white/60 font-medium group transition-all\" data-kid=\"35\">\n                <span class=\"flex items-center gap-3\" data-kid=\"36\">\n                    <i class=\"ti ti-pencil text-white/20 group-hover:text-[#6366F1] transition-colors\" data-kid=\"37\"></i>\n                    Drafts\n                </span>\n                <span class=\"text-[10px] bg-white/5 px-1.5 py-0.5 rounded text-white/40\" data-kid=\"38\">3</span>\n            </button>\n            <button class=\"flex items-center justify-between w-full px-4 py-2.5 hover:bg-white/5 rounded-lg text-sm text-white/60 font-medium group transition-all\" data-kid=\"39\">\n                <span class=\"flex items-center gap-3 text-red-400/80\" data-kid=\"40\">\n                    <i class=\"ti ti-trash text-red-400/20 group-hover:text-red-400 transition-colors\" data-kid=\"41\"></i>\n                    Archive\n                </span>\n            </button>\n        </div>\n\n        <div class=\"mt-8 px-6\" data-kid=\"42\">\n            <span class=\"text-[10px] font-bold text-white/30 uppercase tracking-[0.2em]\" data-kid=\"43\">Usage</span>\n            <div class=\"mt-4 p-4 bg-[#18181B] rounded-xl border border-white/5\" data-kid=\"44\">\n                <div class=\"flex justify-between text-xs mb-2\" data-kid=\"45\">\n                    <span class=\"text-white/60\" data-kid=\"46\">Free Credits</span>\n                    <span class=\"text-white font-medium\" data-kid=\"47\">8 / 10</span>\n                </div>\n                <div class=\"w-full bg-white/5 h-1.5 rounded-full overflow-hidden\" data-kid=\"48\">\n                    <div class=\"bg-[#6366F1] h-full w-[80%] rounded-full shadow-[0_0_10px_rgba(99,102,241,0.5)]\" data-kid=\"49\"></div>\n                </div>\n                <button class=\"w-full mt-4 py-2 bg-white/5 hover:bg-white/10 rounded-lg text-[11px] font-bold text-white/80 transition-colors\" data-kid=\"50\">\n                    Upgrade to Pro\n                </button>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 flex flex-col aurora-glow relative overflow-hidden min-h-0\" data-kid=\"51\">\n        \n        <header class=\"h-16 border-b border-white/5 flex items-center justify-between px-10 bg-[#09090B]/50 backdrop-blur-md relative z-40\" data-kid=\"52\">\n            <div class=\"flex items-center gap-4\" data-kid=\"53\">\n                <h2 class=\"font-inter font-bold text-xl text-white\" data-kid=\"54\">Resume Repository</h2>\n                <div class=\"w-px h-6 bg-white/10 mx-2\" data-kid=\"55\"></div>\n                <div class=\"flex items-center gap-2 text-xs text-white/40\" data-kid=\"56\">\n                    <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"57\">CareerForge</a>\n                    <i class=\"ti ti-chevron-right text-[10px]\" data-kid=\"58\"></i>\n                    <span class=\"text-white/80\" data-kid=\"59\">My Resumes</span>\n                </div>\n            </div>\n\n            <div class=\"flex items-center gap-6\" data-kid=\"60\">\n                <div class=\"relative group\" data-kid=\"61\">\n                    <i class=\"ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-white/20 group-focus-within:text-[#6366F1] transition-colors\" data-kid=\"62\"></i>\n                    <input type=\"text\" placeholder=\"Search by title or job role...\" class=\"bg-[#18181B] border border-white/5 rounded-full pl-10 pr-6 py-2 text-sm text-white w-72 focus:outline-none focus:ring-2 focus:ring-[#6366F1]/20 focus:border-[#6366F1]/40 transition-all placeholder:text-white/20\" data-kid=\"63\">\n                </div>\n                <button class=\"bg-[#6366F1] hover:bg-[#4f46e5] text-white px-5 py-2.5 rounded-full text-sm font-semibold flex items-center gap-2 transition-all shadow-[0_4px_20px_rgba(99,102,241,0.3)] hover:shadow-[0_4px_25px_rgba(99,102,241,0.4)] hover:-translate-y-0.5 active:translate-y-0\" data-kid=\"64\">\n                    <i class=\"ti ti-file-upload text-lg\" data-kid=\"65\"></i>\n                    Upload New\n                </button>\n            </div>\n        </header>\n\n        \n        <div class=\"p-10 flex flex-col gap-8 max-w-7xl mx-auto w-full\" data-kid=\"66\">\n            \n            <div class=\"grid grid-cols-3 gap-6\" data-kid=\"67\">\n                <div class=\"bg-[#18181B]/50 border border-white/5 rounded-2xl p-6 relative overflow-hidden group\" data-kid=\"68\">\n                    <div class=\"relative z-10\" data-kid=\"69\">\n                        <span class=\"text-white/40 text-xs font-bold uppercase tracking-widest\" data-kid=\"70\">Average ATS Score</span>\n                        <div class=\"mt-2 flex items-baseline gap-2\" data-kid=\"71\">\n                            <span class=\"text-3xl font-inter font-bold text-white\" data-kid=\"72\">74%</span>\n                            <span class=\"text-emerald-400 text-xs font-medium flex items-center gap-0.5\" data-kid=\"73\"><i class=\"ti ti-arrow-up-right\" data-kid=\"74\"></i> +12%</span>\n                        </div>\n                    </div>\n                    <div class=\"absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"75\">\n                        <i class=\"ti ti-chart-bar text-8xl text-white\" data-kid=\"76\"></i>\n                    </div>\n                </div>\n                <div class=\"bg-[#18181B]/50 border border-white/5 rounded-2xl p-6 relative overflow-hidden group\" data-kid=\"77\">\n                    <div class=\"relative z-10\" data-kid=\"78\">\n                        <span class=\"text-white/40 text-xs font-bold uppercase tracking-widest\" data-kid=\"79\">Optimized Docs</span>\n                        <div class=\"mt-2 flex items-baseline gap-2\" data-kid=\"80\">\n                            <span class=\"text-3xl font-inter font-bold text-white\" data-kid=\"81\">5</span>\n                            <span class=\"text-white/20 text-xs font-medium\" data-kid=\"82\">/ 12 total</span>\n                        </div>\n                    </div>\n                    <div class=\"absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"83\">\n                        <i class=\"ti ti-sparkles text-8xl text-white\" data-kid=\"84\"></i>\n                    </div>\n                </div>\n                <div class=\"bg-[#18181B]/50 border border-white/5 rounded-2xl p-6 relative overflow-hidden group\" data-kid=\"85\">\n                    <div class=\"relative z-10\" data-kid=\"86\">\n                        <span class=\"text-white/40 text-xs font-bold uppercase tracking-widest\" data-kid=\"87\">Upcoming Deadlines</span>\n                        <div class=\"mt-2 flex items-baseline gap-2\" data-kid=\"88\">\n                            <span class=\"text-3xl font-inter font-bold text-white\" data-kid=\"89\">3</span>\n                            <span class=\"text-amber-400 text-xs font-medium\" data-kid=\"90\">Applications due</span>\n                        </div>\n                    </div>\n                    <div class=\"absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"91\">\n                        <i class=\"ti ti-calendar-event text-8xl text-white\" data-kid=\"92\"></i>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"flex items-center justify-between\" data-kid=\"93\">\n                <div class=\"flex items-center gap-2\" data-kid=\"94\">\n                    <button class=\"px-4 py-1.5 rounded-full bg-white/10 text-white text-sm font-medium border border-white/5 shadow-sm\" data-kid=\"95\">Recent</button>\n                    <button class=\"px-4 py-1.5 rounded-full hover:bg-white/5 text-white/60 text-sm font-medium transition-colors\" data-kid=\"96\">Alphabetical</button>\n                    <button class=\"px-4 py-1.5 rounded-full hover:bg-white/5 text-white/60 text-sm font-medium transition-colors\" data-kid=\"97\">By Score</button>\n                </div>\n                <div class=\"flex items-center gap-3\" data-kid=\"98\">\n                    <span class=\"text-xs text-white/30\" data-kid=\"99\">Layout:</span>\n                    <div class=\"flex bg-[#18181B] p-1 rounded-lg border border-white/5\" data-kid=\"100\">\n                        <button class=\"p-1.5 rounded bg-white/5 text-white\" data-kid=\"101\"><i class=\"ti ti-list text-lg\" data-kid=\"102\"></i></button>\n                        <button class=\"p-1.5 rounded text-white/30 hover:text-white/60 transition-colors\" data-kid=\"103\"><i class=\"ti ti-grid-dots text-lg\" data-kid=\"104\"></i></button>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"flex flex-col gap-4\" data-kid=\"105\">\n                \n                \n                <div class=\"shimmer group bg-[#18181B] border border-white/5 rounded-2xl p-5 flex items-center gap-6 hover:bg-[#1d1d21] hover:border-[#6366F1]/30 hover:shadow-[0_20px_40px_rgba(0,0,0,0.4)] transition-all cursor-pointer\" data-kid=\"106\">\n                    <div class=\"w-12 h-12 bg-emerald-500/10 rounded-xl flex items-center justify-center text-emerald-500 shrink-0 group-hover:scale-110 transition-transform duration-300\" data-kid=\"107\">\n                        <i class=\"ti ti-file-type-pdf text-2xl\" data-kid=\"108\"></i>\n                    </div>\n                    \n                    <div class=\"flex-grow min-w-0\" data-kid=\"109\">\n                        <div class=\"flex items-center gap-3 mb-1\" data-kid=\"110\">\n                            <h3 class=\"font-inter font-semibold text-base text-white truncate max-w-[280px]\" data-kid=\"111\">Senior Product Designer - Meta</h3>\n                            <span class=\"px-2 py-0.5 rounded bg-[#6366F1]/10 text-[#6366F1] text-[10px] font-bold uppercase tracking-widest border border-[#6366F1]/20\" data-kid=\"112\">v3.2</span>\n                        </div>\n                        <div class=\"flex items-center gap-4 text-xs text-white/40\" data-kid=\"113\">\n                            <span class=\"flex items-center gap-1.5 whitespace-nowrap\" data-kid=\"114\"><i class=\"ti ti-calendar text-white/20\" data-kid=\"115\"></i> Modified 2 hrs ago</span>\n                            <span class=\"flex items-center gap-1.5 whitespace-nowrap\" data-kid=\"116\"><i class=\"ti ti-database text-white/20\" data-kid=\"117\"></i> 2.4 MB</span>\n                            <div class=\"flex items-center -space-x-1.5 ml-1\" data-kid=\"118\">\n                                <div class=\"w-5 h-5 rounded-full border-2 border-[#18181B] bg-slate-800 flex items-center justify-center text-[7px] font-bold\" data-kid=\"119\">v1</div>\n                                <div class=\"w-5 h-5 rounded-full border-2 border-[#18181B] bg-slate-700 flex items-center justify-center text-[7px] font-bold\" data-kid=\"120\">v2</div>\n                                <div class=\"w-5 h-5 rounded-full border-2 border-[#18181B] bg-[#6366F1] flex items-center justify-center text-[7px] font-bold\" data-kid=\"121\">+1</div>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"w-32 flex flex-col items-center border-l border-white/5 shrink-0\" data-kid=\"122\">\n                        <span class=\"text-[9px] text-white/30 uppercase font-bold tracking-[0.2em] mb-1\" data-kid=\"123\">ATS Score</span>\n                        <div class=\"flex items-center gap-2\" data-kid=\"124\">\n                            <span class=\"text-2xl font-inter font-bold text-emerald-400 tracking-tighter\" data-kid=\"125\">94</span>\n                            <div class=\"flex items-end gap-0.5 h-6\" data-kid=\"126\">\n                                <div class=\"w-1 h-2 bg-emerald-400/30 rounded-full\" data-kid=\"127\"></div>\n                                <div class=\"w-1 h-4 bg-emerald-400/60 rounded-full\" data-kid=\"128\"></div>\n                                <div class=\"w-1 h-6 bg-emerald-400 rounded-full\" data-kid=\"129\"></div>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"w-32 flex flex-col items-center border-l border-white/5 shrink-0\" data-kid=\"130\">\n                        <span class=\"bg-emerald-500/10 text-emerald-500 text-[10px] px-2.5 py-1 rounded-full font-bold uppercase tracking-wide border border-emerald-500/20\" data-kid=\"131\">Optimized</span>\n                        <span class=\"text-[9px] text-white/30 italic mt-0.5\" data-kid=\"132\">Target: Tech Lead</span>\n                    </div>\n\n                    <div class=\"flex items-center gap-1 shrink-0 ml-auto pl-4 border-l border-white/5\" data-kid=\"133\">\n                        <button class=\"p-2.5 rounded-xl hover:bg-white/5 text-white/40 hover:text-white transition-all\" title=\"View Document\" data-kid=\"134\">\n                            <i class=\"ti ti-eye text-xl\" data-kid=\"135\"></i>\n                        </button>\n                        <button class=\"flex items-center gap-2 px-5 py-2.5 bg-white/5 hover:bg-white/10 rounded-xl text-sm font-bold text-white transition-all\" title=\"Optimize with AI\" data-kid=\"136\">\n                            <i class=\"ti ti-sparkles text-[#6366F1]\" data-kid=\"137\"></i>\n                            Re-Optimize\n                        </button>\n                        <button class=\"p-2.5 rounded-xl hover:bg-red-500/10 text-white/40 hover:text-red-500 transition-all\" data-kid=\"138\">\n                            <i class=\"ti ti-dots-vertical text-xl\" data-kid=\"139\"></i>\n                        </button>\n                    </div>\n                </div>\n\n                \n                <div class=\"shimmer group bg-[#18181B] border border-white/5 rounded-2xl p-5 flex items-center gap-6 hover:bg-[#1d1d21] hover:border-[#6366F1]/30 hover:shadow-[0_20px_40px_rgba(0,0,0,0.4)] transition-all cursor-pointer\" data-kid=\"140\">\n                    <div class=\"w-12 h-12 bg-amber-500/10 rounded-xl flex items-center justify-center text-amber-500 shrink-0\" data-kid=\"141\">\n                        <i class=\"ti ti-file-type-doc text-2xl\" data-kid=\"142\"></i>\n                    </div>\n                    \n                    <div class=\"flex-grow min-w-0\" data-kid=\"143\">\n                        <div class=\"flex items-center gap-3 mb-1\" data-kid=\"144\">\n                            <h3 class=\"font-inter font-semibold text-base text-white truncate max-w-[280px]\" data-kid=\"145\">Marketing Strategist - Hubspot</h3>\n                            <span class=\"px-2 py-0.5 rounded bg-white/5 text-white/40 text-[10px] font-bold uppercase tracking-widest border border-white/10\" data-kid=\"146\">v1.0</span>\n                        </div>\n                        <div class=\"flex items-center gap-4 text-xs text-white/40\" data-kid=\"147\">\n                            <span class=\"flex items-center gap-1.5 whitespace-nowrap\" data-kid=\"148\"><i class=\"ti ti-calendar text-white/20\" data-kid=\"149\"></i> Modified yesterday</span>\n                            <span class=\"flex items-center gap-1.5 whitespace-nowrap\" data-kid=\"150\"><i class=\"ti ti-database text-white/20\" data-kid=\"151\"></i> 1.1 MB</span>\n                        </div>\n                    </div>\n\n                    <div class=\"w-32 flex flex-col items-center border-l border-white/5 shrink-0\" data-kid=\"152\">\n                        <span class=\"text-[9px] text-white/30 uppercase font-bold tracking-[0.2em] mb-1\" data-kid=\"153\">ATS Score</span>\n                        <div class=\"flex items-center gap-2\" data-kid=\"154\">\n                            <span class=\"text-2xl font-inter font-bold text-amber-400 tracking-tighter\" data-kid=\"155\">62</span>\n                            <div class=\"flex items-end gap-0.5 h-6\" data-kid=\"156\">\n                                <div class=\"w-1 h-2 bg-amber-400/30 rounded-full\" data-kid=\"157\"></div>\n                                <div class=\"w-1 h-4 bg-amber-400 rounded-full\" data-kid=\"158\"></div>\n                                <div class=\"w-1 h-6 bg-white/10 rounded-full\" data-kid=\"159\"></div>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"w-32 flex flex-col items-center border-l border-white/5 shrink-0\" data-kid=\"160\">\n                        <span class=\"bg-amber-500/10 text-amber-500 text-[10px] px-2.5 py-1 rounded-full font-bold uppercase tracking-wide border border-amber-500/20\" data-kid=\"161\">Needs Polish</span>\n                        <span class=\"text-[9px] text-white/30 italic mt-0.5\" data-kid=\"162\">Lacks Keywords</span>\n                    </div>\n\n                    <div class=\"flex items-center gap-1 shrink-0 ml-auto pl-4 border-l border-white/5\" data-kid=\"163\">\n                        <button class=\"p-2.5 rounded-xl hover:bg-white/5 text-white/40 hover:text-white transition-all\" data-kid=\"164\">\n                            <i class=\"ti ti-eye text-xl\" data-kid=\"165\"></i>\n                        </button>\n                        <button class=\"flex items-center gap-2 px-5 py-2.5 bg-[#6366F1] hover:bg-[#4f46e5] ro