      "html": "\n<div class=\"bg-[#F8FAFC] text-[#3730A3] font-['Red_Hat_Text'] overflow-x-hidden selection:bg-[#E0E7FF] selection:text-[#3730A3]\" data-kid=\"0\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css\" data-kid=\"1\">\n    <style data-kid=\"2\">\n        @import url('https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@400;500;600;700;800;900&family=Red+Hat+Text:wght@400;500&display=swap');\n\n        .font-display { font-family: 'Red Hat Display', sans-serif; }\n        \n        .glass {\n            background: rgba(255, 255, 255, 0.65);\n            backdrop-filter: blur(28px);\n            -webkit-backdrop-filter: blur(28px);\n            border: 1px solid rgba(255, 255, 255, 0.7);\n            box-shadow: 0 10px 40px -10px rgba(31, 38, 135, 0.05);\n        }\n\n        .glass-dark {\n            background: rgba(55, 48, 163, 0.05);\n            backdrop-filter: blur(12px);\n            border: 1px solid rgba(255, 255, 255, 0.7);\n        }\n\n        .mesh-bg {\n            position: absolute;\n            inset: 0;\n            z-index: 0;\n            background: \n                radial-gradient(at 0% 0%, #E0E7FF 0%, transparent 50%),\n                radial-gradient(at 100% 0%, #F5F3FF 0%, transparent 50%),\n                radial-gradient(at 100% 100%, #EEF2FF 0%, transparent 50%),\n                radial-gradient(at 0% 100%, #E0E7FF 0%, transparent 50%);\n            opacity: 0.8;\n        }\n\n        .orb {\n            position: absolute;\n            border-radius: 50%;\n            filter: blur(80px);\n            z-index: 1;\n            opacity: 0.6;\n        }\n\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n        .polaroid {\n            background: white;\n            padding: 12px 12px 48px 12px;\n            box-shadow: 0 20px 60px -15px rgba(31, 38, 135, 0.1);\n            border: 1px solid #f8fafc;\n            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n        .polaroid:hover {\n            transform: scale(1.1) rotate(0deg) !important;\n            z-index: 50;\n            box-shadow: 0 30px 80px rgba(55, 48, 163, 0.2);\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-10px); }\n        }\n        .animate-float { animation: float 6s ease-in-out infinite; }\n    </style>\n\n    \n    <header class=\"absolute top-0 left-0 right-0 z-[100] px-6 py-4 flex justify-center\" data-kid=\"3\">\n        <nav class=\"w-full max-w-6xl glass rounded-full px-6 py-3 flex justify-between items-center border border-white/70 shadow-lg\" data-kid=\"4\">\n            <div class=\"flex items-center gap-2\" data-kid=\"5\">\n                <div class=\"w-9 h-9 bg-[#3730A3] rounded-xl flex items-center justify-center shadow-lg shadow-indigo-900/20\" data-kid=\"6\">\n                    <i class=\"fa-solid fa-bolt-lightning text-white text-sm\" data-kid=\"7\"></i>\n                </div>\n                <span class=\"text-xl font-black text-[#3730A3] tracking-tight font-display\" data-kid=\"8\">CareerForge</span>\n            </div>\n            <div class=\"hidden md:flex items-center gap-8 text-[#3730A3]/60 font-semibold text-sm\" data-kid=\"9\">\n                <a href=\"#features\" class=\"hover:text-[#3730A3] transition-colors\" data-kid=\"10\">Features</a>\n                <a href=\"#how-it-works\" class=\"hover:text-[#3730A3] transition-colors\" data-kid=\"11\">Process</a>\n                <a href=\"#testimonials\" class=\"hover:text-[#3730A3] transition-colors\" data-kid=\"12\">Success Stories</a>\n                <a href=\"#pricing\" class=\"hover:text-[#3730A3] transition-colors\" data-kid=\"13\">Pricing</a>\n            </div>\n            <div class=\"flex items-center gap-3\" data-kid=\"14\">\n                <button class=\"text-sm font-bold text-[#3730A3]/70 px-4 py-2 hover:text-[#3730A3] transition-colors\" data-kid=\"15\">Login</button>\n                <button class=\"bg-[#3730A3] text-white px-5 py-2 rounded-full text-sm font-bold shadow-lg shadow-indigo-900/20 hover:bg-[#2D268A] transition-all transform hover:scale-105 active:scale-95\" data-kid=\"16\">Get Started</button>\n            </div>\n        </nav>\n    </header>\n\n    \n    <section class=\"min-h-[850px] relative flex flex-col items-center justify-center pt-24 pb-20 overflow-hidden\" data-kid=\"17\">\n        <div class=\"mesh-bg\" data-kid=\"18\"></div>\n        <div class=\"orb w-[600px] h-[600px] bg-[#818CF8]/30 -top-48 -left-48 animate-float\" data-kid=\"19\"></div>\n        <div class=\"orb w-[500px] h-[500px] bg-[#3730A3]/10 -bottom-24 -right-24\" style=\"animation: float 8s ease-in-out infinite reverse;\" data-kid=\"20\"></div>\n\n        <div class=\"relative z-10 w-full max-w-5xl px-6\" data-kid=\"21\">\n            \n            <div class=\"glass p-12 md:p-20 rounded-[60px] text-center border-white ring-1 ring-black/[0.02]\" data-kid=\"22\">\n                <div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/60 border border-indigo-100 text-[#3730A3] text-[10px] font-black mb-8 uppercase tracking-[0.2em] animate-pulse\" data-kid=\"23\">\n                    <span class=\"w-1.5 h-1.5 rounded-full bg-green-500\" data-kid=\"24\"></span>\n                    Now with GPT-4o Optimization\n                </div>\n                \n                <h1 class=\"text-5xl md:text-7xl lg:text-8xl font-black text-[#3730A3] leading-[0.95] mb-8 tracking-tighter font-display\" data-kid=\"25\">\n                    Land More Interviews <br data-kid=\"26\"> <span class=\"bg-gradient-to-r from-[#818CF8] to-[#3730A3] bg-clip-text text-transparent\" data-kid=\"27\">With AI Precision</span>\n                </h1>\n                \n                <p class=\"text-lg md:text-xl text-[#3730A3]/50 mb-12 max-w-2xl mx-auto leading-relaxed font-medium\" data-kid=\"28\">\n                    The modern toolkit that scans resumes, optimizes applications, and crafts your story for top-tier companies.\n                </p>\n\n                \n                <div class=\"max-w-xl mx-auto relative group\" data-kid=\"29\">\n                    <div class=\"absolute -inset-2 bg-gradient-to-r from-[#818CF8] to-[#3730A3] rounded-[30px] blur-2xl opacity-10 group-hover:opacity-25 transition duration-1000\" data-kid=\"30\"></div>\n                    <div class=\"relative bg-white p-2 rounded-[28px] flex flex-col sm:flex-row items-center gap-2 shadow-[0_20px_60px_-15px_rgba(55,48,163,0.15)] ring-1 ring-black/[0.05]\" data-kid=\"31\">\n                        <div class=\"flex-grow flex items-center px-6 w-full\" data-kid=\"32\">\n                            <i class=\"fa-solid fa-file-shield text-[#818CF8] mr-3\" data-kid=\"33\"></i>\n                            <input type=\"text\" placeholder=\"Upload your resume link...\" class=\"w-full py-4 outline-none text-[#3730A3] placeholder-[#3730A3]/30 font-bold text-base\" data-kid=\"34\">\n                        </div>\n                        <button class=\"w-full sm:w-auto bg-[#3730A3] text-white px-10 py-4 rounded-[22px] font-black text-base flex items-center justify-center gap-3 hover:bg-[#2D268A] transition-all transform hover:scale-[1.03] shadow-lg shadow-indigo-900/20 active:scale-95\" data-kid=\"35\">\n                            Analyze <i class=\"fa-solid fa-sparkles\" data-kid=\"36\"></i>\n                        </button>\n                    </div>\n                </div>\n                \n                <div class=\"mt-8 flex flex-wrap items-center justify-center gap-8 text-[#3730A3]/40\" data-kid=\"37\">\n                    <div class=\"flex items-center gap-2\" data-kid=\"38\">\n                        <i class=\"fa-solid fa-shield-check text-[#818CF8]\" data-kid=\"39\"></i>\n                        <span class=\"text-sm font-bold\" data-kid=\"40\">Privacy Guaranteed</span>\n                    </div>\n                    <div class=\"flex items-center gap-2\" data-kid=\"41\">\n                        <i class=\"fa-solid fa-bolt text-[#818CF8]\" data-kid=\"42\"></i>\n                        <span class=\"text-sm font-bold\" data-kid=\"43\">Real-time Analysis</span>\n                    </div>\n                    <div class=\"flex items-center gap-2\" data-kid=\"44\">\n                        <i class=\"fa-solid fa-users text-[#818CF8]\" data-kid=\"45\"></i>\n                        <span class=\"text-sm font-bold\" data-kid=\"46\">Used by 50k+ Pros</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"relative z-10 mt-24 w-full overflow-hidden\" data-kid=\"47\">\n            <div class=\"max-w-6xl mx-auto px-6\" data-kid=\"48\">\n                <p class=\"text-center text-[#3730A3]/30 text-xs font-black uppercase tracking-[0.3em] mb-12\" data-kid=\"49\">Candidates Hired At Elite Tech Firms</p>\n                <div class=\"flex flex-wrap justify-center items-center gap-12 md:gap-20 opacity-30 grayscale contrast-125\" data-kid=\"50\">\n                    <div class=\"flex items-center gap-3 text-3xl font-black font-display tracking-tighter\" data-kid=\"51\"><i class=\"fa-brands fa-google text-4xl\" data-kid=\"52\"></i> Google</div>\n                    <div class=\"flex items-center gap-3 text-3xl font-black font-display tracking-tighter\" data-kid=\"53\"><i class=\"fa-brands fa-meta text-4xl\" data-kid=\"54\"></i> Meta</div>\n                    <div class=\"flex items-center gap-3 text-3xl font-black font-display tracking-tighter\" data-kid=\"55\"><i class=\"fa-brands fa-amazon text-4xl\" data-kid=\"56\"></i> Amazon</div>\n                    <div class=\"flex items-center gap-3 text-3xl font-black font-display tracking-tighter\" data-kid=\"57\"><i class=\"fa-brands fa-apple text-4xl\" data-kid=\"58\"></i> Apple</div>\n                    <div class=\"flex items-center gap-3 text-3xl font-black font-display tracking-tighter\" data-kid=\"59\"><i class=\"fa-brands fa-microsoft text-4xl\" data-kid=\"60\"></i> Microsoft</div>\n                    <div class=\"flex items-center gap-3 text-3xl font-black font-display tracking-tighter\" data-kid=\"61\"><i class=\"fa-brands fa-spotify text-4xl\" data-kid=\"62\"></i> Spotify</div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"features\" class=\"py-32 relative\" data-kid=\"63\">\n        <div class=\"max-w-6xl mx-auto px-6\" data-kid=\"64\">\n            <div class=\"text-center mb-24\" data-kid=\"65\">\n                <span class=\"text-[#818CF8] font-black uppercase tracking-[0.4em] text-xs mb-4 block\" data-kid=\"66\">The Toolkit</span>\n                <h2 class=\"text-4xl md:text-6xl font-black text-[#3730A3] mb-6 font-display tracking-tight\" data-kid=\"67\">Everything You Need to Succeed</h2>\n                <p class=\"text-[#3730A3]/50 text-xl max-w-2xl mx-auto font-medium\" data-kid=\"68\">Stop guessing. Start measuring. Our AI tools give you the unfair advantage in every application.</p>\n            </div>\n\n            \n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"69\">\n                \n                <div class=\"glass p-10 rounded-[40px] border-white group hover:scale-[1.02] transition-all\" data-kid=\"70\">\n                    <div class=\"w-16 h-16 bg-[#F1F5F9] rounded-2xl flex items-center justify-center mb-8 group-hover:bg-[#E0E7FF] transition-colors\" data-kid=\"71\">\n                        <i class=\"fa-solid fa-radar text-[#3730A3] text-2xl\" data-kid=\"72\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-black text-[#3730A3] mb-4 font-display\" data-kid=\"73\">ATS Scanner</h3>\n                    <p class=\"text-[#3730A3]/60 leading-relaxed font-medium\" data-kid=\"74\">See exactly how recruiters see you. We simulate 100+ different applicant tracking systems to ensure you're never filtered out.</p>\n                </div>\n                \n                <div class=\"glass p-10 rounded-[40px] border-white group hover:scale-[1.02] transition-all bg-gradient-to-br from-white/60 to-transparent\" data-kid=\"75\">\n                    <div class=\"w-16 h-16 bg-[#F1F5F9] rounded-2xl flex items-center justify-center mb-8 group-hover:bg-[#E0E7FF] transition-colors\" data-kid=\"76\">\n                        <i class=\"fa-solid fa-wand-magic-sparkles text-[#3730A3] text-2xl\" data-kid=\"77\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-black text-[#3730A3] mb-4 font-display\" data-kid=\"78\">Resume Optimizer</h3>\n                    <h4 class=\"text-sm font-bold text-[#818CF8] mb-2 uppercase tracking-wide\" data-kid=\"79\">AI Powerhouse</h4>\n                    <p class=\"text-[#3730A3]/60 leading-relaxed font-medium\" data-kid=\"80\">Paste any job description and let our AI rewrite your bullet points for maximum impact and keyword relevance.</p>\n                </div>\n                \n                <div class=\"glass p-10 rounded-[40px] border-white group hover:scale-[1.02] transition-all\" data-kid=\"81\">\n                    <div class=\"w-16 h-16 bg-[#F1F5F9] rounded-2xl flex items-center justify-center mb-8 group-hover:bg-[#E0E7FF] transition-colors\" data-kid=\"82\">\n                        <i class=\"fa-solid fa-comments-question text-[#3730A3] text-2xl\" data-kid=\"83\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-black text-[#3730A3] mb-4 font-display\" data-kid=\"84\">Interview Copilot</h3>\n                    <p class=\"text-[#3730A3]/60 leading-relaxed font-medium\" data-kid=\"85\">Practice with an AI that listens and talks back. Get instant feedback on your tone, pacing, and technical accuracy.</p>\n                </div>\n                \n                <div class=\"glass p-10 rounded-[40px] border-white group hover:scale-[1.02] transition-all\" data-kid=\"86\">\n                    <div class=\"w-16 h-16 bg-[#F1F5F9] rounded-2xl flex items-center justify-center mb-8 group-hover:bg-[#E0E7FF] transition-colors\" data-kid=\"87\">\n                        <i class=\"fa-solid fa-diagram-project text-[#3730A3] text-2xl\" data-kid=\"88\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-black text-[#3730A3] mb-4 font-display\" data-kid=\"89\">Application Tracker</h3>\n                    <p class=\"text-[#3730A3]/60 leading-relaxed font-medium\" data-kid=\"90\">A unified command center for every application. Track deadlines, follow-ups, and offer details in one sleek dashboard.</p>\n                </div>\n                \n                <div class=\"glass p-10 rounded-[40px] border-white group hover:scale-[1.02] transition-all\" data-kid=\"91\">\n                    <div class=\"w-16 h-16 bg-[#F1F5F9] rounded-2xl flex items-center justify-center mb-8 group-hover:bg-[#E0E7FF] transition-colors\" data-kid=\"92\">\n                        <i class=\"fa-solid fa-envelope-open-text text-[#3730A3] text-2xl\" data-kid=\"93\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-black text-[#3730A3] mb-4 font-display\" data-kid=\"94\">Networking AI</h3>\n                    <p class=\"text-[#3730A3]/60 leading-relaxed font-medium\" data-kid=\"95\">Generate personalized LinkedIn reach-outs that actually get replies. We analyze the recipient's profile to craft the perfect hook.</p>\n                </div>\n                \n                <div class=\"glass p-10 rounded-[40px] border-white group hover:scale-[1.02] transition-all\" data-kid=\"96\">\n                    <div class=\"w-16 h-16 bg-[#F1F5F9] rounded-2xl flex items-center justify-center mb-8 group-hover:bg-[#E0E7FF] transition-colors\" data-kid=\"97\">\n                        <i class=\"fa-solid fa-map-location-dot text-[#3730A3] text-2xl\" data-kid=\"98\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-black text-[#3730A3] mb-4 font-display\" data-kid=\"99\">Career Mapping</h3>\n                    <p class=\"text-[#3730A3]/60 leading-relaxed font-medium\" data-kid=\"100\">Define your target role and let us chart the fastest path there. Identify skill gaps and get curated learning resources.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"how-it-works\" class=\"py-32 bg-[#E0E7FF]/20 relative overflow-hidden\" data-kid=\"101\">\n        <div class=\"max-w-6xl mx-auto px-6\" data-kid=\"102\">\n            <div class=\"flex flex-col md:flex-row items-end justify-between mb-20 gap-8\" data-kid=\"103\">\n                <div class=\"max-w-xl\" data-kid=\"104\">\n                    <span class=\"text-[#818CF8] font-black uppercase tracking-[0.4em] text-xs mb-4 block\" data-kid=\"105\">The Journey</span>\n                    <h2 class=\"text-4xl md:text-6xl font-black text-[#3730A3] font-display tracking-tight leading-tight\" data-kid=\"106\">Forge Your Path <br data-kid=\"107\"> in 4 Simple Steps</h2>\n                </div>\n                <div class=\"flex gap-4\" data-kid=\"108\">\n                    <button class=\"w-14 h-14 rounded-full border border-[#3730A3]/10 flex items-center justify-center text-[#3730A3] hover:bg-white transition-all\" data-kid=\"109\"><i class=\"fa-solid fa-chevron-left\" data-kid=\"110\"></i></button>\n                    <button class=\"w-14 h-14 rounded-full border border-[#3730A3]/10 flex items-center justify-center text-[#3730A3] hover:bg-white transition-all\" data-kid=\"111\"><i class=\"fa-solid fa-chevron-right\" data-kid=\"112\"></i></button>\n                </div>\n            </div>\n\n            \n            <div class=\"overflow-x-auto no-scrollbar pb-8 -mx-6\" data-kid=\"113\">\n                <div class=\"flex gap-8 px-6 min-w-max\" data-kid=\"114\">\n                    \n                    <div class=\"w-[400px] glass p-12 rounded-[50px] border-white/60 relative overflow-hidden\" data-kid=\"115\">\n                        <span class=\"absolute top-8 right-8 text-7xl font-black text-[#3730A3]/5 font-display\" data-kid=\"116\">01</span>\n                        <div class=\"w-16 h-16 bg-[#3730A3] rounded-2xl flex items-center justify-center mb-8 shadow-xl shadow-indigo-900/20\" data-kid=\"117\">\n                            <i class=\"fa-solid fa-cloud-arrow-up text-white text-2xl\" data-kid=\"118\"></i>\n                        </div>\n                        <h4 class=\"text-3xl font-black text-[#3730A3] mb-6 font-display\" data-kid=\"119\">Deep Upload</h4>\n                        <p class=\"text-[#3730A3]/60 text-lg leading-relaxed font-medium\" data-kid=\"120\">Securely upload your resume. We extract every semantic detail using our proprietary LLM models.</p>\n                        <div class=\"mt-8 flex items-center gap-3 text-[#818CF8] font-bold text-sm\" data-kid=\"121\">\n                            Learn more <i class=\"fa-solid fa-arrow-right\" data-kid=\"122\"></i>\n                        </div>\n                    </div>\n                    \n                    <div class=\"w-[400px] glass p-12 rounded-[50px] border-white/60 relative overflow-hidden\" data-kid=\"123\">\n                        <span class=\"absolute top-8 right-8 text-7xl font-black text-[#3730A3]/5 font-display\" data-kid=\"124\">02</span>\n                        <div class=\"w-16 h-16 bg-[#818CF8] rounded-2xl flex items-center justify-center mb-8 shadow-xl shadow-indigo-400/20\" data-kid=\"125\">\n                            <i class=\"fa-solid fa-vial text-white text-2xl\" data-kid=\"126\"></i>\n                        </div>\n                        <h4 class=\"text-3xl font-black text-[#3730A3] mb-6 font-display\" data-kid=\"127\">AI Optimization</h4>\n                        <p class=\"text-[#3730A3]/60 text-lg leading-relaxed font-medium\" data-kid=\"128\">Our AI suggests structural changes and key phrase optimizations based on actual hiring data.</p>\n                        <div class=\"mt-8 flex items-center gap-3 text-[#818CF8] font-bold text-sm\" data-kid=\"129\">\n                            Learn more <i class=\"fa-solid fa-arrow-right\" data-kid=\"130\"></i>\n                        </div>\n                    </div>\n                    \n                    <div class=\"w-[400px] glass p-12 rounded-[50px] border-white/60 relative overflow-hidden\" data-kid=\"131\">\n                        <span class=\"absolute top-8 right-8 text-7xl font-black text-[#3730A3]/5 font-display\" data-kid=\"132\">03</span>\n                        <div class=\"w-16 h-16 bg-[#3730A3] rounded-2xl flex items-center justify-center mb-8 shadow-xl shadow-indigo-900/20\" data-kid=\"133\">\n                            <i class=\"fa-solid fa-paper-plane text-white text-2xl\" data-kid=\"134\"></i>\n                        </div>\n                        <h4 class=\"text-3xl font-black text-[#3730A3] mb-6 font-display\" data-kid=\"135\">Smart Apply</h4>\n                        <p class=\"text-[#3730A3]/60 text-lg leading-relaxed font-medium\" data-kid=\"136\">Use our outreach automation to find hiring managers and send perfectly crafted messages.</p>\n                        <div class=\"mt-8 flex items-center gap-3 text-[#818CF8] font-bold text-sm\" data-kid=\"137\">\n                            Learn more <i class=\"fa-solid fa-arrow-right\" data-kid=\"138\"></i>\n                        </div>\n                    </div>\n                    \n                    <div class=\"w-[400px] glass p-12 rounded-[50px] border-white/60 relative overflow-hidden\" data-kid=\"139\">\n                        <span class=\"absolute top-8 right-8 text-7xl font-black text-[#3730A3]/5 font-display\" data-kid=\"140\">04</span>\n                        <div class=\"w-16 h-16 bg-green-500 rounded-2xl flex items-center justify-center mb-8 shadow-xl shadow-green-500/20\" data-kid=\"141\">\n                            <i class=\"fa-solid fa-trophy text-white text-2xl\" data-kid=\"142\"></i>\n                        </div>\n                        <h4 class=\"text-3xl font-black text-[#3730A3] mb-6 font-display\" data-kid=\"143\">Offer Accepted</h4>\n                        <p class=\"text-[#3730A3]/60 text-lg leading-relaxed font-medium\" data-kid=\"144\">Go into negotiations armed with market data and confidence to land the best possible offer.</p>\n                        <div class=\"mt-8 flex items-center gap-3 text-[#818CF8] font-bold text-sm\" data-kid=\"145\">\n                            Learn more <i class=\"fa-solid fa-arrow-right\" data-kid=\"146\"></i>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"testimonials\" class=\"py-32 relative bg-[#F8FAFC]\" data-kid=\"147\">\n        <div class=\"max-w-6xl mx-auto px-6\" data-kid=\"148\">\n            <div class=\"text-center mb-32\" data-kid=\"149\">\n                <span class=\"text-[#818CF8] font-black uppercase tracking-[0.4em] text-xs mb-4 block\" data-kid=\"150\">Success Stories</span>\n                <h2 class=\"text-4xl md:text-6xl font-black text-[#3730A3] mb-6 font-display tracking-tight\" data-kid=\"151\">Stories from the Forge</h2>\n            </div>\n\n            \n            <div class=\"relative h-[800px] w-full mt-20\" data-kid=\"152\">\n                \n                <div class=\"polaroid absolute top-0 left-[5%] w-72 -rotate-6 z-10\" data-kid=\"153\">\n                    <div class=\"bg-indigo-50 h-52 w-full mb-6 rounded overflow-hidden\" data-kid=\"154\">\n                        <img src=\"https://images.pexels.com/photos/1239291/pexels-photo-1239291.jpeg?auto=compress&cs=tinysrgb&w=400&q=80\" alt=\"Sarah\" class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all\" data-kid=\"155\">\n                    </div>\n                    <p class=\"text-base font-black text-[#3730A3] mb-2 leading-tight\" data-kid=\"156\">\"Landed a Sr. PM role at Google in just 3 weeks!\"</p>\n                    <p class=\"text-xs font-bold text-[#818CF8] uppercase tracking-wider\" data-kid=\"157\">Sarah J. • Product Manager</p>\n                </div>\n                \n                <div class=\"polaroid absolute top-20 right-[8%] w-72 rotate-3 z-20\" data-kid=\"158\">\n                    <div class=\"bg-blue-50 h-52 w-full mb-6 rounded overflow-hidden\" data-kid=\"159\">\n                        <img src=\"https://images.pexels.com/photos/1222271/pexels-photo-1222271.jpeg?auto=compress&cs=tinysrgb&w=400&q=80\" alt=\"Mike\" class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all\" data-kid=\"160\">\n                    </div>\n                    <p class=\"text-base font-black text-[#3730A3] mb-2 leading-tight\" data-kid=\"161\">\"The AI optimizer is literally magic. Recommending to everyone.\"</p>\n                    <p class=\"text-xs font-bold text-[#818CF8] uppercase tracking-wider\" data-kid=\"162\">Mike T. • Software Engineer</p>\n                </div>\n                \n                <div class=\"polaroid absolute bottom-20 left-[15%] w-72 rotate-2 z-30\" data-kid=\"163\">\n                    <div class=\"bg-purple-50 h-52 w-full mb-6 rounded overflow-hidden\" data-kid=\"164\">\n                        <img src=\"https://images.pexels.com/photos/733872/pexels-photo-733872.jpeg?auto=compress&cs=tinysrgb&w=400&q=80\" alt=\"Eliza\" class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all\" data-kid=\"165\">\n                    </div>\n                    <p class=\"text-base font-black text-[#3730A3] mb-2 leading-tight\" data-kid=\"166\">\"Interview Copilot saved my life. I went in feeling zero stress.\"</p>\n                    <p class=\"text-xs font-bold text-[#818CF8] uppercase tracking-wider\" data-kid=\"167\">Eliza R. • Marketing Director</p>\n                </div>\n                \n                <div class=\"polaroid absolute top-[40%] left-[40%] w-72 rotate-6 z-0 opacity-50 blur-xs\" data-kid=\"168\">\n                    <div class=\"bg-indigo-50 h-52 w-full mb-6 rounded overflow-hidden\" data-kid=\"169\">\n                        <img src=\"https://images.pexels.com/photos/91227/pexels-photo-91227.jpeg?auto=compress&cs=tinysrgb&w=400&q=80\" alt=\"David\" class=\"w-full h-full object-cover grayscale\" data-kid=\"170\">\n                    </div>\n                    <p class=\"text-base font-black text-[#3730A3] mb-2 leading-tight\" data-kid=\"171\">\"From zero replies to 5 interviews a week.\"</p>\n                    <p class=\"text-xs font-bold text-[#818CF8] uppercase tracking-wider\" data-kid=\"172\">David K. • Data Scientist</p>\n                </div>\n                \n                <div class=\"polaroid absolute bottom-4 right-[25%] w-72 -rotate-2 z-40\" data-kid=\"173\">\n                    <div class=\"bg-emerald-50 h-52 w-full mb-6 rounded overflow-hidden\" data-kid=\"174\">\n                        <img src=\"https://images.pexels.com/photos/1587009/pexels-photo-1587009.jpeg?auto=compress&cs=tinysrgb&w=400&q=80\" alt=\"Jessica\" class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all\" data-kid=\"175\">\n                    </div>\n                    <p class=\"text-base font-black text-[#3730A3] mb-2 leading-tight\" data-kid=\"176\">\"The salary negotiation tips alone paid for Pro ten times over.\"</p>\n                    <p class=\"text-xs font-bold text-[#818CF8] uppercase tracking-wider\" data-kid=\"177\">Jessica L. • Sales Lead</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"pricing\" class=\"py-32 relative overflow-hidden\" data-kid=\"178\">\n        <div class=\"max-w-6xl mx-auto px-6\" data-kid=\"179\">\n            <div class=\"text-center mb-24\" data-kid=\"180\">\n                <span class=\"text-[#818CF8] font-black uppercase tracking-[0.4em] text-xs mb-4 block\" data-kid=\"181\">Invest in Yourself</span>\n                <h2 class=\"text-4xl md:text-6xl font-black text-[#3730A3] mb-6 font-display tracking-tight\" data-kid=\"182\">Simple, Transparent Plans</h2>\n            </div>\n\n            \n            <div class=\"grid grid-cols-1 lg:grid-cols-4 gap-8\" data-kid=\"183\">\n                \n                <div class=\"lg:col-span-2 lg:row-span-2 rounded-[60px] p-12 bg-gradient-to-br from-[#3730A3] to-[#818CF8] text-white flex flex-col justify-between border border-white/10 shadow-[0_32px_80px_-20px_rgba(55,48,163,0.3)] relative overflow-hidden group\" data-kid=\"184\">\n                    <div class=\"absolute inset-0 bg-white/10 backdrop-blur-xl opacity-20\" data-kid=\"185\"></div>\n                    <div class=\"absolute -top-32 -right-32 w-96 h-96 bg-white/20 blur-[100px] rounded-full group-hover:bg-white/30 transition-all duration-700\" data-kid=\"186\"></div>\n                    <div data-kid=\"187\">\n                        <div class=\"inline-block px-4 py-1.5 rounded-full bg-white/20 backdrop-blur-md text-xs font-black uppercase tracking-widest mb-10\" data-kid=\"188\">Most Popular</div>\n                        <h3 class=\"text-5xl md:text-6xl font-black mb-6 font-display tracking-tight\" data-kid=\"189\">Pro Forge</h3>\n                        <p class=\"text-white/80 text-lg mb-12 font-medium max-w-sm leading-relaxed\" data-kid=\"190\">Everything you need to accelerate your career and land top-tier offers with confidence.</p>\n                        \n                        <div class=\"space-y-6 mb-12\" data-kid=\"191\">\n                            <div class=\"flex items-center gap-4 text-lg font-bold\" data-kid=\"192\">\n                                <div class=\"w-6 h-6 rounded-full bg-green-400/20 flex items-center justify-center\" data-kid=\"193\"><i class=\"fa-solid fa-check text-green-400 text-xs\" data-kid=\"194\"></i></div>\n                                <span data-kid=\"195\">Unlimited AI Resume Optimizations</span>\n                            </div>\n                            <div class=\"flex items-center gap-4 text-lg font-bold\" data-kid=\"196\">\n                                <div class=\"w-6 h-6 rounded-full bg-green-400/20 flex items-center justify-center\" data-kid=\"197\"><i class=\"fa-solid fa-check text-green-400 text-xs\" data-kid=\"198\"></i></div>\n                                <span data-kid=\"199\">Full Interview Copilot Suite</span>\n                            </div>\n                            <div class=\"flex items-center gap-4 text-lg font-bold\" data-kid=\"200\">\n                                <div class=\"w-6 h-6 rounded-full bg-green-400/20 flex items-center justify-center\" data-kid=\"201\"><i class=\"fa-solid fa-check text-green-400 text-xs\" data-kid=\"202\"></i></div>\n                                <span data-kid=\"203\">Networking Automation Tools</span>\n                            </div>\n                        </div>\n                    </div>\n                    \n                    <div class=\"relative z-10\" data-kid=\"204\">\n                        <div class=\"flex items-baseline gap-3 mb-10\" data-kid=\"205\">\n                            <span class=\"text-7xl font-black font-display\" data-kid=\"206\">$19</span>\n                            <span class=\"text-white/60 font-black uppercase tracking-widest text-xs\" data-kid=\"207\">per month</span>\n                        </div>\n                        <button class=\"w-full bg-white text-[#3730A3] py-6 rounded-3xl font-black text-xl shadow-2xl hover:scale-[1.02] transition-all transform active:scale-95 shadow-indigo-900/40 hover:shadow-indigo-900/60\" data-kid=\"208\">Upgrade to Pro</button>\n                    </div>\n                </div>\n\n                \n                <div class=\"md:col-span-2 glass rounded-[50px] p-10 flex flex-col justify-between group border-white\" data-kid=\"209\">\n                    <div data-kid=\"210\">\n                        <h3 class=\"text-3xl font-black text-[#3730A3] mb-4 font-display\" data-kid=\"211\">Free Explorer</h3>\n                        <p class=\"text-[#3730A3]/50 font-medium mb-6\" data-kid=\"212\">Test the waters with our basic analysis tools.</p>\n                        <div class=\"space-y-3\" data-kid=\"213\">\n                            <div class=\"flex items-center gap-3 text-sm font-bold text-[#3730A3]/70\" data-kid=\"214\">\n                                <i class=\"fa-solid fa-check text-[#818CF8]\" data-kid=\"215\"></i>\n                                <span data-kid=\"216\">3 AI Resume Scans / mo</span>\n                            </div>\n                            <div class=\"flex items-center gap-3 text-sm font-bold text-[#3730A3]/70\" data-kid=\"217\">\n                                <i class=\"fa-solid fa-check text-[#818CF8]\" data-kid=\"218\"></i>\n                                <span data-kid=\"219\">Basic Career Roadmap</span>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"mt-8 flex items-center justify-between gap-4\" data-kid=\"220\">\n                        <span class=\"text-4xl font-black text-[#3730A3] font-display\" data-kid=\"221\">$0</span>\n                        <button class=\"flex-grow bg-[#3730A3]/5 text-[#3730A3] py-4 rounded-2xl font-black hover:bg-[#3730A3]/10 transition-colors\" data-kid=\"222\">Start Free</button>\n                    </div>\n                </div>\n\n                \n                <div class=\"md:col-span-2 glass rounded-[50px] p-10 flex flex-col justify-between group border-white\" data-kid=\"223\">\n                    <div data-kid=\"224\">\n                        <h3 class=\"text-3xl font-black text-[#3730A3] mb-4 font-display\" data-kid=\"225\">Institution</h3>\n                        <p class=\"text-[#3730A3]/50 font-medium mb-6\" data-kid=\"226\">For bootcamps, universities, and coaching firms.</p>\n                        <div class=\"space-y-3\" data-kid=\"227\">\n                            <div class=\"flex items-center gap-3 text-sm font-bold text-[#3730A3]/70\" data-kid=\"228\">\n                                <i class=\"fa-solid fa-check text-[#818CF8]\" data-kid=\"229\"></i>\n                                <span data-kid=\"230\">Bulk Student Licenses</span>\n                            </div>\n                            <div class=\"flex items-center gap-3 text-sm font-bold text-[#3730A3]/70\" data-kid=\"231\">\n                                <i class=\"fa-solid fa-check text-[#818CF8]\" data-kid=\"232\"></i>\n                                <span data-kid=\"233\">Admin Analytics Dashboard</span>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"mt-8 flex items-center justify-between gap-4\" data-kid=\"234\">\n                        <span class=\"text-3xl font-black text-[#3730A3] font-display\" data-kid=\"235\">Custom</span>\n                        <button class=\"flex-grow bg-[#3730A3]/10 text-[#3730A3] py-4 rounded-2xl font-black hover:bg-[#3730A3]/20 transition-colors\" data-kid=\"236\">Contact Sales</button>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 relative\" data-kid=\"237\">\n        <div class=\"max-w-6xl mx-auto px-6\" data-kid=\"238\">\n            <div class=\"flex flex-col md:flex-row gap-20\" data-kid=\"239\">\n                \n                <div class=\"md:w-1/3\" data-kid=\"240\">\n                    <span class=\"text-[#818CF8] font-black uppercase tracking-[0.4em] text-xs mb-4 block\" data-kid=\"241\">Support</span>\n                    <h2 class=\"text-4xl md:text-6xl font-black text-[#3730A3] mb-8 font-display tracking-tight leading-tight\" data-kid=\"242\">Got <br data-kid=\"243\"> Questions?</h2>\n                    <p class=\"text-[#3730A3]/50 text-xl font-medium mb-12\" data-kid=\"244\">Can't find the answer you're looking for? Reach out to our 24/7 success team.</p>\n                    <a href=\"#\" class=\"inline-flex items-center gap-3 text-[#3730A3] font-black text-lg group\" data-kid=\"245\">\n                        Chat with Support\n                        <div class=\"w-10 h-10 rounded-full bg-[#3730A3]/5 flex items-center justify-center group-hover:translate-x-1 transition-transform\" data-kid=\"246\">\n                            <i class=\"fa-solid fa-arrow-right\" data-kid=\"247\"></i>\n                        </div>\n                    </a>\n                </div>\n                \n                <div class=\"md:w-2/3 space-y-6\" data-kid=\"248\">\n                    <div class=\"glass p-8 rounded-[32px] border-white group cursor-pointer hover:bg-white transition-all\" data-kid=\"249\">\n                        <div class=\"flex justify-between items-center\" data-kid=\"250\">\n                            <h4 class=\"text-xl font-black text-[#3730A3] font-display\" data-kid=\"251\">How secure is my personal data?</h4>\n                            <div class=\"w-8 h-8 rounded-full bg-[#3730A3]/5 flex items-center justify-center group-hover:bg-[#3730A3] group-hover:text-white transition-all\" data-kid=\"252\">\n                                <i class=\"fa-solid fa-plus text-xs\" data-kid=\"253\"></i>\n                            </div>\n                        </div>\n                        <div class=\"mt-6 text-[#3730A3]/50 font-medium leading-relaxed hidden group-hover:block\" data-kid=\"254\">\n                            We use bank-level AES-256 encryption for all data storage. Your resumes and personal info are never shared with third parties or used to train public AI models.\n                        </div>\n                    </div>\n                    <div class=\"glass p-8 rounded-[32px] border-white group cursor-pointer hover:bg-white transition-all\" data-kid=\"255\">\n                        <div class=\"flex justify-between items-center\" data-kid=\"256\">\n                            <h4 class=\"text-xl font-black text-[#3730A3] font-display\" data-kid=\"257\">Does it really work for high-end tech roles?</h4>\n                            <div class=\"w-8 h-8 rounded-full bg-[#3730A3]/5 flex items-center justify-center group-hover:bg-[#3730A3] group-hover:text-white transition-all\" data-kid=\"258\">\n                                <i class=\"fa-solid fa-plus text-xs\" data-kid=\"259\"></i>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"glass p-8 rounded-[32px] border-white group cursor-pointer hover:bg-white transition-all\" data-kid=\"260\">\n                        <div class=\"flex justify-between items-center\" data-kid=\"261\">\n                            <h4 class=\"text-xl font-black text-[#3730A3] font-display\" data-kid=\"262\">Can I cancel my Pro subscription anytime?</h4>\n                            <div class=\"w-8 h-8 rounded-full bg-[#3730A3]/5 flex items-center justify-center group-hover:bg-[#3730A3] group-hover:text-white transition-all\" data-kid=\"263\">\n                                <i class=\"fa-solid fa-plus text-xs\" data-kid=\"264\"></i>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"glass p-8 rounded-[32px] border-white group cursor-pointer hover:bg-white transition-all\" data-kid=\"265\">\n                        <div class=\"flex justify-between items-center\" data-kid=\"266\">\n                            <h4 class=\"text-xl font-black text-[#3730A3] font-display\" data-kid=\"267\">What AI models are powering the tools?</h4>\n                            <div class=\"w-8 h-8 rounded-full bg-[#3730A3]/5 flex items-center justify-center group-hover:bg-[#3730A3] group-hover:text-white transition-all\" data-kid=\"268\">\n                                <i class=\"fa-solid fa-plus text-xs\" data-kid=\"269\"></i>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"py-24 relative overflow-hidden\" data-kid=\"270\">\n        <div class=\"max-w-6xl mx-auto px-6 text-center\" data-kid=\"271\">\n            <div class=\"glass p-20 rounded-[60px] border-white mb-24 relative overflow-hidden\" data-kid=\"272\">\n                <div class=\"absolute inset-0 bg-gradient-to-br from-[#E0E7FF]/20 to-transparent\" data-kid=\"273\"></div>\n                <div class=\"relative z-10\" data-kid=\"274\">\n                    <h2 class=\"text-4xl md:text-7xl font-black text-[#3730A3] mb-8 font-display tracking-tight leading-none\" data-kid=\"275\">Ready to Forge <br data-kid=\"276\"> Your Future?</h2>\n                    <p class=\"text-[#3730A3]/50 text-xl font-medium mb-12 max-w-xl mx-auto\" data-kid=\"277\">Join 50,000+ ambitious professionals landing dream offers every week.</p>\n                    <button class=\"bg-[#3730A3] text-white px-12 py-5 rounded-3xl font-black text-2xl shadow-2xl shadow-indigo-900/30 hover:scale-105 transition-transform active:scale-95\" data-kid=\"278\">Get Started Free</button>\n                </div>\n            </div>\n\n            \n            <div class=\"max-w-5xl mx-auto\" data-kid=\"279\">\n                <div class=\"glass rounded-full p-4 flex flex-col md:flex-row items-center justify-between border-white shadow-2xl gap-8\" data-kid=\"280\">\n                    <div class=\"flex items-center gap-3 px-6\" data-kid=\"281\">\n                        <div class=\"w-10 h-10 bg-[#3730A3] rounded-xl flex items-center justify-center shadow-lg shadow-indigo-900/20\" data-kid=\"282\">\n                            <i class=\"fa-solid fa-bolt-lightning text-white text-sm\" data-kid=\"283\"></i>\n                        </div>\n                        <span class=\"text-2xl font-black text-[#3730A3] tracking-tight font-display\" data-kid=\"284\">CareerForge</span>\n                    </div>\n\n                    <div class=\"flex items-center gap-8 text-[#3730A3]/50 font-bold text-sm\" data-kid=\"285\">\n                        <a href=\"#\" class=\"hover:text-[#3730A3] transition-colors\" data-kid=\"286\">Twitter</a>\n                        <a href=\"#\" class=\"hover:text-[#3730A3] transition-colors\" data-kid=\"287\">LinkedIn</a>\n                        <a href=\"#\" class=\"hover:text-[#3730A3] transition-colors\" data-kid=\"288\">Discord</a>\n                        <a href=\"#\" class=\"hover:text-[#3730A3] transition-colors\" data-kid=\"289\">Privacy</a>\n                        <a href=\"#\" class=\"hover:text-[#3730A3] transition-colors\" data-kid=\"290\">Terms</a>\n                    </div>\n\n                    <div class=\"px-6 flex items-center gap-2 text-[#3730A3]/40 font-bold text-[10px] uppercase tracking-widest\" data-kid=\"291\">\n                        © 2024 • CareerForge AI\n                    </div>\n                </div>\n            </div>\n        </div>\n    </footer>\n</div>\n",
