      "html": "\n<div class=\"min-h-[1000px] bg-[#09090B] font-['DM_Sans'] text-zinc-300 flex flex-col items-center justify-center p-12 relative overflow-hidden\" data-kid=\"0\">\n    \n    <div class=\"absolute inset-0 overflow-hidden pointer-events-none\" data-kid=\"1\">\n        \n        <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[1000px] bg-indigo-600/15 blur-[160px] rounded-full\" data-kid=\"2\"></div>\n        \n        <div class=\"absolute top-[-15%] left-[-10%] w-[500px] h-[500px] bg-purple-600/10 blur-[120px] rounded-full\" data-kid=\"3\"></div>\n        <div class=\"absolute bottom-[-15%] right-[-10%] w-[500px] h-[500px] bg-blue-600/10 blur-[120px] rounded-full\" data-kid=\"4\"></div>\n        \n        \n        <div class=\"absolute inset-0 opacity-[0.04]\" style=\"background-image: linear-gradient(to right, #6366F11a 1px, transparent 1px), linear-gradient(to bottom, #6366F11a 1px, transparent 1px); background-size: 60px 60px;\" data-kid=\"5\"></div>\n    </div>\n\n    \n    <header class=\"absolute top-8 left-10 right-10 flex justify-between items-center z-20\" data-kid=\"6\">\n        <div class=\"flex items-center gap-3\" data-kid=\"7\">\n            <div class=\"relative\" data-kid=\"8\">\n                <div class=\"absolute inset-0 bg-indigo-500 blur-md opacity-40 rounded-full\" data-kid=\"9\"></div>\n                <div class=\"relative w-10 h-10 bg-[#18181B] border border-white/10 rounded-xl flex items-center justify-center shadow-lg\" data-kid=\"10\">\n                    <i class=\"ti ti-sparkles text-indigo-400 text-lg\" data-kid=\"11\"></i>\n                </div>\n            </div>\n            <span class=\"text-white text-xl font-bold font-['Inter'] tracking-tight\" data-kid=\"12\">CareerForge<span class=\"text-indigo-500\" data-kid=\"13\">.ai</span></span>\n        </div>\n        <a href=\"/\" class=\"group text-sm font-medium text-zinc-500 hover:text-white transition-all flex items-center gap-2 px-4 py-2 bg-white/5 hover:bg-white/10 rounded-full border border-white/5\" data-kid=\"14\">\n            <i class=\"ti ti-arrow-left transition-transform group-hover:-translate-x-1\" data-kid=\"15\"></i>\n            Back to website\n        </a>\n    </header>\n\n    \n    <main class=\"relative z-10 w-full max-w-[480px] my-12\" data-kid=\"16\">\n        <div class=\"bg-[#18181B]/80 backdrop-blur-3xl border border-white/10 rounded-[40px] p-10 md:p-14 shadow-[0_32px_64px_-16px_rgba(0,0,0,0.9)] relative group/card overflow-hidden\" data-kid=\"17\">\n            \n            <div class=\"absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-indigo-500/50 to-transparent\" data-kid=\"18\"></div>\n            <div class=\"absolute inset-y-0 left-0 w-px bg-gradient-to-b from-transparent via-indigo-500/10 to-transparent\" data-kid=\"19\"></div>\n            \n            <div class=\"text-center mb-10\" data-kid=\"20\">\n                <h1 class=\"text-3xl font-bold text-white font-['Inter'] mb-3 tracking-tight\" data-kid=\"21\">Join the future of work</h1>\n                <p class=\"text-zinc-500\" data-kid=\"22\">Sign up and build your dream career with AI.</p>\n            </div>\n\n            \n            <form class=\"space-y-6\" data-kid=\"23\">\n                \n                <div class=\"space-y-2\" data-kid=\"24\">\n                    <label for=\"name\" class=\"block text-xs font-bold text-zinc-500 uppercase tracking-widest ml-1\" data-kid=\"25\">Full Name</label>\n                    <div class=\"relative group\" data-kid=\"26\">\n                        <div class=\"absolute inset-0 bg-gradient-to-r from-indigo-500/20 to-purple-500/20 rounded-xl blur-md opacity-0 group-focus-within:opacity-100 transition-opacity\" data-kid=\"27\"></div>\n                        <div class=\"relative\" data-kid=\"28\">\n                            <span class=\"absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500 group-focus-within:text-indigo-400 transition-colors\" data-kid=\"29\">\n                                <i class=\"ti ti-user text-lg\" data-kid=\"30\"></i>\n                            </span>\n                            <input type=\"text\" id=\"name\" name=\"name\" placeholder=\"Alex Rivera\" class=\"w-full bg-[#09090B] border border-zinc-800 rounded-xl py-4 pl-11 pr-4 text-white placeholder-zinc-500 focus:outline-none focus:border-indigo-500/50 transition-all\" data-kid=\"31\">\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"space-y-2\" data-kid=\"32\">\n                    <label for=\"email\" class=\"block text-xs font-bold text-zinc-500 uppercase tracking-widest ml-1\" data-kid=\"33\">Email Address</label>\n                    <div class=\"relative group\" data-kid=\"34\">\n                        <div class=\"absolute inset-0 bg-gradient-to-r from-indigo-500/20 to-purple-500/20 rounded-xl blur-md opacity-0 group-focus-within:opacity-100 transition-opacity\" data-kid=\"35\"></div>\n                        <div class=\"relative\" data-kid=\"36\">\n                            <span class=\"absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500 group-focus-within:text-indigo-400 transition-colors\" data-kid=\"37\">\n                                <i class=\"ti ti-mail text-lg\" data-kid=\"38\"></i>\n                            </span>\n                            <input type=\"email\" id=\"email\" name=\"email\" placeholder=\"alex@careerforge.ai\" class=\"w-full bg-[#09090B] border border-zinc-800 rounded-xl py-4 pl-11 pr-4 text-white placeholder-zinc-500 focus:outline-none focus:border-indigo-500/50 transition-all\" data-kid=\"39\">\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"space-y-2\" data-kid=\"40\">\n                    <label for=\"password\" class=\"block text-xs font-bold text-zinc-500 uppercase tracking-widest ml-1\" data-kid=\"41\">Password</label>\n                    <div class=\"relative group\" data-kid=\"42\">\n                        <div class=\"absolute inset-0 bg-gradient-to-r from-indigo-500/20 to-purple-500/20 rounded-xl blur-md opacity-0 group-focus-within:opacity-100 transition-opacity\" data-kid=\"43\"></div>\n                        <div class=\"relative\" data-kid=\"44\">\n                            <span class=\"absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500 group-focus-within:text-indigo-400 transition-colors\" data-kid=\"45\">\n                                <i class=\"ti ti-lock text-lg\" data-kid=\"46\"></i>\n                            </span>\n                            <input type=\"password\" id=\"password\" name=\"password\" placeholder=\"••••••••\" class=\"w-full bg-[#09090B] border border-zinc-800 rounded-xl py-4 pl-11 pr-4 text-white placeholder-zinc-500 focus:outline-none focus:border-indigo-500/50 transition-all\" data-kid=\"47\">\n                        </div>\n                    </div>\n                    <div class=\"flex items-center justify-between px-1 pt-1\" data-kid=\"48\">\n                        <p class=\"text-[10px] text-zinc-400 uppercase font-bold tracking-widest\" data-kid=\"49\">Min. 8 characters</p>\n                        <button type=\"button\" class=\"text-[10px] text-indigo-400 hover:text-indigo-300 uppercase font-bold tracking-widest transition-colors\" data-kid=\"50\">Password strength</button>\n                    </div>\n                </div>\n\n                \n                <div class=\"pt-4\" data-kid=\"51\">\n                    <button type=\"submit\" class=\"group relative w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 rounded-xl transition-all shadow-[0_0_25px_rgba(99,102,241,0.2)] hover:shadow-[0_0_40px_rgba(99,102,241,0.4)] active:scale-[0.98] overflow-hidden\" data-kid=\"52\">\n                        \n                        <div class=\"absolute inset-0 w-[200%] h-full bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:animate-shimmer pointer-events-none\" data-kid=\"53\"></div>\n                        \n                        <span class=\"relative z-10 flex items-center justify-center gap-2\" data-kid=\"54\">\n                            Create Account\n                            <i class=\"ti ti-chevron-right text-sm\" data-kid=\"55\"></i>\n                        </span>\n                    </button>\n                </div>\n\n                \n                <p class=\"text-xs text-center text-zinc-500 leading-relaxed px-2\" data-kid=\"56\">\n                    By clicking \"Create Account\", you agree to our \n                    <a href=\"#\" class=\"text-zinc-300 hover:text-indigo-400 transition-colors underline underline-offset-4\" data-kid=\"57\">Terms of Service</a> \n                    and \n                    <a href=\"#\" class=\"text-zinc-300 hover:text-indigo-400 transition-colors underline underline-offset-4\" data-kid=\"58\">Privacy Policy</a>.\n                </p>\n            </form>\n\n            \n            <div class=\"flex items-center gap-4 my-8\" data-kid=\"59\">\n                <div class=\"h-[1px] flex-1 bg-zinc-800\" data-kid=\"60\"></div>\n                <span class=\"text-[10px] font-bold text-zinc-500 uppercase tracking-[0.25em]\" data-kid=\"61\">Or continue with</span>\n                <div class=\"h-[1px] flex-1 bg-zinc-800\" data-kid=\"62\"></div>\n            </div>\n\n            \n            <div class=\"grid grid-cols-2 gap-3\" data-kid=\"63\">\n                <button class=\"flex items-center justify-center gap-3 py-3.5 bg-[#09090B] border border-zinc-800 rounded-2xl text-white hover:bg-[#121214] transition-all hover:border-zinc-600 hover:shadow-lg\" data-kid=\"64\">\n                    <i class=\"ti ti-brand-google text-xl text-zinc-400\" data-kid=\"65\"></i>\n                    <span class=\"text-xs font-bold uppercase tracking-[0.1em]\" data-kid=\"66\">Google</span>\n                </button>\n                <button class=\"flex items-center justify-center gap-3 py-3.5 bg-[#09090B] border border-zinc-800 rounded-2xl text-white hover:bg-[#121214] transition-all hover:border-zinc-600 hover:shadow-lg\" data-kid=\"67\">\n                    <i class=\"ti ti-brand-github text-xl text-zinc-400\" data-kid=\"68\"></i>\n                    <span class=\"text-xs font-bold uppercase tracking-[0.1em]\" data-kid=\"69\">GitHub</span>\n                </button>\n            </div>\n        </div>\n\n        \n        <div class=\"mt-10 text-center\" data-kid=\"70\">\n            <p class=\"text-zinc-500 text-sm font-medium\" data-kid=\"71\">\n                Already have an account? \n                <a href=\"#\" class=\"text-white hover:text-indigo-400 font-bold transition-all ml-1.5 border-b border-white/20 hover:border-indigo-400 pb-1\" data-kid=\"72\">Sign in here</a>\n            </p>\n        </div>\n    </main>\n\n    \n    <div class=\"absolute bottom-12 left-12 opacity-10 hidden lg:block animate-pulse\" data-kid=\"73\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/checkered-diamond.svg\" class=\"w-20 h-20 invert grayscale\" alt data-kid=\"74\">\n    </div>\n    <div class=\"absolute top-12 right-12 opacity-10 hidden lg:block rotate-180 animate-pulse\" data-kid=\"75\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/checkered-diamond.svg\" class=\"w-20 h-20 invert grayscale\" alt data-kid=\"76\">\n    </div>\n</div>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"77\">\n<style data-kid=\"78\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=DM+Sans:wght@400;500;700&display=swap');\n\n  @keyframes shimmer {\n    100% {\n      transform: translateX(100%);\n    }\n  }\n\n  .animate-shimmer {\n    animation: shimmer 2s infinite linear;\n  }\n</style>\n",
