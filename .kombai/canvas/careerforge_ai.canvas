                    </div>\n\n                    <div class=\"flex items-center gap-1 shrink-0 ml-auto pl-4 border-l border-white/5\" data-kid=\"223\">\n                        <button class=\"p-2.5 rounded-xl hover:bg-white/5 text-white/40 hover:text-white transition-all\" data-kid=\"224\">\n                            <i class=\"ti ti-eye text-xl\" data-kid=\"225\"></i>\n                        </button>\n                        <button class=\"flex items-center gap-2 px-5 py-2.5 bg-white/5 hover:bg-white/10 rounded-xl text-sm font-bold text-white transition-all\" data-kid=\"226\">\n                            <i class=\"ti ti-sparkles text-[#6366F1]\" data-kid=\"227\"></i>\n                            Re-Optimize\n                        </button>\n                        <button class=\"p-2.5 rounded-xl hover:bg-red-500/10 text-white/40 hover:text-red-500 transition-all\" data-kid=\"228\">\n                            <i class=\"ti ti-dots-vertical text-xl\" data-kid=\"229\"></i>\n                        </button>\n                    </div>\n                </div>\n\n            </div>\n\n            \n            <div class=\"flex items-center justify-between mt-4 text-sm text-white/20 font-medium\" data-kid=\"230\">\n                <p data-kid=\"231\">Showing 1 to 4 of 12 resumes</p>\n                <div class=\"flex items-center gap-2\" data-kid=\"232\">\n                    <button class=\"p-2 rounded-lg bg-white/5 text-white/40 hover:text-white transition-colors\" data-kid=\"233\"><i class=\"ti ti-chevron-left\" data-kid=\"234\"></i></button>\n                    <button class=\"px-3 py-1 rounded-lg bg-[#6366F1] text-white\" data-kid=\"235\">1</button>\n                    <button class=\"px-3 py-1 rounded-lg hover:bg-white/5 transition-colors\" data-kid=\"236\">2</button>\n                    <button class=\"px-3 py-1 rounded-lg hover:bg-white/5 transition-colors\" data-kid=\"237\">3</button>\n                    <button class=\"p-2 rounded-lg bg-white